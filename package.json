{
  "name": "profevision",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@profevision/web",
    "dev:web:clean": "turbo clean --filter=@profevision/web && turbo dev --filter=@profevision/web",
    "dev:docs": "turbo dev --filter=@profevision/docs",
    "dev:docs:clean": "turbo clean --filter=@profevision/docs && turbo dev --filter=@profevision/docs",
    "dev:blog": "turbo dev --filter=@profevision/blog",
    "dev:blog:clean": "turbo clean --filter=@profevision/blog && turbo dev --filter=@profevision/blog",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "overrides": {
      "pg": "8.16.3"
    }
  }
}