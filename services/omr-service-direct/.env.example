# Server Configuration
PORT=8082
HOST=0.0.0.0

# Supabase JWT Validation (Dual-Mode Support)
SUPABASE_URL=https://xxx.supabase.co
# Legacy HS256 verification (keep during migration)
SUPABASE_JWT_SECRET=your_jwt_secret_here
# New ES256 verification via JWKS (set project ref to enable)
SUPABASE_PROJECT_REF=xxxyyyyzzzz

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://profevision.com,https://testing.profevision.com

# Image Processing
MAX_IMAGE_SIZE_MB=10
IMAGE_QUALITY=80
MAX_IMAGE_DIMENSION=800

# Logging
LOG_LEVEL=info
