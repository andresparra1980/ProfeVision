# ProfeVision - Environment Variables Example
# Copy this file to .env.local and configure your values

# ============================================
# Supabase Configuration
# ============================================

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# Application Configuration
# ============================================

# Public site URL (used for production deployments)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Node environment (development, production)
NODE_ENV=development

# ============================================
# AI Services (OpenRouter)
# ============================================

# OpenRouter API key for AI features
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Primary AI model
OPENAI_MODEL=google/gemini-2.5-flash-lite

# Fallback AI model
OPENAI_FALLBACK_MODEL=mistralai/ministral-8b

# ============================================
# LangSmith (AI Observability - Optional)
# ============================================

# Enable LangChain tracing
LANGCHAIN_TRACING_V2=true

# LangSmith API key
LANGCHAIN_API_KEY=your_langsmith_api_key_here

# LangSmith project name
LANGCHAIN_PROJECT=ProfeVision

# ============================================
# OMR Service Configuration
# ============================================

# OMR service URL
# - Local development (Docker): http://localhost:8000
# - Production (server físico): http://localhost:8000 (si Next.js está en el mismo servidor)
# - Production (Railway/cloud): https://omr-service-production.up.railway.app
OMR_SERVICE_URL=http://localhost:8000

# Alternative public URL (for client-side access if needed)
NEXT_PUBLIC_OMR_SERVICE_URL=http://localhost:8000

# OMR service API key (optional, for authentication)
OMR_SERVICE_API_KEY=your_omr_api_key_here

# Alternative public API key (only if service is publicly accessible)
# NEXT_PUBLIC_OMR_SERVICE_API_KEY=your_public_omr_api_key_here

# OMR request timeout in milliseconds (default: 30000 = 30 seconds)
OMR_TIMEOUT_MS=30000

# ============================================
# OMR Service Migration Flags
# ============================================

# Use the new OMR HTTP service instead of legacy Python script
# Set to "true" to always use the new service
# Set to "false" to always use the legacy service
OMR_USE_NEW_SERVICE=false

# Canary deployment: percentage of requests to route to new service (0-100)
# Example: 10 = 10% of requests use new service, 90% use legacy
# This is used for gradual migration / A/B testing
# Set to 0 to disable canary routing
OMR_CANARY_PERCENTAGE=0

# ============================================
# Example Production Configuration (Vercel + Hetzner)
# ============================================

# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_key
# NEXT_PUBLIC_SITE_URL=https://profevision.com
# OPENROUTER_API_KEY=your_key
# OMR_SERVICE_URL=http://localhost:8000
# OMR_SERVICE_API_KEY=your_secure_api_key
# OMR_USE_NEW_SERVICE=true
# OMR_CANARY_PERCENTAGE=0
# NODE_ENV=production

# ============================================
# Example Canary Deployment Configuration
# ============================================

# Gradually migrate to new OMR service:
# Week 1: OMR_CANARY_PERCENTAGE=10
# Week 2: OMR_CANARY_PERCENTAGE=25
# Week 3: OMR_CANARY_PERCENTAGE=50
# Week 4: OMR_CANARY_PERCENTAGE=100 or OMR_USE_NEW_SERVICE=true
