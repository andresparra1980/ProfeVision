# URL y claves de Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:3000

# Configuración de OpenRouter AI
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# Configuración de almacenamiento
UPLOAD_DIR=/tmp/profevision-uploads

# Configuración de análisis OMR
PYTHON_EXECUTABLE=python3
OMR_SCRIPT_PATH=scripts/omr/omr_standalone.py

# Cloudflare Turnstile (CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Configuración de PayU
PAYU_API_KEY=your-payu-api-key
PAYU_API_LOGIN=your-payu-api-login
PAYU_MERCHANT_ID=your-payu-merchant-id
PAYU_ACCOUNT_ID=your-payu-account-id
NEXT_PUBLIC_PAYU_TEST=true 