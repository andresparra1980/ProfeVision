# Supabase Configuration
# Client-side: Use new publishable anon key (sb_publishable_*) with ES256 JWT signing
# Legacy anon keys (eyJ...) with HS256 are still supported during migration (Phase 1-2)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Server-side: Use new secret key (sb_secret_*) instead of legacy service_role key
# Migration to sb_secret_* happens in Phase 3 - keep legacy key until then
SUPABASE_SERVICE_ROLE_KEY=eyJ_legacy_service_role_key_here

# Google Tag Manager (GTM) via Cloudflare Gateway
NEXT_PUBLIC_GTM_ID=GTM-5SFVLZMG

# Other environment variables...
# Add your other env vars here
