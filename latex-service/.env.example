# ProfeVision LaTeX Service - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Server Configuration
# ============================================

# Port to run the service on
PORT=8001

# Logging level (debug, info, warning, error)
LOG_LEVEL=info

# ============================================
# Security
# ============================================

# API key for authentication (optional but recommended)
# Generate with: openssl rand -hex 32
# Leave empty to disable authentication (NOT recommended for production)
API_KEY=your_api_key_here

# ============================================
# LaTeX Compilation Limits
# ============================================

# Maximum LaTeX source file size in megabytes
MAX_TEX_SIZE_MB=1

# Compilation timeout in seconds
COMPILE_TIMEOUT_SEC=60

# ============================================
# CORS Configuration
# ============================================

# Allowed origins for CORS (comma-separated)
# For development:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# For production (example):
# ALLOWED_ORIGINS=https://profevision.vercel.app,https://www.profevision.com

# ============================================
# Example Production Configuration
# ============================================

# PORT=8001
# LOG_LEVEL=info
# API_KEY=your_secure_api_key_generated_with_openssl
# MAX_TEX_SIZE_MB=2
# COMPILE_TIMEOUT_SEC=90
# ALLOWED_ORIGINS=https://profevision.vercel.app,https://www.profevision.com
