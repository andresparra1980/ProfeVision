{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalPassThroughEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
    "NEXT_PUBLIC_USE_DIRECT_OMR",
    "NEXT_PUBLIC_OMR_DIRECT_URL",
    "NEXT_PUBLIC_AI_CHAT_MASTRA",
    "NEXT_PUBLIC_AUTO_CAPTURE",
    "NEXT_PUBLIC_EXPERIMENTAL_AUTO_CAM",
    "NEXT_PUBLIC_POLAR_PRODUCT_ID_MONTHLY",
    "NEXT_PUBLIC_POLAR_PRODUCT_ID_ANNUAL",
    "SUPABASE_PROJECT_ID",
    "SUPABASE_SERVICE_ROLE_KEY",
    "OPENROUTER_API_KEY",
    "OPENAI_MODEL",
    "OPENAI_FALLBACK_MODEL",
    "LANGSMITH_TRACING",
    "LANGSMITH_ENDPOINT",
    "LANGSMITH_API_KEY",
    "LANGSMITH_PROJECT",
    "S3_SUPABASE_URL",
    "S3_SUPABASE_ACCESS_KEY",
    "S3_SUPABASE_SECRET_KEY",
    "S3_BUCKET_NAME",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASSWORD",
    "SMTP_FROM_EMAIL",
    "SMTP_TO_EMAIL",
    "TURNSTILE_SECRET_KEY",
    "EXAM_RESPONSE_SHEET_SECRET_KEY",
    "EXAM_RESPONSE_SHEET_SALT",
    "SIMILAR_EXAM_MIN_STEP_MS",
    "TEX_WORK_DIR_BASE",
    "OMR_SERVICE_URL",
    "OMR_SERVICE_API_KEY",
    "OMR_USE_NEW_SERVICE",
    "ENABLE_OMR_DEBUG",
    "ENABLE_DEBUG_LOGS",
    "LATEX_USE_NEW_SERVICE",
    "LATEX_SERVICE_URL",
    "LATEX_SERVICE_API_KEY",
    "LATEX_TIMEOUT_MS",
    "AI_CHAT_MASTRA",
    "POLAR_ACCESS_TOKEN",
    "POLAR_SUCCESS_URL",
    "POLAR_WEBHOOK_SECRET",
    "POLAR_SERVER_ID",
    "POLAR_PRODUCT_ID_MONTHLY",
    "POLAR_PRODUCT_ID_ANNUAL",
    "POLAR_ENVIRONMENT",
    "SEND_PLUS_WELCOME_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
