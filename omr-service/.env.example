# ProfeVision OMR Service - Environment Variables
# Copy this file to .env and configure your values

# ============================================
# Server Configuration
# ============================================

# Port for the OMR service (default: 8000)
PORT=8000

# Host to bind to (default: 0.0.0.0 for Docker, 127.0.0.1 for local)
HOST=0.0.0.0

# Logging level (debug, info, warning, error)
LOG_LEVEL=info

# ============================================
# Security
# ============================================

# API Key for authentication (leave empty to disable)
# Generate with: openssl rand -hex 32
API_KEY=your_secure_random_api_key_here

# ============================================
# Image Processing Configuration
# ============================================

# Maximum image size in MB (default: 10)
MAX_IMAGE_SIZE_MB=10

# Enable debug images generation (true/false)
# Debug images show detected bubbles and QR codes
ENABLE_DEBUG_IMAGES=false

# ============================================
# CORS Configuration
# ============================================

# Comma-separated list of allowed origins
# For local development: http://localhost:3000
# For production: https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# Example Production Configuration
# ============================================

# PORT=8000
# LOG_LEVEL=info
# API_KEY=your_production_api_key
# MAX_IMAGE_SIZE_MB=10
# ENABLE_DEBUG_IMAGES=false
# ALLOWED_ORIGINS=https://profevision.com,https://www.profevision.com
