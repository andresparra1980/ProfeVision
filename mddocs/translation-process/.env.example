# =============================================================================
# Translation Process - Environment Variables
# =============================================================================
# 
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# IMPORTANT: Never commit .env.local to git (already in .gitignore)
# =============================================================================

# OpenRouter API Key (REQUIRED)
# Get your key at: https://openrouter.ai/keys
# Used by: translate-ui.py, translate-docs.py
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Translation Model (OPTIONAL)
# Default: google/gemini-3-flash-preview
# Alternatives: anthropic/claude-3-5-sonnet, openai/gpt-4-turbo
# TRANSLATION_MODEL=google/gemini-3-flash-preview

# Temperature for translations (OPTIONAL)
# Range: 0.0 (deterministic) to 1.0 (creative)
# Default: 0.3 (recommended for translations)
# TRANSLATION_TEMPERATURE=0.3

# Max tokens per request (OPTIONAL)
# Default: 4096
# TRANSLATION_MAX_TOKENS=4096

# Rate limit delay in seconds (OPTIONAL)
# Default: 0.5 seconds between requests
# TRANSLATION_RATE_LIMIT=0.5
