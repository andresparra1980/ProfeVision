'use client';

import { useEffect, useState, useRef } from 'react';
import { useExamChat } from './lib/useExamChat';
import MarkdownRenderer from './components/MarkdownRenderer';
import ExamConversationSidebar from './components/ExamConversationSidebar';
import ExamQuestionDisplay from './components/ExamQuestionDisplay';
import ExamPreview from './components/ExamPreview';
import LoadingSpinner from './components/LoadingSpinner';
// import { DocumentContextIndicator } from './components/DocumentContextIndicator'; // Replaced by DocumentContextBar
import { DocumentContextBar, ProcessingFile } from './components/DocumentContextBar';
import { DocumentDetailModal } from './components/DocumentDetailModal';
// import { ExamService } from './lib/examDatabase'; // Not used in production anymore
import { TopicSummary } from './lib/examDatabase';
import { useDocumentContext } from './lib/hooks/useDocumentContext';

import QuickSuggestions from './components/QuickSuggestions';
import ExamStats from './components/ExamStats';
import { Message } from '@ai-sdk/react';
// import { TopicSummary } from './lib/examDatabase'; // Will be used in DocumentContextBar

export default function ExamChat() {
  const [isClient, setIsClient] = useState(false);
  const [sidebarOpen, setSidebarOpen] = useState(true);
  const [showPreview, setShowPreview] = useState(false);

  const [showSuggestions, setShowSuggestions] = useState(true);
  const [showStats, setShowStats] = useState(false);
  const [documentError, setDocumentError] = useState<string | null>(null);
  const [processingFiles, setProcessingFiles] = useState<ProcessingFile[]>([]);
  const [selectedDocumentForDetails, setSelectedDocumentForDetails] = useState<TopicSummary | null>(null);

  const {
    messages,
    input,
    handleInputChange,
    handleSubmit,
    isLoading,
    currentConversationId,
    conversations,
    extractedQuestions,
    createNewExamConversation,
    loadExamConversation,
    deleteExamConversation,
    updateConversationTitle,
    isLoadingConversations,
    isSaving,
    isProcessingQuestions,
    exportQuestions,
    // Document context
    topicSummaries,
    hasDocumentContext,
    // documentContextSummary, // Not used in UI anymore
    // addTopicSummaryToConversation, // Not used in new design
    removeTopicSummaryFromConversation,
    loadConversationTopicSummaries,
  } = useExamChat({
    api: '/api/chat',
    autoSave: true,
    autoSaveDelay: 1500,
    enableDocumentContext: true,
  });

  // Document processing hook
  const {
    processDocument,
    isProcessing: isDocumentProcessing,
    processingStatus,
    validateFile
  } = useDocumentContext();

  // Convert real processingStatus to ProcessingFile for UI
  const getCurrentProcessingFile = (): ProcessingFile | null => {
    if (!isDocumentProcessing || !processingStatus.fileName) return null;
    
    return {
      id: 'current-processing',
      fileName: processingStatus.fileName,
      fileType: getFileTypeFromFileName(processingStatus.fileName),
      status: processingStatus.stage === 'extracting' ? 'extracting' : 
              processingStatus.stage === 'summarizing' ? 'summarizing' :
              processingStatus.stage === 'saving' ? 'summarizing' : 'queued',
      progress: processingStatus.progress,
      error: processingStatus.stage === 'error' ? processingStatus.message : undefined
    };
  };

  const getFileTypeFromFileName = (fileName: string): ProcessingFile['fileType'] => {
    const extension = fileName.split('.').pop()?.toLowerCase();
    switch (extension) {
      case 'pdf': return 'pdf';
      case 'doc': case 'docx': return 'docx';
      case 'ppt': case 'pptx': return 'pptx';
      default: return 'pdf';
    }
  };

  const currentProcessingFile = getCurrentProcessingFile();
  const allProcessingFiles = currentProcessingFile ? [currentProcessingFile, ...processingFiles] : processingFiles;

  // Ref for the chat messages container to enable auto-scrolling
  const chatContainerRef = useRef<HTMLDivElement>(null);
  const fileInputRef = useRef<HTMLInputElement>(null);

  // Set client side rendering flag
  useEffect(() => {
    setIsClient(true);
  }, []);

  // Auto-scroll to the bottom when messages or questions change
  useEffect(() => {
    if (chatContainerRef.current) {
      chatContainerRef.current.scrollTop = chatContainerRef.current.scrollHeight;
    }
  }, [messages, extractedQuestions]);

  // Auto-reload topic summaries when document processing completes
  useEffect(() => {
    const reloadTopicSummaries = async () => {
      if (
        processingStatus.stage === 'completed' && 
        currentConversationId && 
        processingStatus.fileName
      ) {
        console.log('🔄 Document processing completed, reloading topic summaries...');
        try {
          await loadConversationTopicSummaries(currentConversationId);
          console.log('✅ Topic summaries reloaded successfully');
        } catch (error) {
          console.error('❌ Failed to reload topic summaries:', error);
        }
      }
    };

    reloadTopicSummaries();
  }, [processingStatus.stage, processingStatus.fileName, currentConversationId, loadConversationTopicSummaries]);

  const handleCreateNew = async () => {
    await createNewExamConversation();
  };

  const handleSelectConversation = async (id: number) => {
    await loadExamConversation(id);
  };

  const handleDeleteConversation = async (id: number) => {
    await deleteExamConversation(id);
  };

  const handleUpdateTitle = async (id: number, title: string) => {
    await updateConversationTitle(id, title);
  };

  const handleExportQuestions = async () => {
    try {
      const jsonData = await exportQuestions();
      // Create and download file
      const blob = new Blob([jsonData], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      const currentConv = conversations.find(c => c.id === currentConversationId);
      const filename = currentConv?.titulo.replace(/[^a-z0-9]/gi, '_').toLowerCase() || 'exam';
      // Use a fixed timestamp to avoid hydration mismatches
      const timestamp = new Date().toISOString().split('T')[0];
      a.download = `${filename}-${timestamp}.json`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    } catch (error) {
      console.error('Failed to export questions:', error);
      alert('Error al exportar preguntas');
    }
  };



  const handleShowPreview = () => {
    setShowPreview(true);
  };

  const handleSuggestionClick = (suggestion: string) => {
    handleInputChange({ target: { value: suggestion } } as React.ChangeEvent<HTMLInputElement>);
    setShowSuggestions(false);
  };

  // Document context handlers - kept for future use
  // const handleDocumentProcessed = async (summary: TopicSummary) => {
  //   try {
  //     await addTopicSummaryToConversation(summary);
  //     setDocumentError(null);
  //   } catch (error) {
  //     const errorMessage = error instanceof Error ? error.message : 'Error añadiendo documento';
  //     setDocumentError(errorMessage);
  //   }
  // };

  const handleRemoveDocument = async (summaryId: string) => {
    try {
      await removeTopicSummaryFromConversation(summaryId);
      setDocumentError(null);
    } catch (error) {
      const errorMessage = error instanceof Error ? error.message : 'Error eliminando documento';
      setDocumentError(errorMessage);
    }
  };

  const handleRemoveProcessingFile = (fileId: string) => {
    setProcessingFiles(prev => prev.filter(file => file.id !== fileId));
  };

  const handleViewDocumentDetails = (summary: TopicSummary) => {
    setSelectedDocumentForDetails(summary);
  };

  const handleCloseDocumentDetails = () => {
    setSelectedDocumentForDetails(null);
  };

  // File attachment handlers
  const handleAttachmentClick = () => {
    if (fileInputRef.current) {
      fileInputRef.current.click();
    }
  };

  const handleFileSelect = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file || !currentConversationId) return;

    // Clear any previous errors
    setDocumentError(null);

    try {
      // Validate file first using the hook
      const validation = await validateFile(file);
      if (!validation.isValid) {
        setDocumentError(validation.error || 'Archivo no válido');
        return;
      }

      // Process the document using the real hook
      const summary = await processDocument(file, currentConversationId);
      
      // Clear the file input
      if (fileInputRef.current) {
        fileInputRef.current.value = '';
      }
      
      console.log('Document processed successfully:', summary);
      
      // Reload topic summaries to update the UI with the new document
      await loadConversationTopicSummaries(currentConversationId);
      
      console.log('✅ Document context updated in UI');
    } catch (error) {
      console.error('Error processing file:', error);
      setDocumentError(`Error procesando archivo: ${error instanceof Error ? error.message : 'Error desconocido'}`);
    }
  };



  // const handleClearDocumentContext = async () => {
  //   try {
  //     // Remove all topic summaries from current conversation
  //     for (const summary of topicSummaries) {
  //       await removeTopicSummaryFromConversation(summary.id);
  //     }
  //     setDocumentError(null);
  //   } catch (error) {
  //     const errorMessage = error instanceof Error ? error.message : 'Error limpiando contexto';
  //     setDocumentError(errorMessage);
  //   }
  // };

  // Debug function - not used in production anymore
  // const handleCleanDuplicates = async () => {
  //   try {
  //     if (currentConversationId) {
  //       await ExamService.cleanDuplicateSummaries(currentConversationId);
  //       
  //       // Reload conversation to get updated summaries
  //       await loadExamConversation(currentConversationId);
  //       
  //       alert('Duplicados eliminados exitosamente');
  //     }
  //   } catch (error) {
  //     console.error('Error cleaning duplicates:', error);
  //     alert('Error al limpiar duplicados');
  //   }
  // };




  if (!isClient) {
    return (
      <div className="flex h-screen bg-gray-100">
        <div className="w-80 bg-gray-50 border-r border-gray-200 flex items-center justify-center">
          <LoadingSpinner size="md" color="gray" text="Cargando conversaciones..." />
        </div>
        <div className="flex-1 flex flex-col">
          {/* Header */}
          <div className="bg-indigo-600 text-white p-4">
            <h1 className="text-2xl font-bold">Proficiency Chat Exam Creation</h1>
            <p className="text-indigo-100">Chat with AI to create and manage exams</p>
          </div>

          {/* Loading placeholder */}
          <div className="flex-1 flex items-center justify-center">
            <LoadingSpinner
              size="lg"
              color="blue"
              text="Inicializando interfaz de examen..."
              className="text-gray-500"
            />
          </div>

          {/* Input placeholder */}
          <div className="border-t bg-white p-4">
            <div className="flex space-x-2">
              <div className="flex-1 border border-gray-300 rounded-lg px-4 py-2 bg-gray-100"></div>
              <div className="bg-gray-400 px-6 py-2 rounded-lg"></div>
            </div>
          </div>
        </div>
      </div>
    );
  }

  const currentConversation = conversations.find(c => c.id === currentConversationId);

  return (
    <div className="flex h-screen bg-gray-100">
      {/* Sidebar */}
      {sidebarOpen && (
        <ExamConversationSidebar
          conversations={conversations}
          currentConversationId={currentConversationId}
          onSelectConversation={handleSelectConversation}
          onCreateNew={handleCreateNew}
          onDeleteConversation={handleDeleteConversation}
          onUpdateTitle={handleUpdateTitle}
          isLoading={isLoadingConversations}
          isSaving={isSaving}
        />
      )}

      {/* Main Chat/Exam Area */}
      <div className="flex-1 flex flex-col max-h-screen">
        {/* Header */}
        <div className="bg-indigo-600 text-white p-4 flex items-center justify-between shrink-0">
          <div className="flex items-center gap-3">
            {!sidebarOpen && (
              <button
                onClick={() => setSidebarOpen(true)}
                className="p-1 text-indigo-100 hover:text-white hover:bg-indigo-700 rounded transition-colors"
                title="Mostrar exámenes"
              >
                <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 6h16M4 12h16M4 18h16" />
                </svg>
              </button>
            )}
            <div className="flex-1">
              <p className="text-indigo-100">
                {currentConversation ? currentConversation.titulo : 'Selecciona o crea un examen'}
              </p>
            </div>
          </div>

          <div className="flex items-center gap-3">
            {/* Action buttons */}
            {extractedQuestions.length > 0 && (
              <>
                <button
                  onClick={handleShowPreview}
                  className="px-3 py-1 text-sm font-medium text-indigo-100 bg-indigo-700 rounded-md hover:bg-indigo-800 transition-colors"
                >
                  Vista Previa ({extractedQuestions.length})
                </button>
                <button
                  onClick={() => setShowStats(!showStats)}
                  className="px-3 py-1 text-sm font-medium text-indigo-100 bg-indigo-700 rounded-md hover:bg-indigo-800 transition-colors"
                >
                  Estadísticas
                </button>
              </>
            )}
            


            {sidebarOpen && (
              <button
                onClick={() => setSidebarOpen(false)}
                className="p-2 text-indigo-100 hover:text-white hover:bg-indigo-700 rounded transition-colors"
                title="Ocultar exámenes"
              >
                <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            )}

            {/* Status indicators */}
            {isSaving && (
              <div className="flex items-center gap-2 text-indigo-100 text-sm">
                <div className="w-3 h-3 border border-indigo-100 border-t-transparent rounded-full animate-spin"></div>
                <span className="hidden sm:inline">Guardando...</span>
              </div>
            )}

             {isProcessingQuestions && (
              <div className="flex items-center gap-2 text-indigo-100 text-sm">
                <div className="w-3 h-3 border border-indigo-100 border-t-transparent rounded-full animate-spin"></div>
                <span className="hidden sm:inline">Procesando...</span>
              </div>
            )}
          </div>
        </div>

        {/* Document Context Bar */}
        {(hasDocumentContext || allProcessingFiles.length > 0) && currentConversationId && (
          <DocumentContextBar
            topicSummaries={topicSummaries}
            processingFiles={allProcessingFiles}
            onRemoveDocument={handleRemoveDocument}
            onRemoveProcessingFile={handleRemoveProcessingFile}
            onViewDocumentDetails={handleViewDocumentDetails}
          />
        )}

        {/* Document Error Display */}
        {documentError && (
          <div className="bg-red-50 border-l-4 border-red-400 p-4 mx-4">
            <div className="flex">
              <div className="flex-shrink-0">
                <svg className="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clipRule="evenodd" />
                </svg>
              </div>
              <div className="ml-3">
                <p className="text-sm text-red-700">{documentError}</p>
                <button
                  onClick={() => setDocumentError(null)}
                  className="mt-2 text-xs text-red-600 hover:text-red-800 underline"
                >
                  Cerrar
                </button>
              </div>
            </div>
          </div>
        )}





        {/* Chat Messages and Extracted Questions Area */}
      <div ref={chatContainerRef} className="flex-1 overflow-y-auto p-4 space-y-4 bg-white">
          {currentConversationId === null ? (
            <div className="flex flex-col items-center justify-center h-full text-center text-gray-500">
               <svg className="mx-auto h-16 w-16 text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
              <p className="text-lg mb-2">
                ¡Bienvenido al Creador de Exámenes!
              </p>
              <p className="text-sm">
                Selecciona un examen existente o crea uno nuevo para empezar.
              </p>
              <button
                onClick={handleCreateNew}
                className="mt-4 bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg font-medium transition-colors"
              >
                Crear Nuevo Examen
              </button>
            </div>
          ) : (
            <>
              {/* Quick Suggestions with Document Context */}
              {showSuggestions && messages.filter(m => m.role !== 'system').length === 0 && (
                <div className="mb-6 space-y-4">
                  {!hasDocumentContext && (
                    <div className="bg-blue-50 border border-blue-200 rounded-lg p-4">
                      <h4 className="text-sm font-medium text-blue-900 mb-2">
                        💡 Mejora tus exámenes con contexto documental
                      </h4>
                      <p className="text-sm text-blue-700 mb-3">
                        Sube documentos de clase para generar preguntas más específicas y relevantes al contenido que enseñas.
                      </p>
                      <div className="text-sm text-gray-500">
                        Usa el botón de attachment (📎) en el chat input para subir documentos
                      </div>
                    </div>
                  )}
                  
                  <QuickSuggestions
                    onSuggestionClick={handleSuggestionClick}
                    disabled={isLoading || isProcessingQuestions}
                  />
                </div>
              )}

              {/* Display Chat Messages */}
              {messages.filter(m => m.role !== 'system').map((m: Message) => (
                <div
                  key={m.id}
                  className={`flex ${m.role === 'user' ? 'justify-end' : 'justify-start'}`}
                >
                  <div
                    className={`max-w-sm lg:max-w-2xl px-4 py-3 rounded-lg ${
                      m.role === 'user'
                        ? 'bg-blue-600 text-white'
                        : 'bg-gray-50 border border-gray-200 text-gray-800 shadow-sm'
                    }`}
                  >
                    <div className="font-semibold text-xs mb-2 opacity-70">
                      {m.role === 'user' ? 'Tú' : 'Asistente IA'}
                    </div>
                    <div className="message-content">
                      {m.role === 'user' ? (
                        <div className="whitespace-pre-wrap">{m.content}</div>
                      ) : (
                        <MarkdownRenderer content={m.content} />
                      )}
                    </div>
                  </div>
                </div>
              ))}

              {/* Loading indicator */}
              {isLoading && (
                <div className="flex justify-start">
                  <div className="max-w-sm lg:max-w-2xl px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 text-gray-800 shadow-sm">
                    <div className="font-semibold text-xs mb-2 opacity-70">Asistente IA</div>
                    <div className="flex items-center space-x-1">
                      <div className="flex space-x-1">
                        <div className="w-2 h-2 bg-gray-500 rounded-full animate-bounce"></div>
                        <div
                          className="w-2 h-2 bg-gray-500 rounded-full animate-bounce"
                          style={{ animationDelay: '0.1s' }}
                        ></div>
                        <div
                          className="w-2 h-2 bg-gray-500 rounded-full animate-bounce"
                          style={{ animationDelay: '0.2s' }}
                        ></div>
                      </div>
                      <span className="text-sm text-gray-600 ml-2">Pensando...</span>
                    </div>
                  </div>
                </div>
              )}

              {/* Display Extracted Questions */}
              {extractedQuestions.length > 0 && (
                 <div className="mt-6 pt-6 border-t border-gray-200 space-y-6">
                   {/* Stats Panel */}
                   {showStats && (
                     <ExamStats questions={extractedQuestions} />
                   )}
                   
                   {/* Questions Display */}
                   <ExamQuestionDisplay
                     questions={extractedQuestions}
                     isProcessing={isProcessingQuestions}
                     onExport={handleExportQuestions}
                   />
                 </div>
              )}

               {/* No questions yet message */}
              {extractedQuestions.length === 0 && !isLoading && !isProcessingQuestions && messages.length > 1 && (
                 <div className="mt-6 pt-6 border-t border-gray-200 text-center text-gray-500 text-sm">
                   Aún no se han extraído preguntas de esta conversación.
                   Asegúrate de que las respuestas del AI sigan el formato JSON especificado.
                 </div>
              )}
            </>
          )}
        </div>

        {/* Input Form */}
        <div className="border-t bg-white p-6 shrink-0">
          {!currentConversationId ? (
            <div className="text-center">
              <p className="text-gray-500 mb-3">Crea una nueva conversación de examen para empezar a chatear</p>
              <button
                onClick={handleCreateNew}
                disabled={isSaving}
                className="bg-indigo-600 hover:bg-indigo-700 disabled:bg-indigo-400 text-white px-6 py-2 rounded-lg font-medium transition-colors"
              >
                {isSaving ? 'Creando...' : 'Nuevo Examen'}
              </button>
            </div>
          ) : (
            <form onSubmit={handleSubmit} className="flex space-x-3 items-start">
              <div className="flex-1 relative">
                {/* Attachment Button */}
                <button
                  type="button"
                  onClick={handleAttachmentClick}
                  className="absolute left-4 top-4 text-gray-500 hover:text-gray-700 hover:bg-gray-50 p-1 rounded-full transition-all duration-200 z-10"
                  title="Subir documento (PDF, Word, PowerPoint)"
                  disabled={isLoading || isProcessingQuestions}
                >
                  <svg className="w-6 h-6" fill="none" stroke="currentColor" strokeWidth={2} viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                  </svg>
                </button>
                
                <textarea
                  className="w-full border border-gray-300 text-black rounded-lg pl-14 pr-4 py-3 resize-none focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                  value={input}
                  rows={3}
                  placeholder="Escribe tu prompt para generar preguntas (ej: Crea 5 preguntas sobre la fotosíntesis)"
                  onChange={(e) => {
                    handleInputChange({ target: { value: e.target.value } } as React.ChangeEvent<HTMLInputElement>);
                    if (e.target.value.trim() && showSuggestions) {
                      setShowSuggestions(false);
                    }
                  }}
                  disabled={isLoading || isProcessingQuestions}
                />
                
                {/* Hidden file input */}
                <input
                  ref={fileInputRef}
                  type="file"
                  accept=".pdf,.doc,.docx,.ppt,.pptx"
                  onChange={handleFileSelect}
                  className="hidden"
                  multiple={false}
                />
                {!showSuggestions && messages.filter(m => m.role !== 'system').length === 0 && (
                  <button
                    type="button"
                    onClick={() => setShowSuggestions(true)}
                    className="absolute right-3 top-3 text-gray-400 hover:text-gray-600 transition-colors"
                    title="Mostrar sugerencias"
                  >
                    <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                    </svg>
                  </button>
                )}
              </div>
              <button
                type="submit"
                disabled={isLoading || isProcessingQuestions || !input.trim()}
                className="bg-indigo-600 hover:bg-indigo-700 disabled:bg-gray-400 disabled:cursor-not-allowed text-white px-6 py-3 rounded-lg font-semibold transition-colors flex-shrink-0 self-end"
              >
                {isLoading ? 'Enviando...' : 'Enviar'}
              </button>
            </form>
          )}

          <div className="flex items-center justify-between mt-2">
            <p className="text-xs text-gray-500">
              Powered by OpenRouter • Model: Google Gemini 2.5 Flash Preview
            </p>
            <div className="flex items-center space-x-3">
              {currentConversationId && (
                <p className="text-xs text-gray-400">
                  Auto-guardado activado • Examen #{currentConversationId}
                </p>
              )}
            </div>
          </div>
        </div>
      </div>

      {/* Exam Preview Modal */}
      {showPreview && (
        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-lg shadow-xl max-w-4xl w-full max-h-[90vh] overflow-hidden">
            <ExamPreview
              questions={extractedQuestions}
              title={currentConversation?.titulo || 'Vista Previa del Examen'}
              onClose={() => setShowPreview(false)}
              onExport={handleExportQuestions}
              className="h-full"
            />
          </div>
        </div>
      )}

      {/* Document Detail Modal */}
      <DocumentDetailModal
        summary={selectedDocumentForDetails}
        isOpen={selectedDocumentForDetails !== null}
        onClose={handleCloseDocumentDetails}
      />

    </div>
  );
}
