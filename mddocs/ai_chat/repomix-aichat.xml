import { NextRequest, NextResponse } from 'next/server';
import mammoth from 'mammoth';

export interface DocumentExtractionResult {
  text: string;
  metadata: {
    fileSize?: number;
    wordCount?: number;
    characterCount?: number;
    extractedImages?: number;
  };
}

export async function POST(request: NextRequest) {
  try {
    console.log('🔍 Starting server-side DOCX extraction');
    
    const formData = await request.formData();
    const file = formData.get('file') as File;
    
    if (!file) {
      return NextResponse.json(
        { error: 'No file provided' },
        { status: 400 }
      );
    }
    
    // Validate file type
    const isValidDocx = file.type.includes('wordprocessingml') || 
                       file.type.includes('msword') ||
                       file.name.toLowerCase().endsWith('.docx') ||
                       file.name.toLowerCase().endsWith('.doc');
    
    if (!isValidDocx) {
      return NextResponse.json(
        { error: 'Invalid file type. Only DOCX files are supported.' },
        { status: 400 }
      );
    }
    
    console.log(`📄 Processing DOCX: ${file.name} (${file.size} bytes)`);
    
    // Convert file to ArrayBuffer
    const arrayBuffer = await file.arrayBuffer();
    
    // Extract text using mammoth
    const result = await mammoth.extractRawText({ arrayBuffer });
    
    const extractedText = result.value;
    const messages = result.messages;
    
    // Log any warnings or messages from mammoth
    if (messages.length > 0) {
      console.log('📝 Mammoth messages:', messages);
    }
    
    // Calculate basic statistics
    const wordCount = extractedText.split(/\s+/).filter(word => word.length > 0).length;
    const characterCount = extractedText.length;
    
    console.log(`✅ DOCX extraction completed. Words: ${wordCount}, Characters: ${characterCount}`);
    
    // Build metadata
    const metadata: DocumentExtractionResult['metadata'] = {
      fileSize: file.size,
      wordCount,
      characterCount,
      extractedImages: 0 // mammoth doesn't provide image count directly
    };
    
    const extractionResult: DocumentExtractionResult = {
      text: extractedText.trim(),
      metadata
    };
    
    return NextResponse.json(extractionResult);
    
  } catch (error) {
    console.error('❌ Error extracting DOCX:', error);
    
    const errorMessage = error instanceof Error ? error.message : 'Unknown error';
    
    return NextResponse.json(
      { 
        error: 'Failed to extract DOCX content',
        details: errorMessage
      },
      { status: 500 }
    );
  }
}
