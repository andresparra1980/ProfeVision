"use client";

import Dexie, { Table } from "dexie";

// Define the exam question interface
export interface ExamQuestion {
  id?: number;
  pregunta: string;
  opciones: ExamOption[];
  numeroOpciones: number;
  createdAt: Date;
  numeroPregunta: number;
}

// Define the exam option interface
export interface ExamOption {
  texto: string;
  esCorrecta: boolean;
}

// Define the topic summary interfaces
export interface MicroTopic {
  name: string;
  description: string;
  keyTerms: string[];
  concepts: string[];
}

export interface MacroTopic {
  name: string;
  description: string;
  microTopics: MicroTopic[];
  importance: "high" | "medium" | "low";
}

export interface TopicSummary {
  id: string;
  fileName: string;
  macroTopics: MacroTopic[];
  generalOverview: string;
  academicLevel: string;
  totalTopics: number;
  processedAt: Date;
}

// Define processing job interfaces
export interface ProcessingJob {
  id: string;
  fileName: string;
  fileSize: number;
  conversationId: number;
  status: "queued" | "extracting" | "summarizing" | "completed" | "failed";
  progress: number;
  stage: string;
  createdAt: Date;
  startedAt?: Date;
  completedAt?: Date;
  error?: string;
  result?: TopicSummary;
}

export interface JobQueue {
  jobs: ProcessingJob[];
  activeJobId?: string;
}

// Define the message interface for conversations
export interface ConversationMessage {
  role: "user" | "assistant" | "system";
  content: string;
  timestamp?: Date;
}

// Define the exam conversation interface
export interface ExamConversation {
  id?: number;
  titulo: string;
  descripcion?: string;
  messages: ConversationMessage[];
  createdAt: Date;
  updatedAt: Date;
  totalPreguntas: number;
  topicSummaries?: TopicSummary[];
  hasDocumentContext: boolean;
}

// Define the database class for exams
export class ExamDatabase extends Dexie {
  examConversations!: Table<ExamConversation>;

  constructor() {
    super("ExamDatabase");

    this.version(1).stores({
      examConversations: "++id, titulo, createdAt, updatedAt, totalPreguntas",
    });
  }
}

// Create database instance
export const examDb = new ExamDatabase();

// Exam service operations
export class ExamService {
  // Create a new exam conversation
  static async createExamConversation(
    titulo: string,
    descripcion?: string
  ): Promise<number> {
    const conversation: ExamConversation = {
      titulo,
      descripcion,
      messages: [],
      totalPreguntas: 0,
      createdAt: new Date(),
      updatedAt: new Date(),
      topicSummaries: [],
      hasDocumentContext: false,
    };

    return await examDb.examConversations.add(conversation);
  }

  // Update exam conversation with new messages and questions
  static async updateExamConversation(
    id: number,
    messages: ConversationMessage[],
    preguntas?: ExamQuestion[]
  ): Promise<void> {
    const updateData: Partial<ExamConversation> = {
      messages,
      updatedAt: new Date(),
    };

    if (preguntas) {
      updateData.totalPreguntas = preguntas.length;
    }

    await examDb.examConversations.update(id, updateData);
  }

  // Get an exam conversation
  static async getExamConversation(
    id: number
  ): Promise<ExamConversation | undefined> {
    return await examDb.examConversations.get(id);
  }

  // Get all exam conversations
  static async getAllExamConversations(): Promise<ExamConversation[]> {
    return await examDb.examConversations
      .orderBy("updatedAt")
      .reverse()
      .toArray();
  }

  // Delete an exam conversation
  static async deleteExamConversation(id: number): Promise<void> {
    await examDb.examConversations.delete(id);
  }

  // Parse AI response to extract questions
  static parseAIResponse(aiResponse: string): ExamQuestion[] {
    try {
      // Check if the response is a text-only response (expected behavior for explanations/rejections)
      const isTextOnlyResponse = this.isTextOnlyResponse(aiResponse);
      if (isTextOnlyResponse) {
        console.log(
          "Text-only response received (expected behavior):",
          aiResponse.substring(0, 200)
        );
        return []; // Return empty array for text-only responses
      }

      // Try to extract JSON from the AI response
      const jsonMatch = aiResponse.match(/\{[\s\S]*\}/);
      if (!jsonMatch) {
        console.log(
          "No JSON found in AI response:",
          aiResponse.substring(0, 200)
        );
        throw new Error("No JSON found in AI response");
      }

      let jsonStr = jsonMatch[0];
      console.log("Original JSON extracted:", jsonStr.substring(0, 300));

      // Try to fix common JSON malformation issues
      jsonStr = this.fixMalformedJSON(jsonStr);
      console.log("Fixed JSON:", jsonStr.substring(0, 300));

      const parsed = JSON.parse(jsonStr);

      // Handle single question format (most common for edits)
      if (parsed.pregunta && parsed.opciones) {
        console.log("Single question format detected");
        const question = {
          pregunta: parsed.pregunta,
          opciones: parsed.opciones,
          numeroOpciones: parsed.opciones.length,
          numeroPregunta: 1, // This will be overridden in edit mode
          createdAt: new Date(),
        };

        // Validate the question structure
        if (this.validateQuestion(question)) {
          return [question];
        } else {
          throw new Error(
            "Invalid question structure in single question format"
          );
        }
      }

      // Handle multiple questions format
      if (parsed.preguntas && Array.isArray(parsed.preguntas)) {
        console.log("Multiple questions array format detected");
        const questions = parsed.preguntas.map(
          (p: { pregunta: string; opciones: ExamOption[] }, index: number) => ({
            pregunta: p.pregunta,
            opciones: p.opciones,
            numeroOpciones: p.opciones.length,
            numeroPregunta: index + 1,
            createdAt: new Date(),
          })
        );

        // Validate all questions
        const validQuestions = questions.filter((q: ExamQuestion) =>
          this.validateQuestion(q)
        );
        if (validQuestions.length > 0) {
          return validQuestions;
        } else {
          throw new Error("No valid questions found in array format");
        }
      }

      // Handle numbered questions format (e.g., "pregunta1", "pregunta2", etc.)
      const questions: ExamQuestion[] = [];
      let questionNumber = 1;

      while (
        parsed[`pregunta${questionNumber}`] ||
        parsed[`pregunta_${questionNumber}`]
      ) {
        const key = parsed[`pregunta${questionNumber}`]
          ? `pregunta${questionNumber}`
          : `pregunta_${questionNumber}`;
        const questionData = parsed[key];

        const question = {
          pregunta: questionData.pregunta,
          opciones: questionData.opciones,
          numeroOpciones: questionData.opciones.length,
          numeroPregunta: questionNumber,
          createdAt: new Date(),
        };

        // Only add if valid
        if (this.validateQuestion(question)) {
          questions.push(question);
        } else {
          console.warn(
            `Invalid question structure for pregunta${questionNumber}`
          );
        }

        questionNumber++;
      }

      if (questions.length > 0) {
        console.log(
          "Numbered questions format detected, found:",
          questions.length
        );
        return questions;
      }

      console.log(
        "No valid format detected in parsed JSON:",
        Object.keys(parsed)
      );
      throw new Error("Invalid JSON structure for exam questions");
    } catch (error) {
      // Handle JSON parsing errors gracefully without console errors
      if (error instanceof SyntaxError && error.message.includes("JSON")) {
        // JSON parsing failed, likely due to malformed AI response
        // Return empty array instead of throwing error to avoid console spam
        return [];
      }

      // For other types of errors, still log them as they might be more serious
      console.warn("Non-JSON error parsing AI response:", error);
      return [];
    }
  }

  // Fix common JSON malformation issues
  static fixMalformedJSON(jsonStr: string): string {
    try {
      // Remove markdown code blocks if present
      jsonStr = jsonStr.replace(/```json\s*/g, "").replace(/```\s*/g, "");

      // Fix common issues in numbered question format
      // Pattern: Missing closing brackets and commas before next question
      jsonStr = jsonStr.replace(
        /(\s*}\s*)\s*"pregunta(\d+)":/g,
        '$1\n  },\n  "pregunta$2":'
      );

      // Fix missing closing array bracket before question
      jsonStr = jsonStr.replace(
        /(\s*"esCorrecta":\s*(true|false)\s*}\s*)\s*"pregunta(\d+)":/g,
        '$1\n    ]\n  },\n  "pregunta$3":'
      );

      // Fix incomplete last question - add missing closing brackets if needed
      if (jsonStr.includes('"pregunta') && !jsonStr.trim().endsWith("}")) {
        // Count opening and closing braces to see what's missing
        const openBraces = (jsonStr.match(/\{/g) || []).length;
        const closeBraces = (jsonStr.match(/\}/g) || []).length;
        const openBrackets = (jsonStr.match(/\[/g) || []).length;
        const closeBrackets = (jsonStr.match(/\]/g) || []).length;

        // Add missing closing brackets and braces
        let missing = "";
        if (openBrackets > closeBrackets) {
          missing += "\n    ]";
        }
        if (openBraces > closeBraces) {
          const missingBraces = openBraces - closeBraces;
          missing += "\n  " + "}".repeat(missingBraces);
        }

        if (missing) {
          jsonStr += missing;
        }
      }

      return jsonStr;
    } catch (error) {
      console.warn("Error fixing malformed JSON, returning original:", error);
      return jsonStr;
    }
  }

  // Check if the response is a text-only response (not containing JSON)
  static isTextOnlyResponse(response: string): boolean {
    // Common patterns for text-only responses from the AI
    const textOnlyPatterns = [
      /^No puedo/i,
      /^Mi función es/i,
      /^Solo puedo/i,
      /^Soy un/i,
      /^Mi propósito es/i,
      /^No es posible/i,
      /^Disculpa/i,
      /^Lo siento/i,
      /porque mi función es solo generar/i,
    ];

    // Check if response starts with any text-only pattern
    const startsWithTextPattern = textOnlyPatterns.some((pattern) =>
      pattern.test(response.trim())
    );

    // Check if response doesn't contain JSON structure indicators
    const hasNoJsonStructure =
      !response.includes("{") &&
      !response.includes("}") &&
      !response.includes("[") &&
      !response.includes("]");

    // Check if response is relatively short (likely explanation/rejection)
    const isShortResponse = response.trim().length < 300;

    return startsWithTextPattern || (hasNoJsonStructure && isShortResponse);
  }

  // Validate question structure
  static validateQuestion(question: Partial<ExamQuestion>): boolean {
    if (!question.pregunta || typeof question.pregunta !== "string") {
      return false;
    }

    if (!question.opciones || !Array.isArray(question.opciones)) {
      return false;
    }

    if (question.opciones.length < 2 || question.opciones.length > 4) {
      return false;
    }

    const correctOptions = question.opciones.filter(
      (op: ExamOption) => op.esCorrecta === true
    );
    if (correctOptions.length !== 1) {
      return false;
    }

    return question.opciones.every(
      (op: ExamOption) =>
        typeof op.texto === "string" && typeof op.esCorrecta === "boolean"
    );
  }

  // Search exam conversations
  static async searchExamConversations(
    query: string
  ): Promise<ExamConversation[]> {
    const allConversations = await this.getAllExamConversations();
    const searchTerm = query.toLowerCase();

    return allConversations.filter(
      (conversation) =>
        conversation.titulo.toLowerCase().includes(searchTerm) ||
        (conversation.descripcion &&
          conversation.descripcion.toLowerCase().includes(searchTerm))
    );
  }

  // Test method to verify text-only response handling
  static testTextOnlyResponse(): void {
    console.log("🧪 Testing text-only response handling...");

    const textOnlyResponses = [
      "No puedo explicar la razón de la respuesta correcta porque mi función es solo generar las preguntas y respuestas en formato JSON, sin incluir explicaciones adicionales.",
      "Mi función es únicamente crear preguntas de examen en formato JSON.",
      "Solo puedo generar preguntas, no explicaciones.",
      "Disculpa, pero eso está fuera de mi alcance.",
    ];

    textOnlyResponses.forEach((response, index) => {
      try {
        const result = this.parseAIResponse(response);
        console.log(
          `✅ Test ${index + 1}: Handled correctly. Result length: ${
            result.length
          }`
        );
      } catch (error) {
        console.error(`❌ Test ${index + 1}: Failed with error:`, error);
      }
    });

    console.log("🧪 Text-only response tests completed");
  }

  // Add topic summary to conversation
  static async addTopicSummary(
    conversationId: number,
    summary: TopicSummary
  ): Promise<void> {
    const conversation = await this.getExamConversation(conversationId);
    if (!conversation) {
      throw new Error("Conversation not found");
    }

    const existingSummaries = conversation.topicSummaries || [];

    // Check if a summary with the same ID already exists
    const existingIndex = existingSummaries.findIndex(
      (existing) => existing.id === summary.id
    );

    let updatedSummaries: TopicSummary[];

    if (existingIndex !== -1) {
      // Replace existing summary with new one
      updatedSummaries = [...existingSummaries];
      updatedSummaries[existingIndex] = summary;
      console.log(`🔄 Updated existing document summary: ${summary.fileName}`);
    } else {
      // Add new summary
      updatedSummaries = [...existingSummaries, summary];
      console.log(`➕ Added new document summary: ${summary.fileName}`);
    }

    await examDb.examConversations.update(conversationId, {
      topicSummaries: updatedSummaries,
      hasDocumentContext: true,
      updatedAt: new Date(),
    });
  }

  // Remove topic summary from conversation
  static async removeTopicSummary(
    conversationId: number,
    summaryId: string
  ): Promise<void> {
    const conversation = await this.getExamConversation(conversationId);
    if (!conversation) {
      throw new Error("Conversation not found");
    }

    const updatedSummaries = (conversation.topicSummaries || []).filter(
      (summary) => summary.id !== summaryId
    );

    await examDb.examConversations.update(conversationId, {
      topicSummaries: updatedSummaries,
      hasDocumentContext: updatedSummaries.length > 0,
      updatedAt: new Date(),
    });
  }

  // Get conversation summaries
  static async getConversationSummaries(
    conversationId: number
  ): Promise<TopicSummary[]> {
    const conversation = await this.getExamConversation(conversationId);
    return conversation?.topicSummaries || [];
  }

  // Clean duplicate topic summaries from a conversation
  static async cleanDuplicateSummaries(conversationId: number): Promise<void> {
    const conversation = await this.getExamConversation(conversationId);
    if (!conversation || !conversation.topicSummaries) {
      return;
    }

    const uniqueSummaries = new Map<string, TopicSummary>();

    // Keep only the most recent summary for each ID
    conversation.topicSummaries.forEach((summary) => {
      const existing = uniqueSummaries.get(summary.id);
      if (!existing || summary.processedAt > existing.processedAt) {
        uniqueSummaries.set(summary.id, summary);
      }
    });

    const cleanedSummaries = Array.from(uniqueSummaries.values());
    const duplicatesRemoved =
      conversation.topicSummaries.length - cleanedSummaries.length;

    if (duplicatesRemoved > 0) {
      await examDb.examConversations.update(conversationId, {
        topicSummaries: cleanedSummaries,
        updatedAt: new Date(),
      });

      console.log(
        `🧹 Cleaned ${duplicatesRemoved} duplicate summaries from conversation ${conversationId}`
      );
    }
  }

  // Clean all duplicate summaries across all conversations
  static async cleanAllDuplicateSummaries(): Promise<void> {
    const conversations = await this.getAllExamConversations();
    let totalCleaned = 0;

    for (const conversation of conversations) {
      if (
        conversation.id &&
        conversation.topicSummaries &&
        conversation.topicSummaries.length > 0
      ) {
        const beforeCount = conversation.topicSummaries.length;
        await this.cleanDuplicateSummaries(conversation.id);

        // Refetch to get the updated count
        const updatedConversation = await this.getExamConversation(
          conversation.id
        );
        const afterCount = updatedConversation?.topicSummaries?.length || 0;
        totalCleaned += beforeCount - afterCount;
      }
    }

    console.log(
      `🧹 Total duplicates cleaned across all conversations: ${totalCleaned}`
    );
  }
}

// Initialize exam database
export const initializeExamDatabase = async (): Promise<void> => {
  try {
    await examDb.open();
    console.log("Exam database initialized successfully");
  } catch (error) {
    console.error("Failed to initialize exam database:", error);
  }
};
