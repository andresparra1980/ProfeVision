'use client';

import React, { useState } from 'react';
import { TopicSummary } from '../lib/examDatabase';

interface DocumentContextIndicatorProps {
  topicSummaries: TopicSummary[];
  hasDocumentContext: boolean;
  documentContextSummary: string;
  className?: string;
  onToggleDetails?: () => void;
  onClearContext?: () => void;
}

export function DocumentContextIndicator({
  topicSummaries,
  hasDocumentContext,
  documentContextSummary,
  className = '',
  onToggleDetails,
  onClearContext
}: DocumentContextIndicatorProps) {
  const [isExpanded, setIsExpanded] = useState(false);

  const toggleExpanded = () => {
    setIsExpanded(!isExpanded);
    onToggleDetails?.();
  };

  const handleClearContext = (e: React.MouseEvent) => {
    e.stopPropagation();
    onClearContext?.();
  };

  if (!hasDocumentContext || topicSummaries.length === 0) {
    return null;
  }

  const totalMacroTopics = topicSummaries.reduce((sum, summary) => sum + summary.totalTopics, 0);
  const totalMicroTopics = topicSummaries.reduce((sum, summary) => 
    sum + summary.macroTopics.reduce((microSum, macro) => microSum + macro.microTopics.length, 0), 0
  );

  return (
    <div className={`bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg ${className}`}>
      {/* Main indicator */}
      <div 
        className="p-3 cursor-pointer hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors"
        onClick={toggleExpanded}
      >
        <div className="flex items-center justify-between">
          <div className="flex items-center space-x-3">
            {/* Context icon */}
            <div className="w-6 h-6 text-blue-600 dark:text-blue-400 flex-shrink-0">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" className="w-full h-full">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>

            <div className="flex-1 min-w-0">
              <div className="flex items-center space-x-2">
                <span className="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300 animate-pulse">
                  🤖 Enviando al LLM
                </span>
                <span className="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300">
                  📚 Contexto Activo
                </span>
                <span className="text-xs text-blue-600 dark:text-blue-400">
                  {topicSummaries.length} documento(s)
                </span>
              </div>
              
              <p className="text-sm text-blue-700 dark:text-blue-300 mt-1 truncate">
                {documentContextSummary}
              </p>
              
              <div className="mt-2 flex items-center space-x-2 text-xs">
                <span className="inline-flex items-center px-2 py-0.5 rounded-full bg-green-50 text-green-700 dark:bg-green-900/20 dark:text-green-400">
                  ✓ Contexto incluido en cada mensaje al LLM
                </span>
              </div>
            </div>
          </div>

          <div className="flex items-center space-x-2">
            {/* Clear button */}
            <button
              onClick={handleClearContext}
              className="p-1 text-blue-400 hover:text-red-500 dark:text-blue-500 dark:hover:text-red-400 transition-colors"
              title="Limpiar contexto"
            >
              <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </button>

            {/* Expand/collapse arrow */}
            <div className={`transform transition-transform duration-200 ${isExpanded ? 'rotate-180' : ''}`}>
              <svg className="w-4 h-4 text-blue-500 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>
        </div>
      </div>

      {/* Expanded details */}
      {isExpanded && (
        <div className="border-t border-blue-200 dark:border-blue-800 bg-blue-25 dark:bg-blue-950/20 p-4">
          <div className="space-y-4">
            {/* Summary stats */}
            <div className="grid grid-cols-3 gap-4 text-center">
              <div className="bg-white dark:bg-gray-800 p-3 rounded-lg border border-blue-200 dark:border-blue-700">
                <div className="text-lg font-semibold text-blue-600 dark:text-blue-400">
                  {topicSummaries.length}
                </div>
                <div className="text-xs text-gray-600 dark:text-gray-400">
                  Documentos
                </div>
              </div>
              
              <div className="bg-white dark:bg-gray-800 p-3 rounded-lg border border-blue-200 dark:border-blue-700">
                <div className="text-lg font-semibold text-blue-600 dark:text-blue-400">
                  {totalMacroTopics}
                </div>
                <div className="text-xs text-gray-600 dark:text-gray-400">
                  Macro Temas
                </div>
              </div>
              
              <div className="bg-white dark:bg-gray-800 p-3 rounded-lg border border-blue-200 dark:border-blue-700">
                <div className="text-lg font-semibold text-blue-600 dark:text-blue-400">
                  {totalMicroTopics}
                </div>
                <div className="text-xs text-gray-600 dark:text-gray-400">
                  Subtemas
                </div>
              </div>
            </div>

            {/* Document list */}
            <div>
              <h4 className="text-sm font-medium text-blue-900 dark:text-blue-100 mb-2">
                Documentos cargados:
              </h4>
              <div className="space-y-2">
                {topicSummaries.map((summary) => (
                  <div
                    key={summary.id}
                    className="flex items-center justify-between p-2 bg-white dark:bg-gray-800 rounded border border-blue-200 dark:border-blue-700"
                  >
                    <div className="flex items-center space-x-3 flex-1 min-w-0">
                      <div className="w-4 h-4 text-blue-500 flex-shrink-0">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" className="w-full h-full">
                          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                      </div>
                      
                      <div className="flex-1 min-w-0">
                        <p className="text-sm font-medium text-gray-900 dark:text-gray-100 truncate">
                          {summary.fileName}
                        </p>
                        <div className="flex items-center space-x-2 text-xs text-gray-500 dark:text-gray-400">
                          <span className="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300">
                            {summary.academicLevel}
                          </span>
                          <span>•</span>
                          <span>{summary.totalTopics} tema(s)</span>
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            {/* Context preview */}
            <div className="bg-gray-50 dark:bg-gray-900/50 rounded-lg p-3 border border-gray-200 dark:border-gray-700">
              <h5 className="text-xs font-medium text-gray-700 dark:text-gray-300 mb-2 flex items-center">
                <span className="w-3 h-3 mr-1 text-green-500">
                  <svg fill="currentColor" viewBox="0 0 20 20" className="w-full h-full">
                    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                  </svg>
                </span>
                Contexto enviado automáticamente al LLM:
              </h5>
              <div className="text-xs text-gray-600 dark:text-gray-400 space-y-1">
                <div>• {totalMacroTopics} macro temas principales</div>
                <div>• {totalMicroTopics} subtemas específicos</div>
                <div>• Términos clave y descripciones detalladas</div>
                <div>• Instrucciones para generar preguntas relevantes</div>
              </div>
            </div>

            {/* Action buttons */}
            <div className="flex space-x-2 pt-2 border-t border-blue-200 dark:border-blue-800">
              <button
                onClick={onToggleDetails}
                className="flex-1 px-3 py-2 text-sm font-medium text-blue-700 dark:text-blue-300 bg-white dark:bg-gray-800 border border-blue-300 dark:border-blue-600 rounded-md hover:bg-blue-50 dark:hover:bg-gray-700 transition-colors"
              >
                Ver Detalles
              </button>
              
              <button
                onClick={handleClearContext}
                className="px-3 py-2 text-sm font-medium text-red-700 dark:text-red-300 bg-white dark:bg-gray-800 border border-red-300 dark:border-red-600 rounded-md hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
              >
                Limpiar Todo
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
</file>

<file path="components/DocumentDetailModal.tsx">
'use client';

import React, { useState, useEffect } from 'react';
import { TopicSummary } from '../lib/examDatabase';

interface DocumentDetailModalProps {
  summary: TopicSummary | null;
  isOpen: boolean;
  onClose: () => void;
  className?: string;
}

interface ExpandedState {
  [macroTopicIndex: number]: boolean;
}

export function DocumentDetailModal({
  summary,
  isOpen,
  onClose,
  className = '',
}: DocumentDetailModalProps) {
  const [expandedMacroTopics, setExpandedMacroTopics] = useState<ExpandedState>({});

  // Reset expanded state when modal opens/closes or summary changes
  useEffect(() => {
    if (isOpen && summary) {
      setExpandedMacroTopics({});
    }
  }, [isOpen, summary]);

  // Handle escape key
  useEffect(() => {
    const handleEscape = (e: KeyboardEvent) => {
      if (e.key === 'Escape' && isOpen) {
        onClose();
      }
    };

    if (isOpen) {
      document.addEventListener('keydown', handleEscape);
      // Prevent body scroll
      document.body.style.overflow = 'hidden';
    }

    return () => {
      document.removeEventListener('keydown', handleEscape);
      document.body.style.overflow = 'unset';
    };
  }, [isOpen, onClose]);

  // Toggle macro topic expansion
  const toggleMacroTopic = (index: number) => {
    setExpandedMacroTopics(prev => ({
      ...prev,
      [index]: !prev[index]
    }));
  };

  // Get file type icon and color (same as DocumentContextBar)
  const getFileIcon = (fileName: string) => {
    const extension = fileName.split('.').pop()?.toLowerCase() || '';
    switch (extension) {
      case 'pdf':
        return { icon: '📄', color: 'text-red-600 bg-red-50' };
      case 'doc':
      case 'docx':
        return { icon: '📝', color: 'text-blue-600 bg-blue-50' };
      case 'ppt':
      case 'pptx':
        return { icon: '📊', color: 'text-orange-600 bg-orange-50' };
      default:
        return { icon: '📄', color: 'text-gray-600 bg-gray-50' };
    }
  };

  // Get importance color
  const getImportanceColor = (importance: 'high' | 'medium' | 'low') => {
    switch (importance) {
      case 'high':
        return 'bg-red-100 text-red-800 border-red-200';
      case 'medium':
        return 'bg-yellow-100 text-yellow-800 border-yellow-200';
      case 'low':
        return 'bg-green-100 text-green-800 border-green-200';
      default:
        return 'bg-gray-100 text-gray-800 border-gray-200';
    }
  };

  // Get academic level color
  const getAcademicLevelColor = (level: string) => {
    const lowerLevel = level.toLowerCase();
    if (lowerLevel.includes('universitario') || lowerLevel.includes('superior')) {
      return 'bg-purple-100 text-purple-800 border-purple-200';
    }
    if (lowerLevel.includes('bachillerato') || lowerLevel.includes('secundaria')) {
      return 'bg-blue-100 text-blue-800 border-blue-200';
    }
    if (lowerLevel.includes('primaria') || lowerLevel.includes('básico')) {
      return 'bg-green-100 text-green-800 border-green-200';
    }
    return 'bg-gray-100 text-gray-800 border-gray-200';
  };

  if (!isOpen || !summary) return null;

  const { icon, color } = getFileIcon(summary.fileName);
  const totalMicroTopics = summary.macroTopics.reduce((sum, macro) => sum + macro.microTopics.length, 0);

  return (
    <div className={`fixed inset-0 z-50 overflow-y-auto ${className}`}>
      {/* Overlay */}
      <div 
