<file path="lib/document-processor/topic-summarizer.ts">
'use client';

import { TopicSummary, MacroTopic } from '../examDatabase';

export interface TopicSummarizerOptions {
  maxTokens?: number;
  temperature?: number;
  model?: string;
}

export class TopicSummarizer {
  private static readonly DEFAULT_OPTIONS: TopicSummarizerOptions = {
    maxTokens: 50000,
    temperature: 0.3,
    model: 'google/gemini-2.5-flash-lite'
  };

  private static readonly SUMMARIZATION_PROMPT = `
Eres un experto analizador de contenido académico. Analiza el siguiente texto de clase/material educativo y proporciona un resumen estructurado de los temas.

TEXTO DEL DOCUMENTO:
{document_text}

INSTRUCCIONES:
1. Identifica los MACRO-TEMAS principales (temas generales, capítulos, unidades)
2. Para cada macro-tema, identifica los MICRO-TEMAS específicos (subtemas, conceptos específicos)
3. Extrae términos clave y conceptos importantes
4. Determina el nivel académico aparente
5. Proporciona una visión general del contenido

RESPONDE EN EL SIGUIENTE FORMATO JSON:
{
  "generalOverview": "Descripción general del contenido en 2-3 oraciones",
  "academicLevel": "básico|intermedio|avanzado|universitario",
  "macroTopics": [
    {
      "name": "Nombre del macro-tema",
      "description": "Descripción del macro-tema",
      "importance": "high|medium|low",
      "microTopics": [
        {
          "name": "Nombre del micro-tema",
          "description": "Descripción específica",
          "keyTerms": ["término1", "término2", "término3"],
          "concepts": ["concepto1", "concepto2"]
        }
      ]
    }
  ]
}

IMPORTANTE: Responde SOLO con el JSON válido, sin texto adicional.
`;

  static async summarizeDocument(
    documentText: string,
    fileName: string,
    options: TopicSummarizerOptions = {}
  ): Promise<TopicSummary> {
    try {
      console.log('🔍 Starting topic summarization for:', fileName);
      
      const opts = { ...this.DEFAULT_OPTIONS, ...options };
      
      // Limit text length to avoid token limits
      const limitedText = documentText.substring(0, opts.maxTokens);
      
      // Prepare prompt with the text content
      const prompt = this.SUMMARIZATION_PROMPT.replace(
        '{document_text}',
        limitedText
      );

      console.log(`📝 Sending ${limitedText.length} characters to AI for analysis`);

      // Call the AI API
      const response = await fetch('/api/summarize-topics', {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ 
          prompt,
          options: {
            temperature: opts.temperature,
            model: opts.model
          }
        })
      });

      if (!response.ok) {
        const errorText = await response.text();
        throw new Error(`API Error: ${response.status} - ${errorText}`);
      }

      const summaryData = await response.json();

      // Validate the response structure
      this.validateSummaryData(summaryData);

      const topicSummary: TopicSummary = {
        id: `${fileName}-${Date.now()}`,
        fileName,
        generalOverview: summaryData.generalOverview,
        academicLevel: summaryData.academicLevel,
        macroTopics: summaryData.macroTopics,
        totalTopics: summaryData.macroTopics?.length || 0,
        processedAt: new Date()
      };

      console.log(`✅ Topic summarization completed. Found ${topicSummary.totalTopics} macro-topics`);

      return topicSummary;

    } catch (error) {
      console.error('❌ Error summarizing document:', error);
      throw new Error(`Failed to summarize document: ${error instanceof Error ? error.message : 'Unknown error'}`);
    }
  }

  // Generate context for chat from multiple summaries
  static generateChatContext(summaries: TopicSummary[]): string {
    if (summaries.length === 0) return '';

    console.log(`📚 Generating chat context from ${summaries.length} document(s)`);

    const contextParts = summaries.map(summary => {
      const macroTopicsText = summary.macroTopics.map(macro => {
        const microTopicsText = macro.microTopics.map(micro => 
          `    - ${micro.name}: ${micro.description} (Términos clave: ${micro.keyTerms.join(', ')})`
        ).join('\n');

        return `
  • ${macro.name} (Importancia: ${macro.importance})
    ${macro.description}
${microTopicsText}`;
      }).join('\n');

      return `
=== CONTENIDO DE: ${summary.fileName} ===
Nivel académico: ${summary.academicLevel}
Resumen general: ${summary.generalOverview}

TEMAS PRINCIPALES:
${macroTopicsText}

---
`;
    });

    const fullContext = `
CONTEXTO DOCUMENTAL DISPONIBLE:

${contextParts.join('\n')}

INSTRUCCIONES: Utiliza este contexto documental para generar preguntas de examen específicas y relevantes al contenido real. Las preguntas deben estar alineadas con los temas, conceptos y términos clave identificados en los documentos.
`;

    console.log(`📄 Generated context: ${fullContext.length} characters`);
    return fullContext;
  }

  // Generate a summary of available topics for display
  static generateTopicsSummary(summaries: TopicSummary[]): string {
    if (summaries.length === 0) return 'No hay documentos cargados';

    const totalMacroTopics = summaries.reduce((sum, summary) => sum + summary.totalTopics, 0);
    const totalMicroTopics = summaries.reduce((sum, summary) => 
      sum + summary.macroTopics.reduce((microSum, macro) => microSum + macro.microTopics.length, 0), 0
    );

    const filesList = summaries.map(summary => 
      `• ${summary.fileName} (${summary.totalTopics} temas, nivel: ${summary.academicLevel})`
    ).join('\n');

    return `
📚 CONTEXTO DOCUMENTAL ACTIVO:

${filesList}

📊 Resumen total:
• ${summaries.length} documento(s) procesado(s)
• ${totalMacroTopics} macro-tema(s)
• ${totalMicroTopics} micro-tema(s)
`;
  }

  // Validate the AI response structure
  private static validateSummaryData(data: unknown): void {
    if (!data || typeof data !== 'object') {
      throw new Error('Invalid response: not an object');
    }

    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    const typedData = data as any;

    if (!typedData.generalOverview || typeof typedData.generalOverview !== 'string') {
      throw new Error('Invalid response: missing or invalid generalOverview');
    }

    if (!typedData.academicLevel || typeof typedData.academicLevel !== 'string') {
      throw new Error('Invalid response: missing or invalid academicLevel');
    }

    if (!Array.isArray(typedData.macroTopics)) {
      throw new Error('Invalid response: macroTopics must be an array');
    }

    // Validate each macro topic
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    typedData.macroTopics.forEach((macro: any, index: number) => {
      if (!macro.name || typeof macro.name !== 'string') {
        throw new Error(`Invalid macro topic ${index}: missing or invalid name`);
      }

      if (!macro.description || typeof macro.description !== 'string') {
        throw new Error(`Invalid macro topic ${index}: missing or invalid description`);
      }

      if (!macro.importance || !['high', 'medium', 'low'].includes(macro.importance)) {
        throw new Error(`Invalid macro topic ${index}: invalid importance level`);
      }

      if (!Array.isArray(macro.microTopics)) {
        throw new Error(`Invalid macro topic ${index}: microTopics must be an array`);
      }

      // Validate each micro topic
      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      macro.microTopics.forEach((micro: any, microIndex: number) => {
        if (!micro.name || typeof micro.name !== 'string') {
          throw new Error(`Invalid micro topic ${index}.${microIndex}: missing or invalid name`);
        }

        if (!micro.description || typeof micro.description !== 'string') {
          throw new Error(`Invalid micro topic ${index}.${microIndex}: missing or invalid description`);
        }

        if (!Array.isArray(micro.keyTerms)) {
          throw new Error(`Invalid micro topic ${index}.${microIndex}: keyTerms must be an array`);
        }

        if (!Array.isArray(micro.concepts)) {
          throw new Error(`Invalid micro topic ${index}.${microIndex}: concepts must be an array`);
        }
      });
    });
  }

  // Extract key terms from all summaries
  static extractAllKeyTerms(summaries: TopicSummary[]): string[] {
    const allTerms = new Set<string>();

    summaries.forEach(summary => {
      summary.macroTopics.forEach(macro => {
        macro.microTopics.forEach(micro => {
          micro.keyTerms.forEach(term => allTerms.add(term));
        });
      });
    });

    return Array.from(allTerms).sort();
  }

  // Extract all concepts from summaries
  static extractAllConcepts(summaries: TopicSummary[]): string[] {
    const allConcepts = new Set<string>();

    summaries.forEach(summary => {
      summary.macroTopics.forEach(macro => {
        macro.microTopics.forEach(micro => {
          micro.concepts.forEach(concept => allConcepts.add(concept));
        });
      });
    });

    return Array.from(allConcepts).sort();
  }

  // Get topics by importance level
  static getTopicsByImportance(summaries: TopicSummary[], importance: 'high' | 'medium' | 'low'): MacroTopic[] {
    const topics: MacroTopic[] = [];

    summaries.forEach(summary => {
      const filteredTopics = summary.macroTopics.filter(macro => macro.importance === importance);
      topics.push(...filteredTopics);
    });

    return topics;
  }

  // Generate a focused context for specific topics
  static generateFocusedContext(summaries: TopicSummary[], topicNames: string[]): string {
    if (summaries.length === 0 || topicNames.length === 0) return '';

    const focusedTopics: MacroTopic[] = [];

    summaries.forEach(summary => {
      const matchingTopics = summary.macroTopics.filter(macro => 
        topicNames.some(name => 
          macro.name.toLowerCase().includes(name.toLowerCase()) ||
          name.toLowerCase().includes(macro.name.toLowerCase())
        )
      );
      focusedTopics.push(...matchingTopics);
    });

    if (focusedTopics.length === 0) {
      return this.generateChatContext(summaries); // Fallback to full context
    }

    const focusedContext = focusedTopics.map(macro => {
      const microTopicsText = macro.microTopics.map(micro => 
        `    - ${micro.name}: ${micro.description} (Términos: ${micro.keyTerms.join(', ')})`
      ).join('\n');

      return `
• ${macro.name} (Importancia: ${macro.importance})
  ${macro.description}
${microTopicsText}`;
    }).join('\n');

    return `
CONTEXTO DOCUMENTAL ENFOCADO:

TEMAS ESPECÍFICOS SOLICITADOS:
${focusedContext}

INSTRUCCIONES: Enfócate específicamente en estos temas para generar preguntas relevantes y precisas.
`;
  }
}
</file>

