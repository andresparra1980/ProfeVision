<file path="components/DocumentProcessor.tsx">
'use client';

import React, { useState, useCallback, useRef } from 'react';
import { useDocumentContext } from '../lib/hooks/useDocumentContext';
import { useBackgroundProcessing } from '../lib/hooks/useBackgroundProcessing';
import { TopicSummary } from '../lib/examDatabase';
import { BackgroundProcessingStatus } from './BackgroundProcessingStatus';

interface DocumentProcessorProps {
  conversationId?: number;
  onDocumentProcessed?: (summary: TopicSummary) => void;
  onError?: (error: string) => void;
  className?: string;
  maxFiles?: number;
  enableBackgroundProcessing?: boolean;
}

export function DocumentProcessor({
  conversationId,
  onDocumentProcessed,
  onError,
  className = '',
  maxFiles = 5,
  enableBackgroundProcessing = true
}: DocumentProcessorProps) {
  const {
    isProcessing,
    processingStatus,
    topicSummaries,
    processDocument,
    removeDocument,
    validateFile,
    getSupportedFormats
  } = useDocumentContext();

  // Background processing hook
  const backgroundProcessing = useBackgroundProcessing({
    maxConcurrentJobs: 2,
    onJobCompleted: (jobId, result) => {
      console.log(`🎉 Background job completed: ${result.fileName}`);
      onDocumentProcessed?.(result);
    },
    onJobFailed: (jobId, error) => {
      console.error(`❌ Background job failed: ${jobId} - ${error}`);
      onError?.(error);
    },
  });

  const [isDragOver, setIsDragOver] = useState(false);
  const fileInputRef = useRef<HTMLInputElement>(null);

  // Handle file processing
  const handleFiles = useCallback(async (files: FileList) => {
    const fileArray = Array.from(files);
    
    // Check if we would exceed max files
    const currentFiles = topicSummaries.length + backgroundProcessing.state.jobs.filter(j => j.status !== 'failed').length;
    if (currentFiles + fileArray.length > maxFiles) {
      const error = `Máximo ${maxFiles} archivos permitidos. Actualmente tienes ${currentFiles}.`;
      onError?.(error);
      return;
    }

    for (const file of fileArray) {
      try {
        // Validate file
        const validation = await validateFile(file);
        if (!validation.isValid) {
          onError?.(validation.error || 'Archivo no válido');
          continue;
        }

        if (enableBackgroundProcessing && conversationId) {
          // Add to background processing queue
          const jobId = await backgroundProcessing.addJob(file, conversationId);
          console.log(`📋 Added file to background queue: ${file.name} (${jobId})`);
        } else {
          // Process immediately (legacy mode)
          const summary = await processDocument(file, conversationId);
          onDocumentProcessed?.(summary);
        }

      } catch (error) {
        const errorMessage = error instanceof Error ? error.message : 'Error procesando archivo';
        onError?.(errorMessage);
      }
    }
  }, [processDocument, conversationId, onDocumentProcessed, onError, validateFile, topicSummaries.length, maxFiles, enableBackgroundProcessing, backgroundProcessing]);

  // Drag and drop handlers
  const handleDragOver = useCallback((e: React.DragEvent) => {
    e.preventDefault();
    e.stopPropagation();
    setIsDragOver(true);
  }, []);

  const handleDragLeave = useCallback((e: React.DragEvent) => {
    e.preventDefault();
    e.stopPropagation();
    setIsDragOver(false);
  }, []);

  const handleDrop = useCallback((e: React.DragEvent) => {
    e.preventDefault();
    e.stopPropagation();
    setIsDragOver(false);

    const files = e.dataTransfer.files;
    if (files.length > 0) {
      handleFiles(files);
    }
  }, [handleFiles]);

  // File input handler
  const handleFileInput = useCallback((e: React.ChangeEvent<HTMLInputElement>) => {
    const files = e.target.files;
    if (files && files.length > 0) {
      handleFiles(files);
    }
    // Reset input value to allow selecting the same file again
    e.target.value = '';
  }, [handleFiles]);

  // Open file dialog
  const openFileDialog = useCallback(() => {
    fileInputRef.current?.click();
  }, []);

  // Remove document handler
  const handleRemoveDocument = useCallback(async (summaryId: string) => {
    try {
      await removeDocument(summaryId, conversationId);
    } catch (error) {
      const errorMessage = error instanceof Error ? error.message : 'Error eliminando documento';
      onError?.(errorMessage);
    }
  }, [removeDocument, conversationId, onError]);

  const supportedFormats = getSupportedFormats();
  const remainingSlots = maxFiles - topicSummaries.length;

  return (
    <div className={`w-full ${className}`}>
      {/* File Drop Zone */}
      <div
        onDragOver={handleDragOver}
        onDragLeave={handleDragLeave}
        onDrop={handleDrop}
        onClick={openFileDialog}
        className={`
          relative border-2 border-dashed rounded-lg p-8 text-center cursor-pointer transition-all duration-200
          ${isDragOver 
            ? 'border-blue-500 bg-blue-50 dark:bg-blue-900/20' 
            : 'border-gray-300 dark:border-gray-600 hover:border-gray-400 dark:hover:border-gray-500'
          }
          ${isProcessing ? 'pointer-events-none opacity-50' : ''}
        `}
      >
        <input
          ref={fileInputRef}
          type="file"
          multiple
          accept={supportedFormats.join(',')}
          onChange={handleFileInput}
          className="hidden"
        />

        <div className="space-y-4">
          {/* Upload Icon */}
          <div className="mx-auto w-16 h-16 text-gray-400 dark:text-gray-500">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" className="w-full h-full">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
            </svg>
          </div>

          {/* Main text */}
          <div>
            <h3 className="text-lg font-medium text-gray-900 dark:text-gray-100">
              {isDragOver ? 'Suelta los archivos aquí' : 'Sube documentos para contexto'}
            </h3>
            <p className="text-sm text-gray-500 dark:text-gray-400 mt-2">
              Arrastra y suelta archivos o haz clic para seleccionar
            </p>
          </div>

          {/* Supported formats */}
          <div className="text-xs text-gray-400 dark:text-gray-500">
            <p>Formatos soportados: {supportedFormats.join(', ')}</p>
            <p>Máximo 50MB por archivo • {remainingSlots} archivo(s) restante(s)</p>
          </div>
        </div>
      </div>

      {/* Processing Status */}
      {isProcessing && (
        <div className="mt-4 p-4 bg-blue-50 dark:bg-blue-900/20 rounded-lg border border-blue-200 dark:border-blue-800">
          <div className="flex items-center space-x-3">
            <div className="animate-spin w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full"></div>
            <div className="flex-1">
              <div className="flex justify-between items-center mb-2">
                <span className="text-sm font-medium text-blue-900 dark:text-blue-100">
                  {processingStatus.message}
                </span>
                <span className="text-xs text-blue-600 dark:text-blue-300">
                  {processingStatus.progress}%
                </span>
              </div>
              <div className="w-full bg-blue-200 dark:bg-blue-800 rounded-full h-2">
                <div 
                  className="bg-blue-500 h-2 rounded-full transition-all duration-300"
                  style={{ width: `${processingStatus.progress}%` }}
                ></div>
              </div>
              {processingStatus.fileName && (
                <p className="text-xs text-blue-600 dark:text-blue-300 mt-1">
                  Archivo: {processingStatus.fileName}
                </p>
              )}
            </div>
          </div>
        </div>
      )}

      {/* Error Display */}
      {processingStatus.stage === 'error' && (
        <div className="mt-4 p-4 bg-red-50 dark:bg-red-900/20 rounded-lg border border-red-200 dark:border-red-800">
          <div className="flex items-center space-x-3">
            <div className="w-5 h-5 text-red-500">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" className="w-full h-full">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <p className="text-sm text-red-800 dark:text-red-200">
              {processingStatus.message}
            </p>
          </div>
        </div>
      )}

      {/* Processed Documents List */}
      {topicSummaries.length > 0 && (
        <div className="mt-6 space-y-3">
          <h4 className="text-sm font-medium text-gray-900 dark:text-gray-100">
            Documentos procesados ({topicSummaries.length})
          </h4>
          
          <div className="space-y-2">
            {topicSummaries.map((summary) => (
              <div
                key={summary.id}
                className="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700"
              >
                <div className="flex-1 min-w-0">
                  <div className="flex items-center space-x-3">
                    {/* File icon */}
                    <div className="w-8 h-8 text-blue-500 flex-shrink-0">
                      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" className="w-full h-full">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                    </div>
                    
                    <div className="flex-1 min-w-0">
                      <p className="text-sm font-medium text-gray-900 dark:text-gray-100 truncate">
                        {summary.fileName}
                      </p>
                      <div className="flex items-center space-x-4 text-xs text-gray-500 dark:text-gray-400">
                        <span>Nivel: {summary.academicLevel}</span>
                        <span>•</span>
                        <span>{summary.totalTopics} tema(s)</span>
                        <span>•</span>
                        <span>{new Date(summary.processedAt).toLocaleDateString()}</span>
                      </div>
                    </div>
                  </div>
                </div>

                {/* Remove button */}
                <button
                  onClick={() => handleRemoveDocument(summary.id)}
                  className="ml-3 p-2 text-gray-400 hover:text-red-500 dark:text-gray-500 dark:hover:text-red-400 transition-colors"
                  title="Eliminar documento"
                >
                  <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Background Processing Status */}
      {enableBackgroundProcessing && backgroundProcessing.state.jobs.length > 0 && (
        <BackgroundProcessingStatus
          jobs={backgroundProcessing.state.jobs}
          onRemoveJob={backgroundProcessing.removeJob}
          onClearCompleted={backgroundProcessing.clearCompletedJobs}
          onRetryJob={backgroundProcessing.retryJob}
          className="mt-4"
        />
      )}
    </div>
  );
}
