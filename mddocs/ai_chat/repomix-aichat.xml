<file path="components/ExamPreview.tsx">
"use client";

import { useState } from "react";
import { ExamQuestion } from "../lib/examDatabase";

interface ExamPreviewProps {
  questions: ExamQuestion[];
  title?: string;
  onClose?: () => void;
  onEdit?: (questionIndex: number) => void;
  onExport?: () => void;
  className?: string;
}

export default function ExamPreview({
  questions,
  title = "Vista Previa del Examen",
  onClose,
  onEdit,
  onExport,
  className = "",
}: ExamPreviewProps) {
  const [currentMode, setCurrentMode] = useState<"preview" | "practice">(
    "preview",
  );
  const [userAnswers, setUserAnswers] = useState<Record<number, number>>({});
  const [showResults, setShowResults] = useState(false);
  const [selectedAnswers, setSelectedAnswers] = useState<
    Record<number, number>
  >({});

  const getOptionLetter = (index: number) => {
    return String.fromCharCode(65 + index); // A, B, C, D
  };

  const handleAnswerSelect = (questionNumber: number, optionIndex: number) => {
    if (currentMode === "practice") {
      setSelectedAnswers((prev) => ({
        ...prev,
        [questionNumber]: optionIndex,
      }));
    }
  };

  const handleSubmitPractice = () => {
    setUserAnswers(selectedAnswers);
    setShowResults(true);
  };

  const resetPractice = () => {
    setSelectedAnswers({});
    setUserAnswers({});
    setShowResults(false);
  };

  const getResults = () => {
    let correct = 0;
    const total = questions.length;

    questions.forEach((question) => {
      const userAnswer = userAnswers[question.numeroPregunta];
      const correctAnswer = question.opciones.findIndex((op) => op.esCorrecta);
      if (userAnswer === correctAnswer) {
        correct++;
      }
    });

    return { correct, total, percentage: (correct / total) * 100 };
  };

  const getQuestionStats = () => {
    const verdaderoFalso = questions.filter(
      (q) => q.numeroOpciones === 2,
    ).length;
    const opcionMultiple = questions.filter((q) => q.numeroOpciones > 2).length;

    return { verdaderoFalso, opcionMultiple };
  };

  if (questions.length === 0) {
    return (
      <div
        className={`bg-white rounded-lg border border-gray-200 p-6 ${className}`}
      >
        <div className="text-center">
          <svg
            className="mx-auto h-12 w-12 text-gray-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              strokeLinecap="round"
              strokeLinejoin="round"
              strokeWidth={2}
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            />
          </svg>
          <h3 className="mt-2 text-lg font-medium text-gray-900">
            No hay preguntas para mostrar
          </h3>
          <p className="mt-1 text-sm text-gray-500">
            Crea algunas preguntas primero para ver la vista previa del examen.
          </p>
        </div>
      </div>
    );
  }

  const stats = getQuestionStats();
  const results = showResults ? getResults() : null;

  return (
    <div className={`bg-white rounded-lg border border-gray-200 ${className}`}>
      {/* Header */}
      <div className="px-6 py-4 border-b border-gray-200 bg-gray-50 rounded-t-lg">
        <div className="flex items-center justify-between">
          <div>
            <h2 className="text-xl font-bold text-gray-900">{title}</h2>
            <div className="mt-1 flex items-center space-x-4 text-sm text-gray-600">
              <span>
                {questions.length} pregunta{questions.length !== 1 ? "s" : ""}
              </span>
              <span>•</span>
              <span>{stats.verdaderoFalso} V/F</span>
              <span>•</span>
              <span>{stats.opcionMultiple} Opción Múltiple</span>
            </div>
          </div>

          <div className="flex items-center space-x-2">
            {/* Mode Toggle */}
            <div className="flex items-center space-x-1 bg-gray-200 rounded-lg p-1">
              <button
                onClick={() => {
                  setCurrentMode("preview");
                  resetPractice();
                }}
                className={`px-3 py-1 text-sm font-medium rounded-md transition-colors ${
                  currentMode === "preview"
                    ? "bg-white text-gray-900 shadow-sm"
                    : "text-gray-600 hover:text-gray-900"
                }`}
              >
                Vista Previa
              </button>
              <button
                onClick={() => {
                  setCurrentMode("practice");
                  resetPractice();
                }}
                className={`px-3 py-1 text-sm font-medium rounded-md transition-colors ${
                  currentMode === "practice"
                    ? "bg-white text-gray-900 shadow-sm"
                    : "text-gray-600 hover:text-gray-900"
                }`}
              >
                Modo Práctica
              </button>
            </div>

            {onExport && (
              <button
                onClick={onExport}
                className="px-4 py-2 text-sm font-medium text-indigo-600 bg-indigo-50 rounded-lg hover:bg-indigo-100 transition-colors"
              >
                Exportar
              </button>
            )}

            {onClose && (
              <button
                onClick={onClose}
                className="p-2 text-gray-400 hover:text-gray-600 transition-colors"
              >
                <svg
                  className="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    strokeLinecap="round"
                    strokeLinejoin="round"
                    strokeWidth={2}
                    d="M6 18L18 6M6 6l12 12"
                  />
                </svg>
              </button>
            )}
          </div>
        </div>

        {/* Results Summary */}
        {showResults && results && (
          <div className="mt-4 p-4 bg-blue-50 rounded-lg">
            <div className="flex items-center justify-between">
              <div>
                <h3 className="text-lg font-medium text-blue-900">
                  Resultados
                </h3>
                <p className="text-sm text-blue-700">
                  {results.correct} de {results.total} respuestas correctas (
                  {results.percentage.toFixed(1)}%)
                </p>
              </div>
              <div
                className={`text-2xl font-bold ${
                  results.percentage >= 80
                    ? "text-green-600"
                    : results.percentage >= 60
                      ? "text-yellow-600"
                      : "text-red-600"
                }`}
              >
                {results.percentage.toFixed(0)}%
              </div>
            </div>
            <div className="mt-2">
              <div className="w-full bg-blue-200 rounded-full h-2">
                <div
                  className={`h-2 rounded-full ${
                    results.percentage >= 80
                      ? "bg-green-500"
                      : results.percentage >= 60
                        ? "bg-yellow-500"
                        : "bg-red-500"
                  }`}
                  style={{ width: `${results.percentage}%` }}
                ></div>
              </div>
            </div>
          </div>
        )}
      </div>

      {/* Questions */}
      <div className="max-h-96 overflow-y-auto">
        {questions.map((question, questionIndex) => {
          const correctOptionIndex = question.opciones.findIndex(
            (op) => op.esCorrecta,
          );
          const userAnswer = selectedAnswers[question.numeroPregunta];
          const submittedAnswer = userAnswers[question.numeroPregunta];
          const isCorrect =
            showResults && submittedAnswer === correctOptionIndex;
          const isIncorrect =
            showResults &&
            submittedAnswer !== undefined &&
            submittedAnswer !== correctOptionIndex;

          return (
            <div
              key={question.numeroPregunta}
              className="p-6 border-b border-gray-100 last:border-b-0"
            >
              <div className="flex items-start justify-between mb-4">
                <div className="flex-1">
                  <div className="flex items-center space-x-3 mb-2">
                    <h3 className="text-lg font-medium text-gray-900">
                      Pregunta {question.numeroPregunta}
                    </h3>

                    <span
                      className={`inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${
                        question.numeroOpciones === 2
                          ? "bg-green-100 text-green-800"
                          : "bg-blue-100 text-blue-800"
                      }`}
                    >
                      {question.numeroOpciones === 2
                        ? "V/F"
                        : `${question.numeroOpciones} opciones`}
                    </span>

                    {showResults && (
                      <span
                        className={`inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${
                          isCorrect
                            ? "bg-green-100 text-green-800"
                            : isIncorrect
                              ? "bg-red-100 text-red-800"
                              : "bg-gray-100 text-gray-800"
                        }`}
                      >
                        {isCorrect
                          ? "✓ Correcta"
                          : isIncorrect
                            ? "✗ Incorrecta"
                            : "No respondida"}
                      </span>
                    )}
                  </div>

                  <p className="text-gray-800 text-base leading-relaxed">
                    {question.pregunta}
                  </p>
                </div>

                {onEdit && currentMode === "preview" && (
                  <button
                    onClick={() => onEdit(questionIndex)}
                    className="ml-4 p-2 text-gray-400 hover:text-blue-600 transition-colors"
                  >
                    <svg
                      className="w-5 h-5"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        strokeLinecap="round"
                        strokeLinejoin="round"
                        strokeWidth={2}
                        d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                      />
                    </svg>
                  </button>
                )}
              </div>

              <div className="space-y-3">
                {question.opciones.map((opcion, optionIndex) => {
                  const isSelected = userAnswer === optionIndex;
                  const wasSelected = submittedAnswer === optionIndex;
                  const isCorrectOption = optionIndex === correctOptionIndex;

                  let optionClasses =
                    "flex items-start space-x-3 p-3 rounded-lg border transition-all cursor-pointer hover:bg-gray-50";

                  if (currentMode === "practice") {
                    if (showResults) {
                      if (isCorrectOption) {
                        optionClasses += " bg-green-50 border-green-200";
                      } else if (wasSelected && !isCorrectOption) {
                        optionClasses += " bg-red-50 border-red-200";
                      } else {
                        optionClasses += " bg-gray-50 border-gray-200";
                      }
                    } else {
                      if (isSelected) {
                        optionClasses += " bg-blue-50 border-blue-200";
                      } else {
                        optionClasses += " border-gray-200";
                      }
                    }
                  } else {
                    if (isCorrectOption) {
                      optionClasses += " bg-green-50 border-green-200";
                    } else {
                      optionClasses += " border-gray-200";
                    }
                  }

                  return (
                    <div
                      key={optionIndex}
                      className={optionClasses}
                      onClick={() =>
                        currentMode === "practice" &&
                        !showResults &&
                        handleAnswerSelect(question.numeroPregunta, optionIndex)
                      }
                    >
                      <div
                        className={`flex items-center justify-center w-8 h-8 rounded-full text-sm font-medium ${
                          currentMode === "preview" && isCorrectOption
                            ? "bg-green-600 text-white"
                            : currentMode === "practice" &&
                                showResults &&
                                isCorrectOption
                              ? "bg-green-600 text-white"
                              : currentMode === "practice" &&
                                  showResults &&
                                  wasSelected &&
                                  !isCorrectOption
                                ? "bg-red-600 text-white"
                                : currentMode === "practice" && isSelected
                                  ? "bg-blue-600 text-white"
                                  : "bg-gray-200 text-gray-700"
                        }`}
                      >
                        {getOptionLetter(optionIndex)}
                      </div>

                      <span className="flex-1 text-gray-800">
                        {opcion.texto}
                      </span>

                      {currentMode === "preview" && isCorrectOption && (
                        <svg
                          className="w-5 h-5 text-green-600"
                          fill="currentColor"
                          viewBox="0 0 20 20"
                        >
                          <path
                            fillRule="evenodd"
                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                            clipRule="evenodd"
                          />
                        </svg>
                      )}

                      {currentMode === "practice" && showResults && (
                        <>
                          {isCorrectOption && (
                            <svg
                              className="w-5 h-5 text-green-600"
                              fill="currentColor"
                              viewBox="0 0 20 20"
                            >
                              <path
                                fillRule="evenodd"
                                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                clipRule="evenodd"
                              />
                            </svg>
                          )}
                          {wasSelected && !isCorrectOption && (
                            <svg
                              className="w-5 h-5 text-red-600"
                              fill="currentColor"
                              viewBox="0 0 20 20"
                            >
                              <path
                                fillRule="evenodd"
                                d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                                clipRule="evenodd"
                              />
                            </svg>
                          )}
                        </>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>

      {/* Footer Actions */}
      {currentMode === "practice" && (
        <div className="px-6 py-4 bg-gray-50 border-t border-gray-200 rounded-b-lg">
          <div className="flex items-center justify-between">
            <div className="text-sm text-gray-600">
              {showResults ? (
                <span>Examen completado</span>
              ) : (
                <span>
                  Respondidas: {Object.keys(selectedAnswers).length} de{" "}
                  {questions.length}
                </span>
              )}
            </div>

            <div className="flex items-center space-x-3">
              {!showResults ? (
                <button
                  onClick={handleSubmitPractice}
                  disabled={Object.keys(selectedAnswers).length === 0}
                  className="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 disabled:bg-gray-300 disabled:cursor-not-allowed transition-colors"
                >
                  Finalizar Examen
                </button>
              ) : (
                <button
                  onClick={resetPractice}
                  className="px-4 py-2 text-sm font-medium text-blue-600 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors"
                >
                  Intentar de Nuevo
                </button>
              )}
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
