<file path="lib/document-processor/extractors/PDFExtractor.ts">
'use client';

export interface DocumentExtractionResult {
  text: string;
  metadata: {
    pageCount?: number;
    title?: string;
    author?: string;
    subject?: string;
    keywords?: string;
    creator?: string;
    producer?: string;
    creationDate?: Date;
    modificationDate?: Date;
    fileSize?: number;
    wordCount?: number;
    characterCount?: number;
    extractedImages?: number;
  };
}

export class PDFExtractor {
  static async extractText(file: File): Promise<DocumentExtractionResult> {
    try {
      console.log('🔍 Starting document extraction for:', file.name);
      
      // Detect file type and route to appropriate API
      const fileType = this.detectFileType(file);
      
      if (!this.validateFile(file)) {
        throw new Error('Unsupported file type');
      }
      
      // Create FormData to send file to server
      const formData = new FormData();
      formData.append('file', file);
      
      // Determine which API endpoint to use
      let apiEndpoint = '';
      if (fileType === 'pdf') {
        apiEndpoint = '/api/extract-pdf';
      } else if (fileType === 'docx') {
        apiEndpoint = '/api/extract-docx';
      } else {
        throw new Error('Unsupported file type');
      }
      
      console.log(`📄 Routing to ${apiEndpoint} for file type: ${fileType}`);
      
      // Send file to appropriate server-side extraction API
      const response = await fetch(apiEndpoint, {
        method: 'POST',
        body: formData,
      });
      
      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.error || `Failed to extract ${fileType.toUpperCase()}`);
      }
      
      const result: DocumentExtractionResult = await response.json();
      
      // Convert date strings back to Date objects if they exist
      if (result.metadata.creationDate) {
        result.metadata.creationDate = new Date(result.metadata.creationDate);
      }
      if (result.metadata.modificationDate) {
        result.metadata.modificationDate = new Date(result.metadata.modificationDate);
      }
      
      console.log(`✅ Document extraction completed. Text length: ${result.text.length} characters`);
      
      return result;
      
    } catch (error) {
      console.error('❌ Error extracting document:', error);
      throw new Error(`Failed to extract document content: ${error instanceof Error ? error.message : 'Unknown error'}`);
    }
  }
  
  // Detect file type based on MIME type and extension
  private static detectFileType(file: File): string {
    // Check MIME type first
    if (file.type.includes('pdf')) {
      return 'pdf';
    }
    if (file.type.includes('wordprocessingml') || file.type.includes('msword')) {
      return 'docx';
    }
    
    // Fallback to file extension
    const fileName = file.name.toLowerCase();
    if (fileName.endsWith('.pdf')) {
      return 'pdf';
    }
    if (fileName.endsWith('.docx') || fileName.endsWith('.doc')) {
      return 'docx';
    }
    
    return 'unknown';
  }
  
  // Validate if file is supported
  static validateFile(file: File): boolean {
    const supportedTypes = [
      'application/pdf',
      'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
      'application/msword'
    ];
    
    const supportedExtensions = ['.pdf', '.docx', '.doc'];
    
    const hasValidType = supportedTypes.some(type => file.type.includes(type.split('/')[1]));
    const hasValidExtension = supportedExtensions.some(ext => 
      file.name.toLowerCase().endsWith(ext)
    );
    
    return hasValidType || hasValidExtension;
  }
  
  // Get supported file extensions
  static getSupportedExtensions(): string[] {
    return ['.pdf', '.docx', '.doc'];
  }
  
  // Get supported MIME types
  static getSupportedMimeTypes(): string[] {
    return [
      'application/pdf',
      'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
      'application/msword'
    ];
  }
  
  // Get human-readable supported formats
  static getSupportedFormats(): string[] {
    return ['PDF', 'Microsoft Word (DOCX, DOC)'];
  }
}
