        "Genera preguntas complejas de economía internacional",
        "Haz preguntas de filosofía sobre ética aplicada",
        "Crea preguntas técnicas de ingeniería de software",
      ],
    },
    {
      category: "Formatos Específicos",
      icon: "⚙️",
      items: [
        "Crea 5 preguntas verdadero/falso sobre el sistema solar",
        "Genera preguntas con 3 opciones sobre literatura española",
        "Haz preguntas de opción múltiple con 2 opciones sobre lógica",
        "Crea preguntas de formato mixto sobre ciencias naturales",
      ],
    },
  ];

  const quickActions = [
    {
      label: "Examen Completo",
      description: "Genera un examen de 10-15 preguntas",
      prompt:
        "Crea un examen completo con 12 preguntas de opción múltiple sobre ",
      icon: "📋",
      color: "blue",
    },
    {
      label: "Quiz Rápido",
      description: "Crear 5 preguntas rápidas",
      prompt: "Crea 5 preguntas rápidas sobre ",
      icon: "⚡",
      color: "green",
    },
    {
      label: "Verdadero/Falso",
      description: "Solo preguntas V/F",
      prompt: "Crea preguntas verdadero/falso sobre ",
      icon: "✓",
      color: "purple",
    },
    {
      label: "Personalizado",
      description: "Especifica tus requisitos",
      prompt: "Crea preguntas personalizadas sobre ",
      icon: "🎨",
      color: "orange",
    },
  ];

  const handleSuggestionClick = (suggestion: string) => {
    if (!disabled) {
      onSuggestionClick(suggestion);
    }
  };

  const getColorClasses = (color: string) => {
    switch (color) {
      case "blue":
        return "bg-blue-50 text-blue-700 border-blue-200 hover:bg-blue-100";
      case "green":
        return "bg-green-50 text-green-700 border-green-200 hover:bg-green-100";
      case "purple":
        return "bg-purple-50 text-purple-700 border-purple-200 hover:bg-purple-100";
      case "orange":
        return "bg-orange-50 text-orange-700 border-orange-200 hover:bg-orange-100";
      default:
        return "bg-gray-50 text-gray-700 border-gray-200 hover:bg-gray-100";
    }
  };

  return (
    <div className={`bg-white rounded-lg border border-gray-200 ${className}`}>
      {/* Header */}
      <div className="px-4 py-3 border-b border-gray-200 bg-gray-50 rounded-t-lg">
        <div className="flex items-center justify-between">
          <div className="flex items-center space-x-2">
            <svg
              className="w-5 h-5 text-gray-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth={2}
                d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
              />
            </svg>
            <h3 className="text-sm font-medium text-gray-900">
              Sugerencias Rápidas
            </h3>
          </div>
          <button
            onClick={() => setIsExpanded(!isExpanded)}
            className="p-1 text-gray-400 hover:text-gray-600 transition-colors"
          >
            <svg
              className={`w-4 h-4 transition-transform ${isExpanded ? "rotate-180" : ""}`}
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth={2}
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </button>
        </div>
      </div>

      {/* Quick Actions */}
      <div className="p-4">
        <div className="grid grid-cols-2 gap-2 mb-4">
          {quickActions.map((action, index) => (
            <button
              key={index}
              onClick={() => handleSuggestionClick(action.prompt)}
              disabled={disabled}
              className={`p-3 rounded-lg border text-left transition-all text-sm ${getColorClasses(
                action.color,
              )} ${disabled ? "opacity-50 cursor-not-allowed" : "cursor-pointer"}`}
            >
              <div className="flex items-center space-x-2 mb-1">
                <span className="text-lg">{action.icon}</span>
                <span className="font-medium">{action.label}</span>
              </div>
              <p className="text-xs opacity-75">{action.description}</p>
            </button>
          ))}
        </div>

        {/* Expandable Suggestions */}
        {isExpanded && (
          <div className="space-y-4">
