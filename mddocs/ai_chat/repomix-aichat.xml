<file path="components/TopicSummaryViewer.tsx">
'use client';

import React, { useState } from 'react';
import { TopicSummary, MacroTopic, MicroTopic } from '../lib/examDatabase';

interface TopicSummaryViewerProps {
  summaries: TopicSummary[];
  className?: string;
  showFileName?: boolean;
  expandByDefault?: boolean;
  onTopicClick?: (topic: MacroTopic) => void;
  onMicroTopicClick?: (microTopic: MicroTopic) => void;
}

interface ExpandedState {
  [summaryId: string]: {
    summary: boolean;
    macroTopics: { [macroTopicIndex: number]: boolean };
  };
}

export function TopicSummaryViewer({
  summaries,
  className = '',
  showFileName = true,
  expandByDefault = false,
  onTopicClick,
  onMicroTopicClick
}: TopicSummaryViewerProps) {
  const [expandedState, setExpandedState] = useState<ExpandedState>(() => {
    const initialState: ExpandedState = {};
    summaries.forEach(summary => {
      initialState[summary.id] = {
        summary: expandByDefault,
        macroTopics: {}
      };
    });
    return initialState;
  });

  // Toggle summary expansion
  const toggleSummary = (summaryId: string) => {
    setExpandedState(prev => ({
      ...prev,
      [summaryId]: {
        ...prev[summaryId],
        summary: !prev[summaryId]?.summary
      }
    }));
  };

  // Toggle macro topic expansion
  const toggleMacroTopic = (summaryId: string, macroTopicIndex: number) => {
    setExpandedState(prev => ({
      ...prev,
      [summaryId]: {
        ...prev[summaryId],
        macroTopics: {
          ...prev[summaryId]?.macroTopics,
          [macroTopicIndex]: !prev[summaryId]?.macroTopics?.[macroTopicIndex]
        }
      }
    }));
  };

  // Get importance color
  const getImportanceColor = (importance: 'high' | 'medium' | 'low') => {
    switch (importance) {
      case 'high':
        return 'bg-red-100 text-red-800 dark:bg-red-900/20 dark:text-red-300';
      case 'medium':
        return 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/20 dark:text-yellow-300';
      case 'low':
        return 'bg-green-100 text-green-800 dark:bg-green-900/20 dark:text-green-300';
      default:
        return 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300';
    }
  };

  // Get academic level color
  const getAcademicLevelColor = (level: string) => {
    switch (level.toLowerCase()) {
      case 'básico':
        return 'bg-blue-100 text-blue-800 dark:bg-blue-900/20 dark:text-blue-300';
      case 'intermedio':
        return 'bg-purple-100 text-purple-800 dark:bg-purple-900/20 dark:text-purple-300';
      case 'avanzado':
        return 'bg-orange-100 text-orange-800 dark:bg-orange-900/20 dark:text-orange-300';
      case 'universitario':
        return 'bg-pink-100 text-pink-800 dark:bg-pink-900/20 dark:text-pink-300';
      default:
        return 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300';
    }
  };

  if (summaries.length === 0) {
    return (
      <div className={`text-center py-8 text-gray-500 dark:text-gray-400 ${className}`}>
        <div className="w-16 h-16 mx-auto mb-4 text-gray-300 dark:text-gray-600">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" className="w-full h-full">
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <p>No hay documentos procesados</p>
        <p className="text-sm mt-1">Sube documentos para ver el contexto académico</p>
      </div>
    );
  }

  return (
    <div className={`space-y-4 ${className}`}>
      {summaries.map((summary) => {
        const isExpanded = expandedState[summary.id]?.summary || false;
        
        return (
          <div
            key={summary.id}
            className="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden bg-white dark:bg-gray-800"
          >
            {/* Summary Header */}
            <div
              className="p-4 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
              onClick={() => toggleSummary(summary.id)}
            >
              <div className="flex items-start justify-between">
                <div className="flex-1 min-w-0">
                  {showFileName && (
                    <h3 className="text-lg font-semibold text-gray-900 dark:text-gray-100 truncate mb-2">
                      📄 {summary.fileName}
                    </h3>
                  )}
                  
                  <div className="flex flex-wrap gap-2 mb-3">
                    <span className={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${getAcademicLevelColor(summary.academicLevel)}`}>
                      {summary.academicLevel}
                    </span>
                    <span className="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300">
                      {summary.totalTopics} tema(s)
                    </span>
                    <span className="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300">
                      {new Date(summary.processedAt).toLocaleDateString()}
                    </span>
                  </div>
                  
                  <p className="text-sm text-gray-600 dark:text-gray-300 line-clamp-2">
                    {summary.generalOverview}
                  </p>
                </div>
                
                <div className="ml-4 flex-shrink-0">
                  <div className={`transform transition-transform duration-200 ${isExpanded ? 'rotate-180' : ''}`}>
                    <svg className="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                </div>
              </div>
            </div>

            {/* Expanded Content */}
            {isExpanded && (
              <div className="border-t border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900">
                <div className="p-4 space-y-4">
                  {/* General Overview */}
                  <div>
                    <h4 className="text-sm font-medium text-gray-900 dark:text-gray-100 mb-2">
                      📋 Resumen General
                    </h4>
                    <p className="text-sm text-gray-600 dark:text-gray-300 bg-white dark:bg-gray-800 p-3 rounded-lg border border-gray-200 dark:border-gray-700">
                      {summary.generalOverview}
                    </p>
                  </div>

                  {/* Macro Topics */}
                  <div>
                    <h4 className="text-sm font-medium text-gray-900 dark:text-gray-100 mb-3">
                      🎯 Temas Principales ({summary.macroTopics.length})
                    </h4>
                    
                    <div className="space-y-3">
                      {summary.macroTopics.map((macroTopic, macroIndex) => {
                        const isMacroExpanded = expandedState[summary.id]?.macroTopics?.[macroIndex] || false;
                        
                        return (
                          <div
                            key={macroIndex}
                            className="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden"
                          >
                            {/* Macro Topic Header */}
                            <div
                              className="p-3 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                              onClick={() => {
                                toggleMacroTopic(summary.id, macroIndex);
                                onTopicClick?.(macroTopic);
                              }}
                            >
                              <div className="flex items-start justify-between">
                                <div className="flex-1 min-w-0">
                                  <div className="flex items-center gap-2 mb-2">
                                    <h5 className="font-medium text-gray-900 dark:text-gray-100">
                                      {macroTopic.name}
                                    </h5>
                                    <span className={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${getImportanceColor(macroTopic.importance)}`}>
                                      {macroTopic.importance}
                                    </span>
                                  </div>
                                  <p className="text-sm text-gray-600 dark:text-gray-300">
                                    {macroTopic.description}
                                  </p>
                                  <p className="text-xs text-gray-500 dark:text-gray-400 mt-1">
                                    {macroTopic.microTopics.length} subtema(s)
                                  </p>
                                </div>
                                
                                <div className="ml-3 flex-shrink-0">
                                  <div className={`transform transition-transform duration-200 ${isMacroExpanded ? 'rotate-180' : ''}`}>
                                    <svg className="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
                                    </svg>
                                  </div>
                                </div>
                              </div>
                            </div>

                            {/* Micro Topics */}
                            {isMacroExpanded && macroTopic.microTopics.length > 0 && (
                              <div className="border-t border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 p-3">
                                <div className="space-y-3">
                                  {macroTopic.microTopics.map((microTopic, microIndex) => (
                                    <div
                                      key={microIndex}
                                      className="bg-white dark:bg-gray-800 p-3 rounded-lg border border-gray-200 dark:border-gray-700 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                                      onClick={() => onMicroTopicClick?.(microTopic)}
                                    >
                                      <h6 className="font-medium text-gray-900 dark:text-gray-100 mb-2">
                                        🔸 {microTopic.name}
                                      </h6>
                                      <p className="text-sm text-gray-600 dark:text-gray-300 mb-3">
                                        {microTopic.description}
                                      </p>
                                      
                                      {/* Key Terms */}
                                      {microTopic.keyTerms.length > 0 && (
                                        <div className="mb-2">
                                          <p className="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">
                                            Términos clave:
                                          </p>
                                          <div className="flex flex-wrap gap-1">
                                            {microTopic.keyTerms.map((term, termIndex) => (
                                              <span
                                                key={termIndex}
                                                className="inline-flex items-center px-2 py-0.5 rounded text-xs bg-blue-100 text-blue-800 dark:bg-blue-900/20 dark:text-blue-300"
                                              >
                                                {term}
                                              </span>
                                            ))}
                                          </div>
                                        </div>
                                      )}
                                      
                                      {/* Concepts */}
                                      {microTopic.concepts.length > 0 && (
                                        <div>
                                          <p className="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">
                                            Conceptos:
                                          </p>
                                          <div className="flex flex-wrap gap-1">
                                            {microTopic.concepts.map((concept, conceptIndex) => (
                                              <span
                                                key={conceptIndex}
                                                className="inline-flex items-center px-2 py-0.5 rounded text-xs bg-green-100 text-green-800 dark:bg-green-900/20 dark:text-green-300"
                                              >
                                                {concept}
                                              </span>
                                            ))}
                                          </div>
                                        </div>
                                      )}
                                    </div>
                                  ))}
                                </div>
                              </div>
                            )}
                          </div>
                        );
                      })}
                    </div>
                  </div>
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>
  );
}
