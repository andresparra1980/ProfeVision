"use client";

import { ExamQuestion, ExamOption } from "./examDatabase";

// Exam creation prompts and utilities

export interface ExamPromptConfig {
  numOpciones: number;
  tipoExamen: "multiple" | "verdadero-falso";
  tema?: string;
  nivel?: "basico" | "intermedio" | "avanzado";
  numPreguntas?: number;
}

export class ExamPrompts {
  // Generate system prompt for exam creation
  static getSystemPrompt(): string {
    return `Eres un experto en creación de exámenes educativos. Tu función es generar preguntas de opción múltiple de alta calidad.

REGLAS IMPORTANTES:
1. Solo puedes crear preguntas de opción múltiple (2-4 opciones) o verdadero/falso
2. Cada pregunta debe tener exactamente UNA respuesta correcta
3. Las opciones incorrectas deben ser plausibles pero claramente incorrectas
4. SIEMPRE responde en formato JSON válido
5. No incluyas explicaciones adicionales fuera del JSON
6. Las preguntas deben ser claras, precisas y educativamente válidas

COMPORTAMIENTO CRÍTICO:
- Si recibes un examen existente en el contexto, SIEMPRE devuelve el examen COMPLETO actualizado
- Numera las preguntas secuencialmente: pregunta1, pregunta2, pregunta3...
- Si modificas una pregunta, incluye TODAS las demás preguntas sin cambios
- Si agregas preguntas, inclúyelas al final del examen existente
- Si reordenas preguntas, devuelve todas en el nuevo orden
- Mantén preguntas no mencionadas exactamente igual
- NUNCA te refieras al material proporcionado en el contexto ya que el estudiante no lo tiene al alcance, solo usa el contexto para entender el tema.
- NUNCA devuelvas solo las preguntas modificadas - siempre el examen completo

FORMATO DE RESPUESTA REQUERIDO:
Para una sola pregunta (solo cuando NO hay examen previo):
{
  "pregunta": "Texto de la pregunta",
  "opciones": [
    { "texto": "Opción 1", "esCorrecta": false },
    { "texto": "Opción 2", "esCorrecta": true },
    { "texto": "Opción 3", "esCorrecta": false }
  ]
}

Para múltiples preguntas o cuando hay examen existente:
{
  "pregunta1": {
    "pregunta": "Primera pregunta",
    "opciones": [
      { "texto": "Opción A", "esCorrecta": true },
      { "texto": "Opción B", "esCorrecta": false }
    ]
  },
  "pregunta2": {
    "pregunta": "Segunda pregunta", 
    "opciones": [
      { "texto": "Opción A", "esCorrecta": false },
      { "texto": "Opción B", "esCorrecta": true }
    ]
  }
}`;
  }

  // Generate user prompt for specific exam configuration
  static generateUserPrompt(
    config: ExamPromptConfig,
    userRequest: string
  ): string {
    const { numOpciones, tipoExamen, tema, nivel, numPreguntas } = config;

    const prompt = `Crea ${numPreguntas || 1} pregunta${
      numPreguntas && numPreguntas > 1 ? "s" : ""
    } de examen sobre: ${userRequest}

ESPECIFICACIONES:
- Tipo: ${
      tipoExamen === "verdadero-falso" ? "Verdadero/Falso" : "Opción múltiple"
    }
- Número de opciones: ${numOpciones}
- ${tema ? `Tema específico: ${tema}` : ""}
- ${nivel ? `Nivel de dificultad: ${nivel}` : ""}

INSTRUCCIONES:
1. Debe incluir exactamente ${numOpciones} opciones por pregunta
2. Solo UNA opción debe ser correcta (esCorrecta: true)
3. Las opciones incorrectas deben ser creíbles pero incorrectas
4. La pregunta debe ser clara y sin ambigüedades
5. Responde ÚNICAMENTE con el JSON solicitado, sin texto adicional
6. Numera las preguntas secuencialmente: pregunta1, pregunta2, etc.

IMPORTANTE: Si hay un examen existente en el contexto, devuelve el examen COMPLETO actualizado con todas las preguntas.`;

    return prompt;
  }

  // Generate prompt for verdadero/falso questions
  static generateVerdaderoFalsoPrompt(
    userRequest: string,
    numPreguntas: number = 1
  ): string {
    return this.generateUserPrompt(
      {
        numOpciones: 2,
        tipoExamen: "verdadero-falso",
        numPreguntas,
      },
      userRequest
    );
  }

  // Generate prompt for multiple choice questions
  static generateMultipleChoicePrompt(
    userRequest: string,
    numOpciones: number = 4,
    numPreguntas: number = 1
  ): string {
    return this.generateUserPrompt(
      {
        numOpciones,
        tipoExamen: "multiple",
        numPreguntas,
      },
      userRequest
    );
  }

  // Extract question type from user input
  static detectQuestionType(userInput: string): ExamPromptConfig {
    const input = userInput.toLowerCase();

    // Detect verdadero/falso
    if (
      input.includes("verdadero") ||
      input.includes("falso") ||
      input.includes("true") ||
      input.includes("false") ||
      input.includes("v/f") ||
      input.includes("t/f")
    ) {
      return {
        numOpciones: 2,
        tipoExamen: "verdadero-falso",
      };
    }

    // Detect number of options
    let numOpciones = 4; // default
    if (input.includes("2 opciones") || input.includes("dos opciones")) {
      numOpciones = 2;
    } else if (
      input.includes("3 opciones") ||
      input.includes("tres opciones")
    ) {
      numOpciones = 3;
    } else if (
      input.includes("4 opciones") ||
      input.includes("cuatro opciones")
    ) {
      numOpciones = 4;
    }

    // Detect level
    let nivel: "basico" | "intermedio" | "avanzado" | undefined;
    if (
      input.includes("básico") ||
      input.includes("basico") ||
      input.includes("fácil")
    ) {
      nivel = "basico";
    } else if (input.includes("intermedio") || input.includes("medio")) {
      nivel = "intermedio";
    } else if (
      input.includes("avanzado") ||
      input.includes("difícil") ||
      input.includes("dificil")
    ) {
      nivel = "avanzado";
    }

    // Detect number of questions
    let numPreguntas = 1;
    const questionMatches = input.match(/(\d+)\s*pregunta/);
    if (questionMatches) {
      numPreguntas = parseInt(questionMatches[1], 10);
    }

    return {
      numOpciones,
      tipoExamen: "multiple",
      nivel,
      numPreguntas,
    };
  }

  // Validate that user input is appropriate for exam creation
  static validateExamRequest(userInput: string): {
    isValid: boolean;
    message?: string;
  } {
    const input = userInput.toLowerCase().trim();

    if (input.length < 5) {
      return {
        isValid: false,
        message:
          "La solicitud es demasiado corta. Por favor, proporciona más detalles sobre el tema del examen.",
      };
    }

    // Check for inappropriate content
    const inappropriateKeywords = [
      "hack",
      "crack",
      "illegal",
      "trampa",
      "cheat",
    ];
    if (inappropriateKeywords.some((keyword) => input.includes(keyword))) {
      return {
        isValid: false,
        message:
          "La solicitud contiene contenido inapropiado para un contexto educativo.",
      };
    }

    // More permissive validation - allow broader range of inputs
    const examKeywords = [
      "pregunta",
      "examen",
      "test",
      "quiz",
      "evaluación",
      "evaluacion",
      "opción",
      "opcion",
      "verdadero",
      "falso",
      "multiple",
      "choice",
      "crea",
      "genera",
      "haz",
      "sobre",
      "de",
      "cambia",
      "modifica",
    ];

    const hasExamKeywords = examKeywords.some((keyword) =>
      input.includes(keyword)
    );

    if (!hasExamKeywords) {
      return {
        isValid: false,
        message:
          'Por favor, especifica claramente que quieres crear preguntas de examen. Ejemplo: "Crea preguntas sobre matemáticas"',
      };
    }

    return { isValid: true };
  }

  // Generate follow-up suggestions
  static generateFollowUpSuggestions(config: ExamPromptConfig): string[] {
    const suggestions = [
      `Crear más preguntas del mismo tipo (${config.tipoExamen})`,
      "Cambiar el nivel de dificultad",
      "Modificar el número de opciones",
      "Crear preguntas sobre un tema específico",
      "Generar un examen completo (10-20 preguntas)",
    ];

    if (config.tipoExamen === "verdadero-falso") {
      suggestions.push("Convertir a preguntas de opción múltiple");
    } else {
      suggestions.push("Convertir a preguntas verdadero/falso");
    }

    return suggestions;
  }

  // Create example prompts for users
  static getExamplePrompts(): string[] {
    return [
      "Crea 3 preguntas de opción múltiple sobre la fotosíntesis",
      "Genera preguntas verdadero/falso sobre la Segunda Guerra Mundial",
      "Haz preguntas de nivel básico sobre matemáticas con 3 opciones",
      "Crea un examen sobre programación en JavaScript",
      "Preguntas avanzadas de física sobre mecánica cuántica",
      "Test de geografía sobre capitales europeas",
      "Examen de historia del arte renacentista",
      "Preguntas de biología sobre el sistema nervioso",
    ];
  }

  // Format prompt with context (simplified)
  static formatPromptWithContext(userInput: string): string {
    const config = this.detectQuestionType(userInput);
    const validation = this.validateExamRequest(userInput);

    if (!validation.isValid) {
      throw new Error(validation.message);
    }

    return this.generateUserPrompt(config, userInput);
  }
}

// Utility functions for exam management
export class ExamUtils {
  // Format question for display
  static formatQuestionForDisplay(
    question: ExamQuestion,
    index: number
  ): string {
    let formatted = `**Pregunta ${index + 1}:** ${question.pregunta}\n\n`;

    question.opciones.forEach((opcion: ExamOption, optionIndex: number) => {
      const letter = String.fromCharCode(65 + optionIndex); // A, B, C, D
      const marker = opcion.esCorrecta ? "✅" : "◯";
      formatted += `${letter}) ${opcion.texto} ${marker}\n`;
    });

    return formatted;
  }

  // Generate exam title from content
  static generateExamTitle(
    questions: ExamQuestion[],
    fallback: string = "Nuevo Examen"
  ): string {
    if (!questions || questions.length === 0) {
      return fallback;
    }

    // Try to extract topic from first question
    const firstQuestion = questions[0].pregunta.toLowerCase();

    // Common topics mapping
    const topicMappings = {
      matemática: "Matemáticas",
      historia: "Historia",
      biología: "Biología",
      física: "Física",
      química: "Química",
      geografía: "Geografía",
      literatura: "Literatura",
      inglés: "Inglés",
      programación: "Programación",
      javascript: "JavaScript",
      python: "Python",
    };

    for (const [key, value] of Object.entries(topicMappings)) {
      if (firstQuestion.includes(key)) {
        return `Examen de ${value}`;
      }
    }

    // Fallback to question count
    return `Examen (${questions.length} pregunta${
      questions.length > 1 ? "s" : ""
    })`;
  }

  // Validate JSON response from AI
  static validateAIResponse(response: string): {
    isValid: boolean;
    error?: string;
  } {
    try {
      const jsonMatch = response.match(/\{[\s\S]*\}/);
      if (!jsonMatch) {
        return {
          isValid: false,
          error: "No se encontró JSON válido en la respuesta",
        };
      }

      const parsed = JSON.parse(jsonMatch[0]);

      // Validate structure
      if (parsed.pregunta && parsed.opciones) {
        // Single question format
        return this.validateSingleQuestion(parsed);
      } else {
        // Multiple questions format
        return this.validateMultipleQuestions(parsed);
      }
    } catch (error) {
      return { isValid: false, error: `Error de JSON: ${error}` };
    }
  }

  private static validateSingleQuestion(question: Partial<ExamQuestion>): {
    isValid: boolean;
    error?: string;
  } {
    if (!question.pregunta || typeof question.pregunta !== "string") {
      return {
        isValid: false,
        error: 'Falta el campo "pregunta" o no es un string',
      };
    }

    if (!Array.isArray(question.opciones) || question.opciones.length < 2) {
      return {
        isValid: false,
        error: "Las opciones deben ser un array con al menos 2 elementos",
      };
    }

    const correctCount = question.opciones.filter(
      (op: ExamOption) => op.esCorrecta === true
    ).length;
    if (correctCount !== 1) {
      return {
        isValid: false,
        error: "Debe haber exactamente una opción correcta",
      };
    }

    return { isValid: true };
  }

  private static validateMultipleQuestions(
    questions: Record<string, ExamQuestion>
  ): { isValid: boolean; error?: string } {
    const questionKeys = Object.keys(questions).filter((key) =>
      key.startsWith("pregunta")
    );

    if (questionKeys.length === 0) {
      return {
        isValid: false,
        error: "No se encontraron preguntas en el formato esperado",
      };
    }

    for (const key of questionKeys) {
      const validation = this.validateSingleQuestion(questions[key]);
      if (!validation.isValid) {
        return {
          isValid: false,
          error: `Error en ${key}: ${validation.error}`,
        };
      }
    }

    return { isValid: true };
  }
}
