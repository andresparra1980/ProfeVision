'use client';

import { useState, useEffect, useCallback, useRef } from 'react';
import { JobQueue, getJobQueue, JobProgress, JobQueueOptions } from '../workers/jobQueue';
import { TopicSummary, ProcessingJob } from '../examDatabase';

export interface BackgroundProcessingState {
  jobs: ProcessingJob[];
  activeJobs: ProcessingJob[];
  queueStatus: {
    totalJobs: number;
    activeJobs: number;
    queuedJobs: number;
    isProcessing: boolean;
  };
  isProcessing: boolean;
}

export interface UseBackgroundProcessingOptions extends JobQueueOptions {
  autoStart?: boolean;
  updateInterval?: number;
}

export interface UseBackgroundProcessingReturn {
  // State
  state: BackgroundProcessingState;
  
  // Actions
  addJob: (file: File, conversationId: number) => Promise<string>;
  removeJob: (jobId: string) => boolean;
  clearCompletedJobs: () => number;
  retryJob: (jobId: string) => Promise<string>;
  
  // Job monitoring
  getJob: (jobId: string) => ProcessingJob | undefined;
  getJobProgress: (jobId: string) => JobProgress | undefined;
  
  // Queue management
  pauseProcessing: () => void;
  resumeProcessing: () => void;
  clearQueue: () => void;
  
  // Events
  onJobCompleted: (callback: (jobId: string, result: TopicSummary) => void) => void;
  onJobFailed: (callback: (jobId: string, error: string) => void) => void;
  onJobProgress: (callback: (progress: JobProgress) => void) => void;
}

const DEFAULT_OPTIONS: UseBackgroundProcessingOptions = {
  autoStart: true,
  updateInterval: 1000,
  maxConcurrentJobs: 2,
  retryAttempts: 2,
};

export function useBackgroundProcessing(
  options: UseBackgroundProcessingOptions = {}
): UseBackgroundProcessingReturn {
  const opts = { ...DEFAULT_OPTIONS, ...options };
  
  // State management
  const [state, setState] = useState<BackgroundProcessingState>({
    jobs: [],
    activeJobs: [],
    queueStatus: {
      totalJobs: 0,
      activeJobs: 0,
      queuedJobs: 0,
      isProcessing: false,
    },
    isProcessing: false,
  });

  // Refs for event callbacks
  const onJobCompletedRef = useRef<((jobId: string, result: TopicSummary) => void) | null>(null);
  const onJobFailedRef = useRef<((jobId: string, error: string) => void) | null>(null);
  const onJobProgressRef = useRef<((progress: JobProgress) => void) | null>(null);
  
  // Job queue instance
  const jobQueueRef = useRef<JobQueue | null>(null);
  
  // Update interval ref
  const updateIntervalRef = useRef<NodeJS.Timeout | null>(null);

  // Update state from job queue
  const updateState = useCallback(() => {
    if (!jobQueueRef.current) return;

    const queue = jobQueueRef.current;
    
    setState({
      jobs: queue.getAllJobs(),
      activeJobs: queue.getActiveJobs(),
      queueStatus: queue.getQueueStatus(),
      isProcessing: queue.getQueueStatus().isProcessing,
    });
  }, []);

  // Initialize job queue
  useEffect(() => {
    if (!jobQueueRef.current) {
      jobQueueRef.current = getJobQueue({
        maxConcurrentJobs: opts.maxConcurrentJobs,
        retryAttempts: opts.retryAttempts,
        onJobProgress: (progress: JobProgress) => {
          onJobProgressRef.current?.(progress);
          updateState();
        },
        onJobCompleted: (jobId: string, result: TopicSummary) => {
          onJobCompletedRef.current?.(jobId, result);
          updateState();
        },
        onJobFailed: (jobId: string, error: string) => {
          onJobFailedRef.current?.(jobId, error);
          updateState();
        },
      });
    }

    // Start periodic state updates
    if (opts.updateInterval && opts.updateInterval > 0) {
      updateIntervalRef.current = setInterval(updateState, opts.updateInterval);
    }

    // Initial state update
    updateState();

    return () => {
      if (updateIntervalRef.current) {
        clearInterval(updateIntervalRef.current);
      }
    };
  }, [opts.maxConcurrentJobs, opts.retryAttempts, opts.updateInterval, updateState]);

  // Add a new job
  const addJob = useCallback(async (file: File, conversationId: number): Promise<string> => {
    if (!jobQueueRef.current) {
      throw new Error('Job queue not initialized');
    }

    console.log(`📋 Adding background job for: ${file.name}`);

    // Convert file to ArrayBuffer
    const fileData = await file.arrayBuffer();
    
    // Add to queue
    const jobId = jobQueueRef.current.addJob(
      file.name,
      file.size,
      conversationId,
      fileData
    );

    // Update state immediately
    updateState();

    return jobId;
  }, [updateState]);

  // Remove a job
  const removeJob = useCallback((jobId: string): boolean => {
    if (!jobQueueRef.current) return false;

    const success = jobQueueRef.current.removeJob(jobId);
    if (success) {
      updateState();
    }
    return success;
  }, [updateState]);

  // Clear completed jobs
  const clearCompletedJobs = useCallback((): number => {
    if (!jobQueueRef.current) return 0;

    const cleared = jobQueueRef.current.clearCompletedJobs();
    updateState();
    return cleared;
  }, [updateState]);

  // Retry a failed job
  const retryJob = useCallback(async (jobId: string): Promise<string> => {
    if (!jobQueueRef.current) {
      throw new Error('Job queue not initialized');
    }

    const job = jobQueueRef.current.getJob(jobId);
    if (!job) {
      throw new Error('Job not found');
    }

    if (job.status !== 'failed') {
      throw new Error('Can only retry failed jobs');
    }

    // Remove the failed job and create a new one
    jobQueueRef.current.removeJob(jobId);
    
    // Note: We'd need to store file data to retry, for now we'll throw an error
    throw new Error('Retry not implemented - file data not available');
  }, []);

  // Get specific job
  const getJob = useCallback((jobId: string): ProcessingJob | undefined => {
    return jobQueueRef.current?.getJob(jobId);
  }, []);

  // Get job progress (simplified for now)
  const getJobProgress = useCallback((jobId: string): JobProgress | undefined => {
    const job = getJob(jobId);
    if (!job) return undefined;

    return {
      jobId: job.id,
      status: job.status,
      progress: job.progress,
      stage: job.stage,
      error: job.error,
      result: job.result,
    };
  }, [getJob]);

  // Pause processing (not implemented in queue yet)
  const pauseProcessing = useCallback(() => {
    console.log('⏸️ Pause processing not implemented yet');
  }, []);

  // Resume processing (not implemented in queue yet)
  const resumeProcessing = useCallback(() => {
    console.log('▶️ Resume processing not implemented yet');
  }, []);

  // Clear entire queue
  const clearQueue = useCallback(() => {
    if (!jobQueueRef.current) return;

    const allJobs = jobQueueRef.current.getAllJobs();
    allJobs.forEach(job => {
      if (job.status !== 'extracting' && job.status !== 'summarizing') {
        jobQueueRef.current?.removeJob(job.id);
      }
    });
    
    updateState();
  }, [updateState]);

  // Event subscription methods
  const onJobCompleted = useCallback((callback: (jobId: string, result: TopicSummary) => void) => {
    onJobCompletedRef.current = callback;
  }, []);

  const onJobFailed = useCallback((callback: (jobId: string, error: string) => void) => {
    onJobFailedRef.current = callback;
  }, []);

  const onJobProgress = useCallback((callback: (progress: JobProgress) => void) => {
    onJobProgressRef.current = callback;
  }, []);

  return {
    // State
    state,
    
    // Actions
    addJob,
    removeJob,
    clearCompletedJobs,
    retryJob,
    
    // Job monitoring
    getJob,
    getJobProgress,
    
    // Queue management
    pauseProcessing,
    resumeProcessing,
    clearQueue,
    
    // Events
    onJobCompleted,
    onJobFailed,
    onJobProgress,
  };
}

// Helper hook for job statistics
export function useJobStatistics(jobs: ProcessingJob[]) {
  return {
    total: jobs.length,
    queued: jobs.filter(j => j.status === 'queued').length,
    processing: jobs.filter(j => j.status === 'extracting' || j.status === 'summarizing').length,
    completed: jobs.filter(j => j.status === 'completed').length,
    failed: jobs.filter(j => j.status === 'failed').length,
    
    // Average processing time for completed jobs
    avgProcessingTime: (() => {
      const completed = jobs.filter(j => j.status === 'completed' && j.startedAt && j.completedAt);
      if (completed.length === 0) return 0;
      
      const totalTime = completed.reduce((sum, job) => {
        const start = job.startedAt!.getTime();
        const end = job.completedAt!.getTime();
        return sum + (end - start);
      }, 0);
      
      return Math.round(totalTime / completed.length / 1000); // in seconds
    })(),
    
    // Success rate
    successRate: jobs.length > 0 ? Math.round((jobs.filter(j => j.status === 'completed').length / jobs.length) * 100) : 0,
  };
}
</file>

<file path="lib/hooks/useDocumentContext.ts">
'use client';

import { useState, useCallback, useRef } from 'react';
import { TopicSummary, ExamService } from '../examDatabase';
import { DOCXExtractor } from '../document-processor/extractors/DOCXExtractor';
import { PPTXExtractor } from '../document-processor/extractors/PPTXExtractor';
import { PDFExtractor } from '../document-processor/extractors/PDFExtractor';
import { TopicSummarizer } from '../document-processor/topic-summarizer';

export interface ProcessingStatus {
  stage: 'idle' | 'extracting' | 'summarizing' | 'saving' | 'completed' | 'error';
  message: string;
  progress: number; // 0-100
  fileName?: string;
}

export interface UseDocumentContextOptions {
  maxFileSize?: number; // in bytes
  allowedTypes?: string[];
  autoSave?: boolean;
}

export interface UseDocumentContextReturn {
  // State
  isProcessing: boolean;
  processingStatus: ProcessingStatus;
  topicSummaries: TopicSummary[];
  
  // Actions
  processDocument: (file: File, conversationId?: number) => Promise<TopicSummary>;
  removeDocument: (summaryId: string, conversationId?: number) => Promise<void>;
  clearAllDocuments: (conversationId?: number) => Promise<void>;
  
  // Context generation
  getChatContext: () => string;
  getTopicsSummary: () => string;
  
  // Utilities
  validateFile: (file: File) => Promise<{ isValid: boolean; error?: string }>;
  getSupportedFormats: () => string[];
}

const DEFAULT_OPTIONS: UseDocumentContextOptions = {
  maxFileSize: 50 * 1024 * 1024, // 50MB
  allowedTypes: ['.pdf', '.docx', '.doc', '.pptx', '.ppt'],
  autoSave: true
};

export function useDocumentContext(
  options: UseDocumentContextOptions = {}
): UseDocumentContextReturn {
  const opts = { ...DEFAULT_OPTIONS, ...options };
  
  // State management
  const [isProcessing, setIsProcessing] = useState(false);
  const [processingStatus, setProcessingStatus] = useState<ProcessingStatus>({
    stage: 'idle',
    message: 'Listo para procesar documentos',
    progress: 0
  });
  const [topicSummaries, setTopicSummaries] = useState<TopicSummary[]>([]);
  
  // Refs to avoid stale closures
  const topicSummariesRef = useRef<TopicSummary[]>([]);
  
  // Update ref when state changes
  useState(() => {
    topicSummariesRef.current = topicSummaries;
  });

  // Update processing status
  const updateStatus = useCallback((
    stage: ProcessingStatus['stage'],
    message: string,
    progress: number,
    fileName?: string
  ) => {
    setProcessingStatus({ stage, message, progress, fileName });
  }, []);

  // Validate file before processing
  const validateFile = useCallback(async (file: File): Promise<{ isValid: boolean; error?: string }> => {
    // Check file size
    if (file.size > opts.maxFileSize!) {
      return {
        isValid: false,
        error: `El archivo es demasiado grande. Máximo permitido: ${Math.round(opts.maxFileSize! / 1024 / 1024)}MB`
      };
    }

    // Check file type
    const fileExtension = '.' + file.name.split('.').pop()?.toLowerCase();
    const isTypeAllowed = opts.allowedTypes!.includes(fileExtension);
    
    if (!isTypeAllowed) {
      return {
        isValid: false,
        error: `Tipo de archivo no soportado. Formatos permitidos: ${opts.allowedTypes!.join(', ')}`
      };
    }

    // Additional validation based on file type
    if (fileExtension === '.pdf') {
      try {
        if (!PDFExtractor.validateFile(file)) {
          return {
            isValid: false,
            error: 'El archivo PDF no es válido o está corrupto'
          };
        }
      } catch {
        return {
          isValid: false,
          error: 'Error validando archivo PDF'
        };
      }
    }

    if (['.docx', '.doc'].includes(fileExtension) && !DOCXExtractor.validateFile(file)) {
      return {
        isValid: false,
        error: 'El archivo Word no es válido o está corrupto'
      };
    }

    if (['.pptx', '.ppt'].includes(fileExtension) && !PPTXExtractor.validateFile(file)) {
      return {
        isValid: false,
        error: 'El archivo PowerPoint no es válido o está corrupto'
      };
    }

    return { isValid: true };
  }, [opts.maxFileSize, opts.allowedTypes]);

  // Process a document file
  const processDocument = useCallback(async (
    file: File,
    conversationId?: number
  ): Promise<TopicSummary> => {
    try {
      console.log('🔄 Starting document processing for:', file.name);
      
      setIsProcessing(true);
      updateStatus('extracting', `Extrayendo contenido de ${file.name}...`, 10, file.name);

      // Check if file is already processed
      const existingSummary = topicSummariesRef.current.find(
        summary => summary.fileName === file.name
      );

      if (existingSummary) {
        console.log('⚠️ File already processed, skipping:', file.name);
        updateStatus('completed', `Archivo ${file.name} ya procesado anteriormente`, 100, file.name);
        throw new Error(`El archivo "${file.name}" ya ha sido procesado en esta conversación`);
      }

      // Validate file first
      const validation = await validateFile(file);
      if (!validation.isValid) {
        throw new Error(validation.error);
      }

      // Detect file type and choose appropriate extractor
      const fileExtension = '.' + file.name.split('.').pop()?.toLowerCase();
      let extractedContent;

      switch (fileExtension) {
        case '.pdf':
          updateStatus('extracting', 'Extrayendo texto del PDF...', 20, file.name);
          extractedContent = await PDFExtractor.extractText(file);
          break;
          
        case '.docx':
        case '.doc':
          updateStatus('extracting', 'Extrayendo texto del documento Word...', 20, file.name);
          extractedContent = await DOCXExtractor.extractText(file);
          break;
          
        case '.pptx':
        case '.ppt':
          updateStatus('extracting', 'Extrayendo texto de la presentación...', 20, file.name);
          extractedContent = await PPTXExtractor.extractText(file);
          break;
          
        default:
          throw new Error(`Tipo de archivo no soportado: ${fileExtension}`);
      }

      updateStatus('extracting', 'Contenido extraído exitosamente', 40, file.name);

      // Check if we have meaningful content
      if (!extractedContent.text || extractedContent.text.trim().length < 100) {
        throw new Error('El documento no contiene suficiente texto para analizar');
      }

      console.log(`📄 Extracted ${extractedContent.text.length} characters from ${file.name}`);

      // Summarize the content using AI
      updateStatus('summarizing', 'Analizando contenido con IA...', 60, file.name);
      
      const topicSummary = await TopicSummarizer.summarizeDocument(
        extractedContent.text,
        file.name
      );

      updateStatus('summarizing', 'Análisis de temas completado', 80, file.name);

      // Save to conversation if provided
      if (conversationId && opts.autoSave) {
        updateStatus('saving', 'Guardando contexto...', 90, file.name);
        
        await ExamService.addTopicSummary(conversationId, topicSummary);
      }

      // Update local state
      setTopicSummaries(prev => [...prev, topicSummary]);

      updateStatus('completed', `Documento ${file.name} procesado exitosamente`, 100, file.name);
      
      console.log('✅ Document processing completed successfully');
      
      return topicSummary;

    } catch (error) {
      console.error('❌ Error processing document:', error);
      updateStatus(
        'error',
        `Error procesando ${file.name}: ${error instanceof Error ? error.message : 'Error desconocido'}`,
        0,
        file.name
      );
      throw error;
    } finally {
      setIsProcessing(false);
    }
  }, [validateFile, updateStatus, opts.autoSave]);

  // Remove a document
  const removeDocument = useCallback(async (
    summaryId: string,
    conversationId?: number
  ): Promise<void> => {
    try {
      console.log('🗑️ Removing document with ID:', summaryId);

      // Remove from conversation if provided
      if (conversationId) {
        await ExamService.removeTopicSummary(conversationId, summaryId);
      }

      // Update local state
      setTopicSummaries(prev => prev.filter(summary => summary.id !== summaryId));

      console.log('✅ Document removed successfully');

    } catch (error) {
      console.error('❌ Error removing document:', error);
      throw error;
    }
  }, []);

  // Clear all documents
  const clearAllDocuments = useCallback(async (conversationId?: number): Promise<void> => {
    try {
      console.log('🗑️ Clearing all documents');

      if (conversationId) {
        // Remove all summaries from conversation
        const currentSummaries = topicSummariesRef.current;
        for (const summary of currentSummaries) {
          await ExamService.removeTopicSummary(conversationId, summary.id);
        }
      }

      // Clear local state
      setTopicSummaries([]);

      console.log('✅ All documents cleared successfully');

    } catch (error) {
      console.error('❌ Error clearing documents:', error);
      throw error;
    }
  }, []);

  // Generate chat context from all summaries
  const getChatContext = useCallback((): string => {
    return TopicSummarizer.generateChatContext(topicSummariesRef.current);
  }, []);

  // Generate topics summary for display
  const getTopicsSummary = useCallback((): string => {
    return TopicSummarizer.generateTopicsSummary(topicSummariesRef.current);
  }, []);

  // Get supported file formats
  const getSupportedFormats = useCallback((): string[] => {
    return [
      '.pdf',
      ...DOCXExtractor.getSupportedExtensions(),
      ...PPTXExtractor.getSupportedExtensions()
    ];
  }, []);

  return {
    // State
    isProcessing,
    processingStatus,
    topicSummaries,
    
    // Actions
    processDocument,
    removeDocument,
    clearAllDocuments,
    
    // Context generation
    getChatContext,
    getTopicsSummary,
    
    // Utilities
    validateFile,
    getSupportedFormats
  };
}
</file>

<file path="lib/workers/jobQueue.ts">
"use client";

import { ProcessingJob, TopicSummary, ExamService } from "../examDatabase";
import { DOCXExtractor } from "../document-processor/extractors/DOCXExtractor";
import { TopicSummarizer } from "../document-processor/topic-summarizer";

export type JobStatus =
  | "queued"
  | "extracting"
  | "summarizing"
  | "completed"
  | "failed";

export interface JobProgress {
  jobId: string;
  status: JobStatus;
  progress: number;
  stage: string;
  error?: string;
  result?: TopicSummary;
}

export interface JobQueueOptions {
  maxConcurrentJobs?: number;
  retryAttempts?: number;
  onJobProgress?: (progress: JobProgress) => void;
  onJobCompleted?: (jobId: string, result: TopicSummary) => void;
  onJobFailed?: (jobId: string, error: string) => void;
}

export class JobQueue {
  private jobs: Map<string, ProcessingJob> = new Map();
  private activeJobs: Set<string> = new Set();
  private queue: string[] = [];
  private options: Required<JobQueueOptions>;
  private isProcessing = false;

  constructor(options: JobQueueOptions = {}) {
    this.options = {
      maxConcurrentJobs: 2,
      retryAttempts: 2,
      onJobProgress: options.onJobProgress || (() => {}),
      onJobCompleted: options.onJobCompleted || (() => {}),
      onJobFailed: options.onJobFailed || (() => {}),
    };
  }

  // Add a new job to the queue
  addJob(
    fileName: string,
    fileSize: number,
    conversationId: number,
    fileData: ArrayBuffer
  ): string {
    const jobId = `job-${Date.now()}-${Math.random()
      .toString(36)
      .substr(2, 9)}`;

    const job: ProcessingJob = {
      id: jobId,
      fileName,
      fileSize,
      conversationId,
      status: "queued",
      progress: 0,
      stage: "En cola",
      createdAt: new Date(),
    };

    this.jobs.set(jobId, job);
    this.queue.push(jobId);

    // Store file data separately (not in job object to avoid serialization issues)
    this.storeFileData(jobId, fileData);

    console.log(`📋 Job added to queue: ${fileName} (${jobId})`);

    // Notify about job creation
    this.options.onJobProgress({
      jobId,
      status: "queued",
      progress: 0,
      stage: "En cola de procesamiento",
    });

    // Start processing if not already running
    this.processQueue();

    return jobId;
  }

  // Get job status
  getJob(jobId: string): ProcessingJob | undefined {
    return this.jobs.get(jobId);
  }

  // Get all jobs
  getAllJobs(): ProcessingJob[] {
    return Array.from(this.jobs.values()).sort(
      (a, b) => b.createdAt.getTime() - a.createdAt.getTime()
    );
  }

  // Get active jobs
  getActiveJobs(): ProcessingJob[] {
    return Array.from(this.activeJobs)
      .map((jobId) => this.jobs.get(jobId))
      .filter(Boolean) as ProcessingJob[];
  }

  // Get queue status
  getQueueStatus() {
    return {
      totalJobs: this.jobs.size,
      activeJobs: this.activeJobs.size,
      queuedJobs: this.queue.length,
      isProcessing: this.isProcessing,
    };
  }

  // Remove a job
  removeJob(jobId: string): boolean {
    const job = this.jobs.get(jobId);
    if (!job) return false;

    // Don't remove active jobs
    if (this.activeJobs.has(jobId)) {
      console.warn(`Cannot remove active job: ${jobId}`);
      return false;
    }

    this.jobs.delete(jobId);
    this.queue = this.queue.filter((id) => id !== jobId);
    this.clearFileData(jobId);

    console.log(`🗑️ Job removed: ${jobId}`);
    return true;
  }

  // Clear completed jobs
  clearCompletedJobs(): number {
    const completedJobs = Array.from(this.jobs.entries())
      .filter(
        ([, job]) => job.status === "completed" || job.status === "failed"
      )
      .map(([jobId]) => jobId);

    completedJobs.forEach((jobId) => this.removeJob(jobId));

    console.log(`🧹 Cleared ${completedJobs.length} completed jobs`);
    return completedJobs.length;
  }

  // Process the job queue
  private async processQueue(): Promise<void> {
    if (this.isProcessing) return;

    this.isProcessing = true;

    while (
      this.queue.length > 0 &&
      this.activeJobs.size < this.options.maxConcurrentJobs
    ) {
      const jobId = this.queue.shift();
      if (!jobId) continue;

      const job = this.jobs.get(jobId);
      if (!job) continue;

      // Start processing the job
      this.activeJobs.add(jobId);
      this.processJob(jobId);
    }

    this.isProcessing = false;
  }

  // Process an individual job
  private async processJob(jobId: string): Promise<void> {
    const job = this.jobs.get(jobId);
    if (!job) return;

    try {
      console.log(`🚀 Starting job: ${job.fileName} (${jobId})`);

      // Update job status
      this.updateJobStatus(jobId, "extracting", 10, "Extrayendo contenido...");

      // Get file data
      const fileData = this.getFileData(jobId);
      if (!fileData) {
        throw new Error("File data not found");
      }

      // Create File object
      const file = new File([fileData], job.fileName);

      // Step 1: Extract content
      const extractedContent = await this.extractFileContent(file, jobId);

      this.updateJobStatus(
        jobId,
        "summarizing",
        50,
        "Analizando contenido con IA..."
      );

      // Step 2: Summarize content
      const summary = await this.summarizeContent(
        extractedContent,
        job.fileName,
        jobId
      );

      // Step 3: Save to database
      this.updateJobStatus(jobId, "completed", 90, "Guardando resultados...");

      await this.saveToDatabase(job.conversationId, summary);

      // Complete the job
      this.completeJob(jobId, summary);
    } catch (error) {
      console.error(`❌ Job failed: ${jobId}`, error);
      this.failJob(
        jobId,
        error instanceof Error ? error.message : "Unknown error"
      );
    } finally {
      this.activeJobs.delete(jobId);
      this.clearFileData(jobId);

      // Continue processing queue
      setTimeout(() => this.processQueue(), 100);
    }
  }

  // Extract file content
  private async extractFileContent(file: File, jobId: string): Promise<string> {
    const fileExtension = "." + file.name.split(".").pop()?.toLowerCase();

    this.updateJobStatus(
      jobId,
      "extracting",
      20,
      `Procesando ${fileExtension.toUpperCase()}...`
    );

    switch (fileExtension) {
      case ".pdf":
        // Use the new super-fast PDF extraction API
        const formData = new FormData();
        formData.append("file", file);

        const response = await fetch("/api/extract-pdf", {
          method: "POST",
          body: formData,
        });

        if (!response.ok) {
          const errorData = await response.json();
          throw new Error(
            `PDF extraction failed: ${errorData.error || "Unknown error"}`
          );
        }

        const pdfResult = await response.json();
        return pdfResult.text;

      case ".docx":
      case ".doc":
        const docxResult = await DOCXExtractor.extractText(file);
        return docxResult.text;

      default:
        throw new Error(`Unsupported file type: ${fileExtension}`);
    }
  }

  // Summarize content with AI
  private async summarizeContent(
    content: string,
    fileName: string,
    jobId: string
  ): Promise<TopicSummary> {
    this.updateJobStatus(
      jobId,
      "summarizing",
      60,
      "Enviando a IA para análisis..."
    );

    return await TopicSummarizer.summarizeDocument(content, fileName);
  }

  // Save to database
  private async saveToDatabase(
    conversationId: number,
    summary: TopicSummary
  ): Promise<void> {
    await ExamService.addTopicSummary(conversationId, summary);
  }

  // Update job status
  private updateJobStatus(
    jobId: string,
    status: JobStatus,
    progress: number,
    stage: string
  ): void {
    const job = this.jobs.get(jobId);
    if (!job) return;

    job.status = status;
    job.progress = progress;
    job.stage = stage;

    if (status === "extracting" && !job.startedAt) {
      job.startedAt = new Date();
    }

    this.jobs.set(jobId, job);

    // Notify progress
    this.options.onJobProgress({
      jobId,
      status,
      progress,
      stage,
    });

    console.log(`📊 Job ${jobId}: ${status} (${progress}%) - ${stage}`);
  }

  // Complete a job
  private completeJob(jobId: string, result: TopicSummary): void {
    const job = this.jobs.get(jobId);
    if (!job) return;

    job.status = "completed";
    job.progress = 100;
    job.stage = "Completado";
    job.completedAt = new Date();
    job.result = result;

    this.jobs.set(jobId, job);

    console.log(`✅ Job completed: ${job.fileName} (${jobId})`);

    // Notify completion
    this.options.onJobCompleted(jobId, result);
    this.options.onJobProgress({
      jobId,
      status: "completed",
      progress: 100,
      stage: "Documento procesado exitosamente",
      result,
    });
  }

  // Fail a job
  private failJob(jobId: string, error: string): void {
    const job = this.jobs.get(jobId);
    if (!job) return;

    job.status = "failed";
    job.progress = 0;
    job.stage = "Error";
    job.error = error;
    job.completedAt = new Date();

    this.jobs.set(jobId, job);

    console.log(`❌ Job failed: ${job.fileName} (${jobId}) - ${error}`);

    // Notify failure
    this.options.onJobFailed(jobId, error);
    this.options.onJobProgress({
      jobId,
      status: "failed",
      progress: 0,
      stage: `Error: ${error}`,
      error,
    });
  }

  // File data storage (in-memory for now, could be moved to IndexedDB)
  private fileDataStorage = new Map<string, ArrayBuffer>();

  private storeFileData(jobId: string, data: ArrayBuffer): void {
    this.fileDataStorage.set(jobId, data);
  }

  private getFileData(jobId: string): ArrayBuffer | undefined {
    return this.fileDataStorage.get(jobId);
  }

  private clearFileData(jobId: string): void {
    this.fileDataStorage.delete(jobId);
  }
}

// Global job queue instance
let globalJobQueue: JobQueue | null = null;

export function getJobQueue(options?: JobQueueOptions): JobQueue {
  if (!globalJobQueue) {
    globalJobQueue = new JobQueue(options);
  }
  return globalJobQueue;
}

// Reset job queue (useful for testing)
export function resetJobQueue(): void {
  globalJobQueue = null;
}
