<file path="lib/document-processor/extractors/DOCXExtractor.ts">
'use client';

import mammoth from 'mammoth';

export interface DocumentExtractionResult {
  text: string;
  metadata: {
    fileSize?: number;
    wordCount?: number;
    characterCount?: number;
    extractedImages?: number;
  };
}

export class DOCXExtractor {
  static async extractText(file: File): Promise<DocumentExtractionResult> {
    try {
      console.log('🔍 Starting DOCX extraction for:', file.name);
      
      // Convert file to ArrayBuffer
      const arrayBuffer = await file.arrayBuffer();
      
      // Extract text using mammoth
      const result = await mammoth.extractRawText({ arrayBuffer });
      
      const extractedText = result.value;
      const messages = result.messages;
      
      // Log any warnings or messages from mammoth
      if (messages.length > 0) {
        console.log('📝 Mammoth messages:', messages);
      }
      
      // Generate metadata
      const metadata = this.generateMetadata(extractedText, file);
      
      console.log(`✅ DOCX extraction completed. Text length: ${extractedText.length} characters`);
      
      return {
        text: extractedText.trim(),
        metadata
      };
      
    } catch (error) {
      console.error('❌ Error extracting DOCX:', error);
      throw new Error(`Failed to extract DOCX content: ${error instanceof Error ? error.message : 'Unknown error'}`);
    }
  }
  
  static async extractTextWithFormatting(file: File): Promise<{ text: string; html: string; metadata: DocumentExtractionResult['metadata'] }> {
    try {
      console.log('🔍 Starting DOCX extraction with formatting for:', file.name);
      
      // Convert file to ArrayBuffer
      const arrayBuffer = await file.arrayBuffer();
      
      // Extract both raw text and HTML
      const [textResult, htmlResult] = await Promise.all([
        mammoth.extractRawText({ arrayBuffer }),
        mammoth.convertToHtml({ arrayBuffer })
      ]);
      
      const extractedText = textResult.value;
      const extractedHtml = htmlResult.value;
      
      // Log any warnings or messages
      const allMessages = [...textResult.messages, ...htmlResult.messages];
      if (allMessages.length > 0) {
        console.log('📝 Mammoth messages:', allMessages);
      }
      
      // Generate metadata
      const metadata = this.generateMetadata(extractedText, file);
      
      console.log(`✅ DOCX extraction with formatting completed. Text length: ${extractedText.length} characters`);
      
      return {
        text: extractedText.trim(),
        html: extractedHtml,
        metadata
      };
      
    } catch (error) {
      console.error('❌ Error extracting DOCX with formatting:', error);
      throw new Error(`Failed to extract DOCX content with formatting: ${error instanceof Error ? error.message : 'Unknown error'}`);
    }
  }
  
  private static generateMetadata(text: string, file: File): DocumentExtractionResult['metadata'] {
    // Count words (split by whitespace and filter out empty strings)
    const words = text.split(/\s+/).filter(word => word.length > 0);
    const wordCount = words.length;
    
    // Count characters (excluding whitespace)
    const characterCount = text.replace(/\s/g, '').length;
    
    return {
      fileSize: file.size,
      wordCount,
      characterCount,
      extractedImages: 0 // mammoth doesn't provide image count directly
    };
  }
  
  // Validate if file is a valid DOCX
  static validateFile(file: File): boolean {
    const validTypes = [
      'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
      'application/vnd.ms-word.document.macroEnabled.12',
      'application/msword'
    ];
    const validExtensions = ['.docx', '.doc'];
    
    const hasValidType = validTypes.includes(file.type);
    const hasValidExtension = validExtensions.some(ext => 
      file.name.toLowerCase().endsWith(ext)
    );
    
    return hasValidType || hasValidExtension;
  }
  
  // Get supported file extensions
  static getSupportedExtensions(): string[] {
    return ['.docx', '.doc'];
  }
  
  // Get supported MIME types
  static getSupportedMimeTypes(): string[] {
    return [
      'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
      'application/vnd.ms-word.document.macroEnabled.12',
      'application/msword'
    ];
  }
  
  // Clean extracted text (remove excessive whitespace, normalize line breaks)
  static cleanText(text: string): string {
    return text
      // Replace multiple consecutive whitespaces with single space
      .replace(/[ \t]+/g, ' ')
      // Replace multiple consecutive line breaks with double line break
      .replace(/\n{3,}/g, '\n\n')
      // Trim each line
      .split('\n')
      .map(line => line.trim())
      .join('\n')
      // Remove leading/trailing whitespace
      .trim();
  }
}
