'use client';

import { ExamQuestion } from '../lib/examDatabase';

interface ExamStatsProps {
  questions: ExamQuestion[];
  className?: string;
}

export default function ExamStats({
  questions,
  className = ''
}: ExamStatsProps) {
  
  const getStats = () => {
    if (questions.length === 0) {
      return {
        total: 0,
        verdaderoFalso: 0,
        opcionMultiple: 0,
        distribucionOpciones: {},
        dificultadPromedio: 0,
        tiempoEstimado: 0
      };
    }

    const verdaderoFalso = questions.filter(q => q.numeroOpciones === 2).length;
    const opcionMultiple = questions.filter(q => q.numeroOpciones > 2).length;
    
    const distribucionOpciones = questions.reduce((acc, q) => {
      acc[q.numeroOpciones] = (acc[q.numeroOpciones] || 0) + 1;
      return acc;
    }, {} as Record<number, number>);

    // Estimate difficulty based on number of options (more options = harder)
    const dificultadPromedio = questions.reduce((acc, q) => acc + q.numeroOpciones, 0) / questions.length;
    
    // Estimate time: 1-2 minutes per question depending on complexity
    const tiempoEstimado = questions.reduce((acc, q) => {
      return acc + (q.numeroOpciones === 2 ? 1 : 1.5);
    }, 0);

    return {
      total: questions.length,
      verdaderoFalso,
      opcionMultiple,
      distribucionOpciones,
      dificultadPromedio,
      tiempoEstimado: Math.round(tiempoEstimado)
    };
  };

  const getDifficultyLevel = (avg: number) => {
    if (avg <= 2.2) return { label: 'Básico', color: 'green' };
    if (avg <= 3.5) return { label: 'Intermedio', color: 'yellow' };
    return { label: 'Avanzado', color: 'red' };
  };

  const getQualityScore = () => {
    const stats = getStats();
    let score = 70; // Base score
    
    // Bonus for variety in question types
    if (stats.verdaderoFalso > 0 && stats.opcionMultiple > 0) {
      score += 10;
    }
    
    // Bonus for good distribution
    const optionVariety = Object.keys(stats.distribucionOpciones).length;
    if (optionVariety > 1) score += 10;
    
    // Bonus for reasonable length
    if (stats.total >= 5 && stats.total <= 20) score += 10;
    
    return Math.min(100, score);
  };

  const stats = getStats();
  const difficulty = getDifficultyLevel(stats.dificultadPromedio);
  const qualityScore = getQualityScore();

  if (questions.length === 0) {
    return (
      <div className={`bg-white rounded-lg border border-gray-200 p-6 ${className}`}>
        <div className="text-center text-gray-500">
          <svg className="mx-auto h-8 w-8 text-gray-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
          <p className="text-sm">No hay preguntas para analizar</p>
        </div>
      </div>
    );
  }

  return (
    <div className={`bg-white rounded-lg border border-gray-200 ${className}`}>
      {/* Header */}
      <div className="px-4 py-3 border-b border-gray-200 bg-gray-50 rounded-t-lg">
        <div className="flex items-center justify-between">
          <h3 className="text-lg font-medium text-gray-900">Estadísticas del Examen</h3>
          <div className={`px-2 py-1 rounded-full text-xs font-medium ${
            qualityScore >= 90 ? 'bg-green-100 text-green-800' :
            qualityScore >= 70 ? 'bg-yellow-100 text-yellow-800' :
            'bg-red-100 text-red-800'
          }`}>
            Calidad: {qualityScore}%
          </div>
        </div>
      </div>

      <div className="p-6">
        {/* Main Stats Grid */}
        <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
          <div className="text-center p-4 bg-blue-50 rounded-lg">
            <div className="text-2xl font-bold text-blue-600">{stats.total}</div>
            <div className="text-sm text-blue-800">Total Preguntas</div>
          </div>
          
          <div className="text-center p-4 bg-green-50 rounded-lg">
            <div className="text-2xl font-bold text-green-600">{stats.verdaderoFalso}</div>
            <div className="text-sm text-green-800">Verdadero/Falso</div>
          </div>
          
          <div className="text-center p-4 bg-purple-50 rounded-lg">
            <div className="text-2xl font-bold text-purple-600">{stats.opcionMultiple}</div>
            <div className="text-sm text-purple-800">Opción Múltiple</div>
          </div>
          
          <div className="text-center p-4 bg-orange-50 rounded-lg">
            <div className="text-2xl font-bold text-orange-600">{stats.tiempoEstimado}</div>
            <div className="text-sm text-orange-800">Minutos Est.</div>
          </div>
        </div>

        {/* Difficulty and Quality */}
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
          <div className="p-4 border border-gray-200 rounded-lg">
            <div className="flex items-center justify-between mb-2">
              <span className="text-sm font-medium text-gray-700">Nivel de Dificultad</span>
              <span className={`px-2 py-1 rounded-full text-xs font-medium ${
                difficulty.color === 'green' ? 'bg-green-100 text-green-800' :
                difficulty.color === 'yellow' ? 'bg-yellow-100 text-yellow-800' :
                'bg-red-100 text-red-800'
              }`}>
                {difficulty.label}
              </span>
            </div>
            <div className="w-full bg-gray-200 rounded-full h-2">
              <div 
                className={`h-2 rounded-full ${
                  difficulty.color === 'green' ? 'bg-green-500' :
                  difficulty.color === 'yellow' ? 'bg-yellow-500' :
                  'bg-red-500'
                }`}
                style={{ width: `${(stats.dificultadPromedio / 4) * 100}%` }}
              ></div>
            </div>
            <div className="text-xs text-gray-500 mt-1">
              Promedio: {stats.dificultadPromedio.toFixed(1)} opciones
            </div>
          </div>

          <div className="p-4 border border-gray-200 rounded-lg">
            <div className="flex items-center justify-between mb-2">
              <span className="text-sm font-medium text-gray-700">Puntuación de Calidad</span>
              <span className="text-sm font-bold text-gray-900">{qualityScore}/100</span>
            </div>
            <div className="w-full bg-gray-200 rounded-full h-2">
              <div 
                className={`h-2 rounded-full ${
                  qualityScore >= 90 ? 'bg-green-500' :
                  qualityScore >= 70 ? 'bg-yellow-500' :
                  'bg-red-500'
                }`}
                style={{ width: `${qualityScore}%` }}
              ></div>
            </div>
            <div className="text-xs text-gray-500 mt-1">
              Basado en variedad y estructura
            </div>
          </div>
        </div>

        {/* Distribution Chart */}
        <div className="border border-gray-200 rounded-lg p-4">
          <h4 className="text-sm font-medium text-gray-700 mb-3">Distribución por Número de Opciones</h4>
          <div className="space-y-2">
            {Object.entries(stats.distribucionOpciones)
              .sort(([a], [b]) => parseInt(a) - parseInt(b))
              .map(([opciones, cantidad]) => {
                const percentage = (cantidad / stats.total) * 100;
                return (
                  <div key={opciones} className="flex items-center justify-between">
                    <div className="flex items-center space-x-2">
                      <span className="text-sm text-gray-600 w-16">
                        {opciones} opción{parseInt(opciones) > 1 ? 'es' : ''}:
                      </span>
                      <div className="flex-1 bg-gray-200 rounded-full h-2 min-w-24">
                        <div 
                          className="bg-blue-500 h-2 rounded-full"
                          style={{ width: `${percentage}%` }}
                        ></div>
                      </div>
                    </div>
                    <div className="flex items-center space-x-2 text-sm">
                      <span className="text-gray-900 font-medium">{cantidad}</span>
                      <span className="text-gray-500">({percentage.toFixed(0)}%)</span>
                    </div>
                  </div>
                );
              })}
          </div>
        </div>

        {/* Recommendations */}
        <div className="mt-6 p-4 bg-blue-50 rounded-lg">
          <h4 className="text-sm font-medium text-blue-900 mb-2">💡 Recomendaciones</h4>
          <div className="space-y-1 text-xs text-blue-800">
            {stats.total < 5 && (
              <div>• Considera agregar más preguntas para un examen más completo</div>
            )}
            {stats.total > 25 && (
              <div>• El examen podría ser muy largo, considera dividirlo</div>
            )}
            {stats.verdaderoFalso === 0 && (
              <div>• Agregar preguntas V/F puede aumentar la variedad</div>
            )}
            {stats.opcionMultiple === 0 && (
              <div>• Preguntas de opción múltiple pueden evaluar mejor el conocimiento</div>
            )}
            {Object.keys(stats.distribucionOpciones).length === 1 && (
              <div>• Varía el número de opciones para mayor dinamismo</div>
            )}
            {qualityScore === 100 && (
              <div>• ¡Excelente! Tu examen tiene una estructura muy equilibrada</div>
            )}
          </div>
        </div>

        {/* Technical Details */}
        <div className="mt-4 pt-4 border-t border-gray-200">
          <details className="group">
            <summary className="cursor-pointer text-sm font-medium text-gray-700 hover:text-gray-900">
              Detalles Técnicos
              <span className="ml-2 group-open:rotate-90 transition-transform inline-block">▶</span>
            </summary>
            <div className="mt-2 space-y-2 text-xs text-gray-600">
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <strong>Tiempo por pregunta:</strong>
                  <ul className="mt-1 space-y-1">
                    <li>• V/F: ~1 minuto</li>
                    <li>• Opción múltiple: ~1.5 minutos</li>
                  </ul>
                </div>
                <div>
                  <strong>Criterios de calidad:</strong>
                  <ul className="mt-1 space-y-1">
                    <li>• Variedad de tipos (+10)</li>
                    <li>• Múltiples opciones (+10)</li>
                    <li>• Longitud óptima (+10)</li>
                  </ul>
                </div>
              </div>
            </div>
          </details>
        </div>
      </div>
    </div>
  );
}
