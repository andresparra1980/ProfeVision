<file path="components/ExamQuestionDisplay.tsx">
import { useState, useEffect } from "react";
import { ExamQuestion } from "../lib/examDatabase";

interface ExamQuestionDisplayProps {
  questions: ExamQuestion[];
  isProcessing?: boolean;
  onExport?: () => void;
  onClear?: () => void;
  className?: string;
}

export default function ExamQuestionDisplay({
  questions,
  isProcessing = false,
  onExport,
  onClear,
  className = "",
}: ExamQuestionDisplayProps) {
  const [expandedQuestions, setExpandedQuestions] = useState<Set<number>>(
    new Set(),
  );
  const [showAnswers, setShowAnswers] = useState(false);
  const [isClient, setIsClient] = useState(false);
  const [currentTime, setCurrentTime] = useState('');

  useEffect(() => {
    setIsClient(true);
    setCurrentTime(new Date().toLocaleTimeString());
  }, []);

  const toggleQuestion = (questionNumber: number) => {
    const newExpanded = new Set(expandedQuestions);
    if (newExpanded.has(questionNumber)) {
      newExpanded.delete(questionNumber);
    } else {
      newExpanded.add(questionNumber);
    }
    setExpandedQuestions(newExpanded);
  };

  const toggleAllQuestions = () => {
    if (expandedQuestions.size === questions.length) {
      setExpandedQuestions(new Set());
    } else {
      setExpandedQuestions(new Set(questions.map((q) => q.numeroPregunta)));
    }
  };

  const getOptionLetter = (index: number) => {
    return String.fromCharCode(65 + index); // A, B, C, D
  };

  const getQuestionTypeIcon = (numOpciones: number) => {
    if (numOpciones === 2) {
      return (
        <span className="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
          V/F
        </span>
      );
    } else {
      return (
        <span className="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
          {numOpciones} opciones
        </span>
      );
    }
  };

  const getQuestionStats = () => {
    const verdaderoFalso = questions.filter(
      (q) => q.numeroOpciones === 2,
    ).length;
    const opcionMultiple = questions.filter((q) => q.numeroOpciones > 2).length;

    return { verdaderoFalso, opcionMultiple };
  };

  if (questions.length === 0 && !isProcessing) {
    return (
      <div className={`bg-gray-50 rounded-lg p-6 text-center ${className}`}>
        <svg
          className="mx-auto h-12 w-12 text-gray-400"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            strokeLinecap="round"
            strokeLinejoin="round"
            strokeWidth={2}
            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          />
        </svg>
        <h3 className="mt-2 text-sm font-medium text-gray-900">
          No hay preguntas aún
        </h3>
        <p className="mt-1 text-sm text-gray-500">
          Comienza creando preguntas para tu examen usando el chat.
        </p>
        <div className="mt-4 p-3 bg-blue-50 rounded-md">
          <p className="text-sm text-blue-800 font-medium">
            💡 Ejemplos de prompts:
          </p>
          <ul className="mt-2 text-xs text-blue-700 space-y-1">
            <li>• &quot;Crea 3 preguntas sobre matemáticas&quot;</li>
            <li>• &quot;Preguntas verdadero/falso de historia&quot;</li>
            <li>• &quot;Examen de biología con 4 opciones&quot;</li>
          </ul>
        </div>
      </div>
    );
  }

  const stats = getQuestionStats();

  return (
    <div className={`bg-white rounded-lg border border-gray-200 ${className}`}>
      {/* Header */}
      <div className="px-4 py-3 border-b border-gray-200 bg-gray-50 rounded-t-lg">
        <div className="flex items-center justify-between">
          <div className="flex items-center space-x-3">
            <h3 className="text-lg font-medium text-gray-900">
              Preguntas del Examen ({questions.length})
            </h3>
            {isProcessing && (
              <div className="flex items-center space-x-2">
                <div className="w-4 h-4 border-2 border-blue-600 border-t-transparent rounded-full animate-spin"></div>
                <span className="text-sm text-blue-600">Procesando...</span>
              </div>
            )}
          </div>

          <div className="flex items-center space-x-2">
            {questions.length > 0 && (
              <>
                <button
                  onClick={() => setShowAnswers(!showAnswers)}
                  className={`px-3 py-1 text-xs font-medium rounded-md transition-colors ${
                    showAnswers
                      ? "bg-green-100 text-green-800 hover:bg-green-200"
                      : "bg-gray-100 text-gray-800 hover:bg-gray-200"
                  }`}
                >
                  {showAnswers ? "Ocultar" : "Mostrar"} Respuestas
                </button>

                <button
                  onClick={toggleAllQuestions}
                  className="px-3 py-1 text-xs font-medium bg-blue-100 text-blue-800 rounded-md hover:bg-blue-200 transition-colors"
                >
                  {expandedQuestions.size === questions.length
                    ? "Contraer"
                    : "Expandir"}{" "}
                  Todo
                </button>

                {onExport && (
                  <button
                    onClick={onExport}
                    className="px-3 py-1 text-xs font-medium bg-indigo-100 text-indigo-800 rounded-md hover:bg-indigo-200 transition-colors"
                  >
                    Exportar JSON
                  </button>
                )}

                {onClear && (
                  <button
                    onClick={onClear}
                    className="px-3 py-1 text-xs font-medium bg-red-100 text-red-800 rounded-md hover:bg-red-200 transition-colors"
                  >
                    Limpiar
                  </button>
                )}
              </>
            )}
          </div>
        </div>

        {/* Stats */}
        {questions.length > 0 && (
          <div className="mt-2 flex items-center space-x-4 text-sm text-gray-600">
            <span className="flex items-center space-x-1">
              <span className="w-2 h-2 bg-green-500 rounded-full"></span>
              <span>{stats.verdaderoFalso} V/F</span>
            </span>
            <span className="flex items-center space-x-1">
              <span className="w-2 h-2 bg-blue-500 rounded-full"></span>
              <span>{stats.opcionMultiple} Opción Múltiple</span>
            </span>
          </div>
        )}
      </div>

      {/* Questions List */}
      <div className="max-h-96 overflow-y-auto">
        {questions.map((question) => {
          const isExpanded = expandedQuestions.has(question.numeroPregunta);
          const correctOptionIndex = question.opciones.findIndex(
            (op) => op.esCorrecta,
          );

          return (
            <div
              key={question.numeroPregunta}
              className="border-b border-gray-100 last:border-b-0"
            >
              {/* Question Header */}
              <div
                className="px-4 py-3 cursor-pointer hover:bg-gray-50 transition-colors"
                onClick={() => toggleQuestion(question.numeroPregunta)}
              >
                <div className="flex items-start justify-between">
                  <div className="flex-1 min-w-0">
                    <div className="flex items-center space-x-2 mb-1">
                      <span className="font-medium text-gray-900">
                        Pregunta {question.numeroPregunta}
                      </span>
                      {getQuestionTypeIcon(question.numeroOpciones)}
                      {showAnswers && (
                        <span className="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                          Respuesta: {getOptionLetter(correctOptionIndex)}
                        </span>
                      )}
                    </div>
                    <p
                      className={`text-gray-700 ${isExpanded ? "" : "line-clamp-2"}`}
                    >
                      {question.pregunta}
                    </p>
                  </div>

                  <div className="ml-4 flex-shrink-0">
                    <svg
                      className={`w-5 h-5 text-gray-400 transition-transform ${isExpanded ? "rotate-180" : ""}`}
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        strokeLinecap="round"
                        strokeLinejoin="round"
                        strokeWidth={2}
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </div>
                </div>
              </div>

              {/* Question Details */}
              {isExpanded && (
                <div className="px-4 pb-4 bg-gray-50">
                  <div className="space-y-2">
                    {question.opciones.map((opcion, index) => (
                      <div
                        key={index}
                        className={`flex items-start space-x-3 p-2 rounded-md transition-colors ${
                          opcion.esCorrecta && showAnswers
                            ? "bg-green-100 border border-green-200"
                            : "bg-white border border-gray-200"
                        }`}
                      >
                        <span
                          className={`inline-flex items-center justify-center w-6 h-6 rounded-full text-sm font-medium ${
                            opcion.esCorrecta && showAnswers
                              ? "bg-green-600 text-white"
                              : "bg-gray-200 text-gray-700"
                          }`}
                        >
                          {getOptionLetter(index)}
                        </span>
                        <span className="flex-1 text-gray-700">
                          {opcion.texto}
                        </span>
                        {opcion.esCorrecta && showAnswers && (
                          <svg
                            className="w-5 h-5 text-green-600"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                          >
                            <path
                              fillRule="evenodd"
                              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                              clipRule="evenodd"
                            />
                          </svg>
                        )}
                      </div>
                    ))}
                  </div>

                  <div className="mt-3 pt-2 border-t border-gray-200">
                    <div className="flex items-center justify-between text-xs text-gray-500">
                      <span>
                        Creada: {question.createdAt ? new Date(question.createdAt).toLocaleString() : 'N/A'}
                      </span>
                      <span>{question.numeroOpciones} opciones</span>
                    </div>
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>

      {/* Footer */}
      {questions.length > 0 && (
        <div className="px-4 py-3 bg-gray-50 rounded-b-lg border-t border-gray-200">
          <div className="flex items-center justify-between text-sm text-gray-600">
            <span>
              Total: {questions.length} pregunta
              {questions.length !== 1 ? "s" : ""}
            </span>
            {isClient && (
              <span>Última actualización: {currentTime}</span>
            )}
          </div>
        </div>
      )}
    </div>
  );
}
</file>

