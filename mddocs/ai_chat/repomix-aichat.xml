<file path="lib/document-processor/extractors/PPTXExtractor.ts">
'use client';

import JSZip from 'jszip';

export interface DocumentExtractionResult {
  text: string;
  metadata: {
    slideCount?: number;
    fileSize?: number;
    wordCount?: number;
    characterCount?: number;
    hasImages?: boolean;
    hasCharts?: boolean;
  };
}

export class PPTXExtractor {
  static async extractText(file: File): Promise<DocumentExtractionResult> {
    try {
      console.log('🔍 Starting PPTX extraction for:', file.name);
      
      // Convert file to ArrayBuffer
      const arrayBuffer = await file.arrayBuffer();
      
      // Load the PPTX file as a ZIP
      const zip = await JSZip.loadAsync(arrayBuffer);
      
      // Extract text from slides
      const slideTexts = await this.extractSlideTexts(zip);
      
      // Combine all slide texts
      const fullText = slideTexts.join('\n\n');
      
      // Generate metadata
      const metadata = await this.generateMetadata(zip, fullText, file);
      
      console.log(`✅ PPTX extraction completed. Slides: ${slideTexts.length}, Text length: ${fullText.length} characters`);
      
      return {
        text: fullText.trim(),
        metadata
      };
      
    } catch (error) {
      console.error('❌ Error extracting PPTX:', error);
      throw new Error(`Failed to extract PPTX content: ${error instanceof Error ? error.message : 'Unknown error'}`);
    }
  }
  
  private static async extractSlideTexts(zip: JSZip): Promise<string[]> {
    const slideTexts: string[] = [];
    
    try {
      // Find all slide files (slide1.xml, slide2.xml, etc.)
      const slideFiles = Object.keys(zip.files).filter(fileName => 
        fileName.match(/ppt\/slides\/slide\d+\.xml$/)
      );
      
      // Sort slide files numerically
      slideFiles.sort((a, b) => {
        const aNum = parseInt(a.match(/slide(\d+)\.xml$/)?.[1] || '0');
        const bNum = parseInt(b.match(/slide(\d+)\.xml$/)?.[1] || '0');
        return aNum - bNum;
      });
      
      console.log(`📄 Found ${slideFiles.length} slides to process`);
      
      // Extract text from each slide
      for (let i = 0; i < slideFiles.length; i++) {
        const slideFile = slideFiles[i];
        const slideNumber = i + 1;
        
        try {
          const slideXml = await zip.file(slideFile)?.async('text');
          if (slideXml) {
            const slideText = this.extractTextFromSlideXml(slideXml, slideNumber);
            slideTexts.push(slideText);
          }
        } catch (error) {
          console.warn(`⚠️ Error extracting text from slide ${slideNumber}:`, error);
          slideTexts.push(`--- Slide ${slideNumber} ---\n[Error extrayendo contenido de esta diapositiva]`);
        }
      }
      
    } catch (error) {
      console.error('❌ Error finding slide files:', error);
      throw new Error('Could not find slide files in PPTX');
    }
    
    return slideTexts;
  }
  
  private static extractTextFromSlideXml(xmlContent: string, slideNumber: number): string {
    try {
      // Extract text from <a:t> tags (text runs)
      const textMatches = xmlContent.match(/<a:t[^>]*>(.*?)<\/a:t>/g) || [];
      
      const extractedTexts = textMatches.map(match => {
        // Remove the XML tags and decode HTML entities
        const text = match.replace(/<a:t[^>]*>|<\/a:t>/g, '');
        return this.decodeXmlEntities(text);
      });
      
      // Filter out empty texts and join with spaces
      const slideText = extractedTexts
        .filter(text => text.trim().length > 0)
        .join(' ');
      
      return `--- Slide ${slideNumber} ---\n${slideText}`;
      
    } catch (error) {
      console.warn(`⚠️ Error parsing XML for slide ${slideNumber}:`, error);
      return `--- Slide ${slideNumber} ---\n[Error parsing slide content]`;
    }
  }
  
  private static decodeXmlEntities(text: string): string {
    return text
      .replace(/&lt;/g, '<')
      .replace(/&gt;/g, '>')
      .replace(/&amp;/g, '&')
      .replace(/&quot;/g, '"')
      .replace(/&apos;/g, "'");
  }
  
  private static async generateMetadata(zip: JSZip, text: string, file: File): Promise<DocumentExtractionResult['metadata']> {
    try {
      // Count slides
      const slideFiles = Object.keys(zip.files).filter(fileName => 
        fileName.match(/ppt\/slides\/slide\d+\.xml$/)
      );
      
      // Count words and characters
      const words = text.split(/\s+/).filter(word => word.length > 0);
      const wordCount = words.length;
      const characterCount = text.replace(/\s/g, '').length;
      
      // Check for images and charts
      const hasImages = Object.keys(zip.files).some(fileName => 
        fileName.match(/ppt\/media\/image\d+\.(png|jpg|jpeg|gif|bmp)$/i)
      );
      
      const hasCharts = Object.keys(zip.files).some(fileName => 
        fileName.match(/ppt\/charts\/chart\d+\.xml$/)
      );
      
      return {
        slideCount: slideFiles.length,
        fileSize: file.size,
        wordCount,
        characterCount,
        hasImages,
        hasCharts
      };
      
    } catch (error) {
      console.warn('⚠️ Error generating PPTX metadata:', error);
      return {
        slideCount: 0,
        fileSize: file.size,
        wordCount: 0,
        characterCount: 0,
        hasImages: false,
        hasCharts: false
      };
    }
  }
  
  // Validate if file is a valid PPTX
  static validateFile(file: File): boolean {
    const validTypes = [
      'application/vnd.openxmlformats-officedocument.presentationml.presentation',
      'application/vnd.ms-powerpoint.presentation.macroEnabled.12',
      'application/vnd.ms-powerpoint'
    ];
    const validExtensions = ['.pptx', '.ppt'];
    
    const hasValidType = validTypes.includes(file.type);
    const hasValidExtension = validExtensions.some(ext => 
      file.name.toLowerCase().endsWith(ext)
    );
    
    return hasValidType || hasValidExtension;
  }
  
  // Get supported file extensions
  static getSupportedExtensions(): string[] {
    return ['.pptx', '.ppt'];
  }
  
  // Get supported MIME types
  static getSupportedMimeTypes(): string[] {
    return [
      'application/vnd.openxmlformats-officedocument.presentationml.presentation',
      'application/vnd.ms-powerpoint.presentation.macroEnabled.12',
      'application/vnd.ms-powerpoint'
    ];
  }
  
  // Clean extracted text (remove excessive whitespace, normalize line breaks)
  static cleanText(text: string): string {
    return text
      // Replace multiple consecutive whitespaces with single space
      .replace(/[ \t]+/g, ' ')
      // Replace multiple consecutive line breaks with double line break
      .replace(/\n{3,}/g, '\n\n')
      // Trim each line
      .split('\n')
      .map(line => line.trim())
      .join('\n')
      // Remove leading/trailing whitespace
      .trim();
  }
  
  // Extract slide notes if available
  static async extractSlideNotes(file: File): Promise<string[]> {
    try {
      const arrayBuffer = await file.arrayBuffer();
      const zip = await JSZip.loadAsync(arrayBuffer);
      
      const noteTexts: string[] = [];
      
      // Find all notes files
      const noteFiles = Object.keys(zip.files).filter(fileName => 
        fileName.match(/ppt\/notesSlides\/notesSlide\d+\.xml$/)
      );
      
      // Sort note files numerically
      noteFiles.sort((a, b) => {
        const aNum = parseInt(a.match(/notesSlide(\d+)\.xml$/)?.[1] || '0');
        const bNum = parseInt(b.match(/notesSlide(\d+)\.xml$/)?.[1] || '0');
        return aNum - bNum;
      });
      
      // Extract text from each note
      for (const noteFile of noteFiles) {
        try {
          const noteXml = await zip.file(noteFile)?.async('text');
          if (noteXml) {
            const noteText = this.extractTextFromSlideXml(noteXml, noteTexts.length + 1);
            noteTexts.push(noteText);
          }
        } catch (error) {
          console.warn(`⚠️ Error extracting note ${noteTexts.length + 1}:`, error);
          noteTexts.push(`--- Note ${noteTexts.length + 1} ---\n[Error extracting note content]`);
        }
      }
      
      return noteTexts;
      
    } catch (error) {
      console.error('❌ Error extracting slide notes:', error);
      return [];
    }
  }
}
