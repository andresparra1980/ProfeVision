import { NextRequest, NextResponse } from 'next/server';
import { createOpenAI } from '@ai-sdk/openai';
import { generateObject } from 'ai';
import { z } from 'zod';

export async function POST(request: NextRequest) {
  try {
    console.log('🔍 Starting topic summarization API call');
    
    const body = await request.json();
    const { prompt, options = {} } = body;

    if (!prompt) {
      return NextResponse.json(
        { error: 'Prompt is required' },
        { status: 400 }
      );
    }

    // Configure AI model and options
    const model = options.model || process.env.OPENAI_MODEL || 'google/gemini-2.5-flash-lite';
    const temperature = options.temperature || 0.3;
    const maxTokens = options.maxTokens || 4000;

    console.log(`🤖 Using model: ${model} with temperature: ${temperature}`);

    // Create OpenRouter client
    const openrouter = createOpenAI({
      apiKey: process.env.OPENROUTER_API_KEY,
      baseURL: 'https://openrouter.ai/api/v1',
    });

    // Define Zod schema for strict JSON enforcement
    const microTopicSchema = z.object({
      name: z.string(),
      description: z.string(),
      keyTerms: z.array(z.string()),
      concepts: z.array(z.string()),
    });

    const macroTopicSchema = z.object({
      name: z.string(),
      description: z.string(),
      importance: z.enum(['high', 'medium', 'low']),
      microTopics: z.array(microTopicSchema).min(0),
    });

    const summarySchema = z.object({
      generalOverview: z.string(),
      academicLevel: z.string(),
      macroTopics: z.array(macroTopicSchema).min(0),
    });

    // Use Vercel AI SDK to generate a schema-validated object
    const { object: parsedResponse } = await generateObject({
      model: openrouter(model),
      prompt,
      temperature,
      maxTokens,
      schema: summarySchema,
      // Encourage pure JSON
      schemaName: 'TopicSummary',
    });

    // Validate the response structure
    if (!parsedResponse.generalOverview || !parsedResponse.academicLevel || !Array.isArray(parsedResponse.macroTopics)) {
      console.error('❌ Invalid response structure:', parsedResponse);
      return NextResponse.json(
        { 
          error: 'Invalid response structure from AI',
          details: 'Missing required fields: generalOverview, academicLevel, or macroTopics'
        },
        { status: 500 }
      );
    }

    console.log(`✅ Topic summarization completed successfully. Found ${parsedResponse.macroTopics.length} macro-topics`);

    return NextResponse.json(parsedResponse);

  } catch (error) {
    console.error('❌ Error in topic summarization API:', error);
    
    // Handle specific error types
    if (error instanceof Error) {
      if (error.message.includes('API key')) {
        return NextResponse.json(
          { error: 'API key configuration error' },
          { status: 500 }
        );
      }
      
      if (error.message.includes('rate limit')) {
        return NextResponse.json(
          { error: 'Rate limit exceeded. Please try again later.' },
          { status: 429 }
        );
      }
      
      if (error.message.includes('timeout')) {
        return NextResponse.json(
          { error: 'Request timeout. The document might be too large.' },
          { status: 408 }
        );
      }
    }

    return NextResponse.json(
      { 
        error: 'Internal server error during topic summarization',
        details: error instanceof Error ? error.message : 'Unknown error'
      },
      { status: 500 }
    );
  }
}

// Handle unsupported methods
export async function GET() {
  return NextResponse.json(
    { error: 'Method not allowed. Use POST to summarize topics.' },
    { status: 405 }
  );
}

export async function PUT() {
  return NextResponse.json(
    { error: 'Method not allowed. Use POST to summarize topics.' },
    { status: 405 }
  );
}

export async function DELETE() {
  return NextResponse.json(
    { error: 'Method not allowed. Use POST to summarize topics.' },
    { status: 405 }
  );
}
