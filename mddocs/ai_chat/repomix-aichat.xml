'use client';

import React, { useState } from 'react';
import { ProcessingJob } from '../lib/examDatabase';
import { useJobStatistics } from '../lib/hooks/useBackgroundProcessing';

interface BackgroundProcessingStatusProps {
  jobs: ProcessingJob[];
  onRemoveJob?: (jobId: string) => void;
  onClearCompleted?: () => void;
  onRetryJob?: (jobId: string) => void;
  className?: string;
}

export function BackgroundProcessingStatus({
  jobs,
  onRemoveJob,
  onClearCompleted,
  onRetryJob,
  className = ''
}: BackgroundProcessingStatusProps) {
  const [isExpanded, setIsExpanded] = useState(false);
  const stats = useJobStatistics(jobs);

  // Don't render if no jobs
  if (jobs.length === 0) return null;

  const getStatusIcon = (status: ProcessingJob['status']) => {
    switch (status) {
      case 'queued':
        return '⏳';
      case 'extracting':
        return '📄';
      case 'summarizing':
        return '🧠';
      case 'completed':
        return '✅';
      case 'failed':
        return '❌';
      default:
        return '⚪';
    }
  };

  const getStatusColor = (status: ProcessingJob['status']) => {
    switch (status) {
      case 'queued':
        return 'text-yellow-600 bg-yellow-50 border-yellow-200';
      case 'extracting':
      case 'summarizing':
        return 'text-blue-600 bg-blue-50 border-blue-200';
      case 'completed':
        return 'text-green-600 bg-green-50 border-green-200';
      case 'failed':
        return 'text-red-600 bg-red-50 border-red-200';
      default:
        return 'text-gray-600 bg-gray-50 border-gray-200';
    }
  };

  const getProgressBarColor = (status: ProcessingJob['status']) => {
    switch (status) {
      case 'extracting':
      case 'summarizing':
        return 'bg-blue-500';
      case 'completed':
        return 'bg-green-500';
      case 'failed':
        return 'bg-red-500';
      default:
        return 'bg-gray-300';
    }
  };

  const formatDuration = (job: ProcessingJob): string => {
    if (job.status === 'completed' && job.startedAt && job.completedAt) {
      const duration = Math.round((job.completedAt.getTime() - job.startedAt.getTime()) / 1000);
      return `${duration}s`;
    }
    if (job.startedAt) {
      const duration = Math.round((Date.now() - job.startedAt.getTime()) / 1000);
      return `${duration}s`;
    }
    return '';
  };

  const formatFileSize = (bytes: number): string => {
    const mb = bytes / (1024 * 1024);
    if (mb >= 1) return `${mb.toFixed(1)}MB`;
    const kb = bytes / 1024;
    return `${kb.toFixed(0)}KB`;
  };

  return (
    <div className={`bg-white border border-gray-200 rounded-lg shadow-sm ${className}`}>
      {/* Header */}
      <div 
        className="p-3 cursor-pointer hover:bg-gray-50 transition-colors border-b border-gray-100"
        onClick={() => setIsExpanded(!isExpanded)}
      >
        <div className="flex items-center justify-between">
          <div className="flex items-center space-x-3">
            {/* Processing indicator */}
            <div className="relative">
              {stats.processing > 0 ? (
                <div className="w-6 h-6 text-blue-600 animate-spin">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" className="w-full h-full">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                  </svg>
                </div>
              ) : (
                <div className="w-6 h-6 text-gray-400">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" className="w-full h-full">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
              )}
            </div>

            <div>
              <div className="flex items-center space-x-2">
                <span className="font-medium text-gray-900">
                  Procesamiento en segundo plano
                </span>
                {stats.processing > 0 && (
                  <span className="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                    {stats.processing} procesando
                  </span>
                )}
              </div>
              
              <div className="flex items-center space-x-4 text-sm text-gray-500 mt-1">
                <span>{stats.total} trabajo{stats.total !== 1 ? 's' : ''}</span>
                {stats.completed > 0 && <span>✅ {stats.completed}</span>}
                {stats.failed > 0 && <span>❌ {stats.failed}</span>}
                {stats.queued > 0 && <span>⏳ {stats.queued}</span>}
                {stats.avgProcessingTime > 0 && (
                  <span>⏱️ {stats.avgProcessingTime}s promedio</span>
                )}
              </div>
            </div>
          </div>

          <div className="flex items-center space-x-2">
            {/* Clear completed button */}
            {stats.completed > 0 && (
              <button
                onClick={(e) => {
                  e.stopPropagation();
                  onClearCompleted?.();
                }}
                className="p-1 text-gray-400 hover:text-gray-600 transition-colors"
                title="Limpiar completados"
              >
                <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            )}

            {/* Expand/collapse arrow */}
            <div className={`transform transition-transform duration-200 ${isExpanded ? 'rotate-180' : ''}`}>
              <svg className="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>
        </div>
      </div>

      {/* Expanded job list */}
      {isExpanded && (
        <div className="p-3 space-y-3 max-h-80 overflow-y-auto">
          {jobs.map((job) => (
            <div
              key={job.id}
              className={`border rounded-lg p-3 ${getStatusColor(job.status)}`}
            >
              <div className="flex items-center justify-between mb-2">
                <div className="flex items-center space-x-2 flex-1 min-w-0">
                  <span className="text-lg">{getStatusIcon(job.status)}</span>
                  
                  <div className="flex-1 min-w-0">
                    <p className="text-sm font-medium truncate">
                      {job.fileName}
                    </p>
                    <div className="flex items-center space-x-2 text-xs text-gray-500">
                      <span>{formatFileSize(job.fileSize)}</span>
                      <span>•</span>
                      <span>{job.status}</span>
                      {formatDuration(job) && (
                        <>
                          <span>•</span>
                          <span>{formatDuration(job)}</span>
                        </>
                      )}
                    </div>
                  </div>
                </div>

                <div className="flex items-center space-x-1 ml-2">
                  {/* Retry button for failed jobs */}
                  {job.status === 'failed' && onRetryJob && (
                    <button
                      onClick={() => onRetryJob(job.id)}
                      className="p-1 text-red-600 hover:text-red-800 transition-colors"
                      title="Reintentar"
                    >
                      <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                      </svg>
                    </button>
                  )}

                  {/* Remove button for non-active jobs */}
                  {job.status !== 'extracting' && job.status !== 'summarizing' && onRemoveJob && (
                    <button
                      onClick={() => onRemoveJob(job.id)}
                      className="p-1 text-gray-400 hover:text-red-600 transition-colors"
                      title="Eliminar"
                    >
                      <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                      </svg>
                    </button>
                  )}
                </div>
              </div>

              {/* Progress bar */}
              {(job.status === 'extracting' || job.status === 'summarizing' || job.progress > 0) && (
                <div className="mb-2">
                  <div className="flex items-center justify-between text-xs text-gray-600 mb-1">
                    <span>{job.stage}</span>
                    <span>{job.progress}%</span>
                  </div>
                  <div className="w-full bg-gray-200 rounded-full h-1.5">
                    <div
                      className={`h-1.5 rounded-full transition-all duration-300 ${getProgressBarColor(job.status)}`}
                      style={{ width: `${job.progress}%` }}
                    />
                  </div>
                </div>
              )}

              {/* Error message */}
              {job.status === 'failed' && job.error && (
                <div className="text-xs text-red-600 bg-red-50 p-2 rounded border">
                  <strong>Error:</strong> {job.error}
                </div>
              )}

              {/* Success message */}
              {job.status === 'completed' && (
                <div className="text-xs text-green-700">
                  ✅ Documento procesado y agregado al contexto
                </div>
              )}
            </div>
          ))}

          {/* Statistics footer */}
          {jobs.length > 0 && (
            <div className="border-t border-gray-200 pt-3 mt-3">
              <div className="text-xs text-gray-500 space-y-1">
                <div className="flex justify-between">
                  <span>Tasa de éxito:</span>
                  <span className={stats.successRate >= 80 ? 'text-green-600' : stats.successRate >= 60 ? 'text-yellow-600' : 'text-red-600'}>
                    {stats.successRate}%
                  </span>
                </div>
                {stats.avgProcessingTime > 0 && (
                  <div className="flex justify-between">
                    <span>Tiempo promedio:</span>
                    <span>{stats.avgProcessingTime}s</span>
                  </div>
                )}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  );
}
</file>

<file path="components/DocumentContextBar.tsx">
'use client';

import React, { useState } from 'react';
import { TopicSummary } from '../lib/examDatabase';

export interface ProcessingFile {
  id: string;
  fileName: string;
  fileType: 'pdf' | 'doc' | 'docx' | 'ppt' | 'pptx';
  status: 'queued' | 'extracting' | 'summarizing' | 'completed' | 'failed';
  progress: number;
  error?: string;
  result?: TopicSummary;
}

interface DocumentContextBarProps {
  topicSummaries: TopicSummary[];
  processingFiles: ProcessingFile[];
  onRemoveDocument: (summaryId: string) => void;
  onRemoveProcessingFile: (fileId: string) => void;
  onViewDocumentDetails: (summary: TopicSummary) => void;
  className?: string;
}

export function DocumentContextBar({
  topicSummaries,
  processingFiles,
  onRemoveDocument,
  onRemoveProcessingFile,
  onViewDocumentDetails,
  className = '',
}: DocumentContextBarProps) {
  const [hoveredItem, setHoveredItem] = useState<string | null>(null);

  // Get file type icon and color
  const getFileIcon = (fileType: string) => {
    switch (fileType.toLowerCase()) {
      case 'pdf':
        return { icon: '📄', color: 'text-red-600 bg-red-50' };
      case 'doc':
      case 'docx':
        return { icon: '📝', color: 'text-blue-600 bg-blue-50' };
      case 'ppt':
      case 'pptx':
        return { icon: '📊', color: 'text-orange-600 bg-orange-50' };
      default:
        return { icon: '📄', color: 'text-gray-600 bg-gray-50' };
    }
  };

  // Get status text for processing files
  const getStatusText = (status: ProcessingFile['status']) => {
    switch (status) {
      case 'queued':
        return 'En cola...';
      case 'extracting':
        return 'Extrayendo...';
      case 'summarizing':
        return 'Analizando...';
      case 'completed':
        return 'Completado';
      case 'failed':
        return 'Error';
      default:
        return '';
    }
  };

  // Truncate filename
  const truncateFileName = (fileName: string, maxLength: number = 15) => {
    if (fileName.length <= maxLength) return fileName;
    const extension = fileName.split('.').pop();
    const name = fileName.substring(0, fileName.lastIndexOf('.'));
    const truncatedName = name.substring(0, maxLength - extension!.length - 4) + '...';
    return `${truncatedName}.${extension}`;
  };

  return (
    <div className={`bg-white border-b border-gray-200 p-4 ${className}`}>
      <div className="flex items-center gap-4 overflow-x-auto max-w-full py-2">
        <div className="flex items-center gap-2 text-sm text-gray-600 whitespace-nowrap">
          <span className="font-medium">Contexto:</span>
        </div>
        
        {/* Processing Files */}
        {processingFiles.map((file) => {
          const { icon, color } = getFileIcon(file.fileType);
          const isHovered = hoveredItem === `processing-${file.id}`;
          
          return (
            <div
              key={`processing-${file.id}`}
              className="flex flex-col items-center min-w-0 relative px-2 py-1"
              onMouseEnter={() => setHoveredItem(`processing-${file.id}`)}
              onMouseLeave={() => setHoveredItem(null)}
            >
              {/* File Icon with Processing State */}
              <div className={`relative w-16 h-16 rounded-lg flex items-center justify-center ${
                file.status === 'failed' ? 'bg-red-100 text-red-600' : 
                file.status === 'completed' ? color : 'bg-gray-100 text-gray-400'
              }`}>
                <span className="text-2xl">{icon}</span>
                
                {/* Progress Overlay */}
                {(file.status === 'extracting' || file.status === 'summarizing') && (
                  <div className="absolute inset-0 flex items-center justify-center bg-white bg-opacity-75 rounded-lg">
                    <div className="relative w-8 h-8">
                      <div className="absolute inset-0 border-2 border-gray-200 rounded-full"></div>
                      <div 
                        className="absolute inset-0 border-2 border-blue-600 rounded-full animate-spin"
                        style={{
                          clipPath: `polygon(0 0, ${file.progress}% 0, ${file.progress}% 100%, 0 100%)`
                        }}
                      ></div>
                    </div>
                  </div>
                )}
                
                {/* Remove Button */}
                {isHovered && (
                  <button
                    onClick={() => onRemoveProcessingFile(file.id)}
                    className="absolute -top-1 -right-1 w-6 h-6 bg-red-500 text-white rounded-full text-sm hover:bg-red-600 transition-colors flex items-center justify-center shadow-md z-10"
                    title="Eliminar archivo"
                  >
                    ×
                  </button>
                )}
              </div>
              
              {/* Status Text */}
              <div className="mt-2 text-center">
                <div className="text-xs text-gray-600 font-medium">
                  {getStatusText(file.status)}
                </div>
                {file.status !== 'queued' && file.status !== 'failed' && (
                  <div className="text-xs text-gray-500">
                    {file.progress}%
                  </div>
                )}
                {file.status === 'failed' && file.error && (
                  <div className="text-xs text-red-600 max-w-16 truncate" title={file.error}>
                    {file.error}
                  </div>
                )}
              </div>
            </div>
          );
        })}
        
        {/* Completed Documents */}
        {topicSummaries.map((summary) => {
          const fileType = summary.fileName.split('.').pop() || 'pdf';
          const { icon, color } = getFileIcon(fileType);
          const isHovered = hoveredItem === `completed-${summary.id}`;
          
          return (
            <div
              key={`completed-${summary.id}`}
              className="flex flex-col items-center min-w-0 relative cursor-pointer group px-2 py-1"
              onMouseEnter={() => setHoveredItem(`completed-${summary.id}`)}
              onMouseLeave={() => setHoveredItem(null)}
              onClick={() => onViewDocumentDetails(summary)}
            >
              {/* File Icon */}
              <div className={`w-16 h-16 rounded-lg flex items-center justify-center ${color} group-hover:shadow-md transition-shadow`}>
                <span className="text-2xl">{icon}</span>
                
                {/* Remove Button */}
                {isHovered && (
                  <button
                    onClick={(e) => {
                      e.stopPropagation();
                      onRemoveDocument(summary.id);
                    }}
                    className="absolute -top-1 -right-1 w-6 h-6 bg-red-500 text-white rounded-full text-sm hover:bg-red-600 transition-colors flex items-center justify-center shadow-md z-10"
                    title="Eliminar documento"
                  >
                    ×
                  </button>
                )}
              </div>
              
              {/* File Name */}
              <div className="mt-2 text-center max-w-20">
                <div className="text-xs text-gray-700 font-medium truncate" title={summary.fileName}>
                  {truncateFileName(summary.fileName)}
                </div>
                <div className="text-xs text-gray-500">
                  {summary.totalTopics} temas
                </div>
              </div>
            </div>
          );
        })}
        
        {/* Empty State */}
        {topicSummaries.length === 0 && processingFiles.length === 0 && (
          <div className="text-sm text-gray-500 italic py-4">
            No hay documentos de contexto. Usa el botón de attachment (📎) para subir archivos.
          </div>
        )}
      </div>
    </div>
  );
}
</file>

