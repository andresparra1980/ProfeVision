              <h4 className="text-sm font-medium text-gray-700 mb-3">
                Ejemplos por Categoría
              </h4>

              {suggestions.map((category, categoryIndex) => (
                <div key={categoryIndex} className="mb-4">
                  <div className="flex items-center space-x-2 mb-2">
                    <span className="text-sm">{category.icon}</span>
                    <h5 className="text-sm font-medium text-gray-600">
                      {category.category}
                    </h5>
                  </div>

                  <div className="grid gap-2">
                    {category.items.map((item, itemIndex) => (
                      <button
                        key={itemIndex}
                        onClick={() => handleSuggestionClick(item)}
                        disabled={disabled}
                        className={`p-2 text-left text-xs rounded-md border border-gray-200 transition-colors ${
                          disabled
                            ? "opacity-50 cursor-not-allowed"
                            : "hover:bg-gray-50 hover:border-gray-300 cursor-pointer"
                        }`}
                      >
                        {item}
                      </button>
                    ))}
                  </div>
                </div>
              ))}
            </div>

            {/* Tips Section */}
            <div className="border-t border-gray-200 pt-4">
              <h4 className="text-sm font-medium text-gray-700 mb-3">
                💡 Consejos
              </h4>
              <div className="space-y-2 text-xs text-gray-600">
                <div className="flex items-start space-x-2">
                  <span className="text-blue-500">•</span>
                  <span>Especifica el número de preguntas que quieres</span>
                </div>
                <div className="flex items-start space-x-2">
                  <span className="text-blue-500">•</span>
                  <span>
                    Indica el nivel de dificultad (básico, intermedio, avanzado)
                  </span>
                </div>
                <div className="flex items-start space-x-2">
                  <span className="text-blue-500">•</span>
                  <span>
                    Menciona el número de opciones que prefieres (2-4)
                  </span>
                </div>
                <div className="flex items-start space-x-2">
                  <span className="text-blue-500">•</span>
                  <span>Sé específico sobre el tema o subtema</span>
                </div>
              </div>
            </div>

            {/* Format Examples */}
            <div className="border-t border-gray-200 pt-4">
              <h4 className="text-sm font-medium text-gray-700 mb-3">
                📝 Formatos Recomendados
              </h4>
              <div className="space-y-2">
                <div className="p-2 bg-gray-50 rounded text-xs">
                  <strong>Ejemplo 1:</strong> &quot;Crea 5 preguntas de nivel
                  intermedio sobre la revolución francesa con 4 opciones cada
                  una&quot;
                </div>
                <div className="p-2 bg-gray-50 rounded text-xs">
                  <strong>Ejemplo 2:</strong> &quot;Genera preguntas
                  verdadero/falso básicas sobre el sistema digestivo&quot;
                </div>
                <div className="p-2 bg-gray-50 rounded text-xs">
                  <strong>Ejemplo 3:</strong> &quot;Haz un examen completo de 10
                  preguntas sobre programación en Python&quot;
                </div>
              </div>
            </div>
          </div>
        )}
      </div>

      {/* Footer */}
      <div className="px-4 py-2 bg-gray-50 border-t border-gray-200 rounded-b-lg">
