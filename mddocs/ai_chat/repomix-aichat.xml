import { useState } from "react";

interface QuickSuggestionsProps {
  onSuggestionClick: (suggestion: string) => void;
  disabled?: boolean;
  className?: string;
}

export default function QuickSuggestions({
  onSuggestionClick,
  disabled = false,
  className = "",
}: QuickSuggestionsProps) {
  const [isExpanded, setIsExpanded] = useState(false);

  const suggestions = [
    {
      category: "Básico",
      icon: "📚",
      items: [
        "Crea 3 preguntas de opción múltiple sobre la fotosíntesis",
        "Genera preguntas verdadero/falso sobre la Segunda Guerra Mundial",
        "Haz 5 preguntas básicas de matemáticas sobre fracciones",
