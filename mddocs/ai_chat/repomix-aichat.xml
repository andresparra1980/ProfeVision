import { NextRequest, NextResponse } from "next/server";
import { extractText, getDocumentProxy } from "unpdf";

export interface DocumentExtractionResult {
  text: string;
  metadata: {
    pageCount?: number;
    title?: string;
    author?: string;
    subject?: string;
    keywords?: string;
    creator?: string;
    producer?: string;
    creationDate?: Date;
    modificationDate?: Date;
    fileSize?: number;
  };
}

// Función para extraer texto usando unpdf
async function extractTextFromPDF(
  pdfBuffer: Buffer
): Promise<DocumentExtractionResult> {
  try {
    console.log("🚀 Extrayendo texto del PDF con unpdf...");
    const startTime = performance.now();

    // Cargar el PDF usando unpdf
    const pdf = await getDocumentProxy(new Uint8Array(pdfBuffer));

    // Extraer texto de todas las páginas
    const { totalPages, text } = await extractText(pdf, { mergePages: true });

    const endTime = performance.now();
    console.log(
      `⚡ Extracción completada en ${(endTime - startTime).toFixed(2)}ms`
    );
    console.log(`📄 PDF procesado: ${totalPages} páginas`);

    const result: DocumentExtractionResult = {
      text: text,
      metadata: {
        pageCount: totalPages,
        fileSize: pdfBuffer.length,
      },
    };

    console.log(`✅ Texto extraído: ${result.text.length} caracteres`);
    return result;
  } catch (error) {
    console.error("❌ Error extrayendo texto del PDF:", error);
    throw error;
  }
}

export async function POST(request: NextRequest) {
  try {
    console.log("🔍 Iniciando extracción de PDF");

    const formData = await request.formData();
    const file = formData.get("file") as File;

    if (!file) {
      return NextResponse.json({ error: "No file provided" }, { status: 400 });
    }

    // Validate file type
    if (
      !file.type.includes("pdf") &&
      !file.name.toLowerCase().endsWith(".pdf")
    ) {
      return NextResponse.json(
        { error: "Invalid file type. Only PDF files are supported." },
        { status: 400 }
      );
    }

    // Validar tamaño (50MB max)
    if (file.size > 50 * 1024 * 1024) {
      return NextResponse.json(
        { error: "File too large. Maximum 50MB allowed." },
        { status: 400 }
      );
    }

    console.log(`📄 Processing PDF: ${file.name} (${file.size} bytes)`);

    // Convert file to buffer
    const arrayBuffer = await file.arrayBuffer();
    const buffer = Buffer.from(arrayBuffer);

    // Extract text from PDF
    const result = await extractTextFromPDF(buffer);

    // Verificar si se extrajo texto útil
    if (result.text.trim().length < 10) {
      return NextResponse.json({
        ...result,
        warning:
          "Very little text extracted. PDF might be image-based or encrypted.",
      });
    }

    return NextResponse.json(result);
  } catch (error) {
    console.error("❌ Error extracting PDF:", error);

    const errorMessage =
      error instanceof Error ? error.message : "Unknown error";

    return NextResponse.json(
      {
        error: "Failed to extract PDF content",
        details: errorMessage,
      },
      { status: 500 }
    );
  }
}
