"use client";

import { useState, useEffect, useCallback, useRef } from "react";
import { useChat, Message } from "@ai-sdk/react";
import {
  ExamService,
  ExamConversation,
  ExamQuestion,
  ConversationMessage,
  TopicSummary,
  initializeExamDatabase,
} from "./examDatabase";
import { ExamPrompts } from "./examPrompts";

// Helper function to transform ConversationMessages to AI SDK Messages
function transformToAIMessages(
  conversationMessages: ConversationMessage[]
): Message[] {
  return conversationMessages.map((msg, index) => ({
    id: `msg-${index}-${msg.timestamp?.getTime() || index}`,
    role: msg.role,
    content: msg.content,
    createdAt: msg.timestamp || new Date(),
  }));
}

interface UseExamChatOptions {
  api?: string;
  initialConversationId?: number;
  autoSave?: boolean;
  autoSaveDelay?: number;
  enableDocumentContext?: boolean;
}

interface UseExamChatReturn {
  // Chat functionality
  messages: Message[];
  input: string;
  handleInputChange: (e: React.ChangeEvent<HTMLInputElement>) => void;
  handleSubmit: (e: React.FormEvent<HTMLFormElement>) => void;
  isLoading: boolean;

  // Exam conversation management
  currentConversationId: number | null;
  conversations: ExamConversation[];
  extractedQuestions: ExamQuestion[];

  // Document context
  topicSummaries: TopicSummary[];
  hasDocumentContext: boolean;
  documentContextSummary: string;

  // Actions
  createNewExamConversation: () => Promise<void>;
  loadExamConversation: (id: number) => Promise<void>;
  saveCurrentConversation: () => Promise<void>;
  deleteExamConversation: (id: number) => Promise<void>;
  updateConversationTitle: (id: number, title: string) => Promise<void>;

  // Document context actions
  loadConversationTopicSummaries: (conversationId: number) => Promise<void>;
  addTopicSummaryToConversation: (summary: TopicSummary) => Promise<void>;
  removeTopicSummaryFromConversation: (summaryId: string) => Promise<void>;

  // Exam specific actions
  exportQuestions: () => Promise<string>;
  generateExamSummary: () => {
    totalPreguntas: number;
    tiposPreguntas: {
      verdaderoFalso: number;
      opcionMultiple: number;
    };
    distribucionOpciones: Record<number, number>;
  };
  validateLastResponse: () => { isValid: boolean; error?: string };

  // Loading states
  isLoadingConversations: boolean;
  isSaving: boolean;
  isProcessingQuestions: boolean;
}

export function useExamChat(
  options: UseExamChatOptions = {}
): UseExamChatReturn {
  const {
    api = "/api/chat",
    autoSave = true,
    autoSaveDelay = 1500,
    enableDocumentContext = true,
  } = options;

  // State management
  const [currentConversationId, setCurrentConversationId] = useState<
    number | null
  >(null);
  const [conversations, setConversations] = useState<ExamConversation[]>([]);
  const [extractedQuestions, setExtractedQuestions] = useState<ExamQuestion[]>(
    []
  );
  const [isLoadingConversations, setIsLoadingConversations] = useState(true);
  const [isSaving, setIsSaving] = useState(false);
  const [isProcessingQuestions, setIsProcessingQuestions] = useState(false);

  const [lastSavedMessages, setLastSavedMessages] = useState<Message[]>([]);
  const [isLoadingConversation, setIsLoadingConversation] = useState(false);

  // Document context state
  const [topicSummaries, setTopicSummaries] = useState<TopicSummary[]>([]);
  const [hasDocumentContext, setHasDocumentContext] = useState(false);
  const [documentContextSummary, setDocumentContextSummary] = useState("");

  // Use refs to avoid circular dependencies
  const currentConversationIdRef = useRef<number | null>(null);
  const messagesRef = useRef<Message[]>([]);
  const extractedQuestionsRef = useRef<ExamQuestion[]>([]);
  const topicSummariesRef = useRef<TopicSummary[]>([]);

  // Update refs when state changes
  useEffect(() => {
    currentConversationIdRef.current = currentConversationId;
  }, [currentConversationId]);

  useEffect(() => {
    extractedQuestionsRef.current = extractedQuestions;
  }, [extractedQuestions]);

  useEffect(() => {
    topicSummariesRef.current = topicSummaries;
    setHasDocumentContext(topicSummaries.length > 0);

    // Generate document context summary
    if (topicSummaries.length > 0) {
      const totalMacroTopics = topicSummaries.reduce(
        (sum, summary) => sum + summary.totalTopics,
        0
      );
      const filesList = topicSummaries.map((s) => s.fileName).join(", ");
      setDocumentContextSummary(
        `${topicSummaries.length} documento(s): ${filesList} (${totalMacroTopics} temas)`
      );
    } else {
      setDocumentContextSummary("");
    }
  }, [topicSummaries]);

  // Load all conversations helper
  const loadAllConversations = useCallback(async () => {
    try {
      const allConversations = await ExamService.getAllExamConversations();
      setConversations(allConversations);
    } catch (error) {
      console.error("Failed to load conversations:", error);
    }
  }, []);

  // Save current conversation
  const saveCurrentConversation = useCallback(async () => {
    if (!currentConversationIdRef.current) return;

    try {
      setIsSaving(true);
      const currentMessages = messagesRef.current;
      const currentQuestions = extractedQuestionsRef.current;

      // Transform AI SDK Messages to ConversationMessages
      const transformedMessages: ConversationMessage[] = currentMessages
        .filter((msg) => msg.role !== "data") // Filter out data messages
        .map((msg) => ({
          role: msg.role as "system" | "user" | "assistant",
          content: msg.content,
          timestamp: new Date(),
        }));

      await ExamService.updateExamConversation(
        currentConversationIdRef.current,
        transformedMessages,
        currentQuestions
      );
      setLastSavedMessages([...currentMessages]);

      // Update conversation title if it's still default and we have questions
      const conversation = await ExamService.getExamConversation(
        currentConversationIdRef.current
      );
      if (
        conversation &&
        conversation.titulo === "Nueva Conversación de Examen" &&
        currentQuestions.length > 0
      ) {
        await ExamService.updateExamConversation(
          currentConversationIdRef.current,
          transformedMessages
        );
      }

      // Refresh conversations list
      await loadAllConversations();
    } catch (error) {
      console.error("Failed to save exam conversation:", error);
    } finally {
      setIsSaving(false);
    }
  }, [loadAllConversations]);

  // Use ref to store timeout to avoid dependency issues
  const autoSaveTimeoutRef = useRef<NodeJS.Timeout | null>(null);

  // Schedule auto-save with debouncing - using refs for stability
  const scheduleAutoSave = useCallback(() => {
    if (autoSaveTimeoutRef.current) {
      clearTimeout(autoSaveTimeoutRef.current);
    }

    const timeout = setTimeout(async () => {
      // Use refs to get current values to avoid stale closures
      const currentMessages = messagesRef.current;
      const currentQuestions = extractedQuestionsRef.current;
      const conversationId = currentConversationIdRef.current;

      if (conversationId && currentMessages.length > 0) {
        try {
          const transformedMessages: ConversationMessage[] = currentMessages
            .filter((msg) => msg.role !== "data")
            .map((msg) => ({
              role: msg.role as "system" | "user" | "assistant",
              content: msg.content,
              timestamp: new Date(),
            }));

          await ExamService.updateExamConversation(
            conversationId,
            transformedMessages,
            currentQuestions
          );

          // Reload conversations to update sidebar with latest question count
          await loadAllConversations();
          console.log("✅ Auto-saved and updated sidebar with question count");
        } catch (error) {
          console.error("❌ Auto-save failed:", error);
        }
      }
    }, autoSaveDelay);

    autoSaveTimeoutRef.current = timeout;
  }, [autoSaveDelay, loadAllConversations]);

  // Auto-update conversations when questions change
  useEffect(() => {
    if (
      autoSave &&
      currentConversationIdRef.current &&
      extractedQuestions.length > 0
    ) {
      scheduleAutoSave();
    }
  }, [extractedQuestions, autoSave, scheduleAutoSave]);

  // Build context for LLM (include existing questions if any)
  // Generate document context for AI
  const generateDocumentContext = useCallback((): string => {
    if (!enableDocumentContext || topicSummariesRef.current.length === 0) {
      return "";
    }

    const summaries = topicSummariesRef.current;
    const contextParts = summaries.map((summary) => {
      const macroTopicsText = summary.macroTopics
        .map((macro) => {
          const microTopicsText = macro.microTopics
            .map(
              (micro) =>
                `    - ${micro.name}: ${
                  micro.description
                } (Términos: ${micro.keyTerms.join(", ")})`
            )
            .join("\n");

          return `
  • ${macro.name} (Importancia: ${macro.importance})
    ${macro.description}
${microTopicsText}`;
        })
        .join("\n");

      return `
=== CONTENIDO DE: ${summary.fileName} ===
Nivel académico: ${summary.academicLevel}
Resumen general: ${summary.generalOverview}

TEMAS PRINCIPALES:
${macroTopicsText}

---
`;
    });

    return `
CONTEXTO DOCUMENTAL DISPONIBLE:

${contextParts.join("\n")}

INSTRUCCIONES DE CONTEXTO: Utiliza este contexto documental para generar preguntas de examen específicas y relevantes al contenido real. Las preguntas deben estar alineadas con los temas, conceptos y términos clave identificados en los documentos pero NO debes referirte a los documentos en tus preguntas y respuestas.

`;
  }, [enableDocumentContext]);

  // Simplified message processing - always replace complete exam
  const processAIMessage = useCallback(async (message: Message) => {
    if (message.role !== "assistant") return;

    try {
      setIsProcessingQuestions(true);

      console.log("🔄 Processing AI response...");

      // Try to extract questions from the AI response
      const questions = ExamService.parseAIResponse(message.content);

      if (questions.length > 0) {
        console.log("✅ Questions extracted:", questions.length);

        // ALWAYS replace the entire exam with proper numbering
        const numberedQuestions = questions.map((q, index) => ({
          ...q,
          numeroPregunta: index + 1, // Always sequential: 1, 2, 3, 4...
          createdAt: new Date(),
          updatedAt: new Date(),
        }));

        setExtractedQuestions(numberedQuestions);

        console.log(
          "✅ Exam replaced with",
          numberedQuestions.length,
          "questions"
        );
      } else {
        console.log("ℹ️ No questions found in AI response");
      }
    } catch (error) {
      console.error("❌ Error processing AI message:", error);
    } finally {
      setIsProcessingQuestions(false);
    }
  }, []);

  // Enhanced chat options with contextual prompts
  const chatOptions = {
    api,
    initialMessages: [
      {
        id: "system-prompt",
        role: "system" as const,
        content: ExamPrompts.getSystemPrompt(),
      },
    ],
    onFinish: async (message: Message) => {
      await processAIMessage(message);
      if (autoSave && currentConversationIdRef.current) {
        scheduleAutoSave();
      }
    },
  };

  const {
    messages,
    input,
    handleInputChange,
    handleSubmit: originalHandleSubmit,
    isLoading,
    setMessages,
  } = useChat(chatOptions);

  // Override handleSubmit to add context as separate system message
  const handleSubmit = useCallback(
    (e: React.FormEvent<HTMLFormElement>) => {
      e.preventDefault();

      if (!input.trim()) return;

      const currentMessages = messagesRef.current;

      // Generate document context if available
      const documentContext = generateDocumentContext();

      // Build exam context for existing questions
      let examContextMessage = "";
      if (extractedQuestions.length > 0) {
        const examContext = {
          preguntas: extractedQuestions.map((q, index) => ({
            numero: index + 1,
            pregunta: q.pregunta,
            opciones: q.opciones.map((opt, optIndex) => ({
              letra: String.fromCharCode(65 + optIndex),
              texto: opt.texto,
              es_correcta: opt.esCorrecta,
            })),
          })),
        };

        examContextMessage = `EXAMEN ACTUAL:
${JSON.stringify(examContext, null, 2)}

IMPORTANTE:
- SIEMPRE devuelve el examen COMPLETO actualizado (todas las preguntas, editadas + no editadas)
- Numera las preguntas secuencialmente: pregunta1, pregunta2, pregunta3...
- Si editas una pregunta, incluye todas las demás sin cambios
- Si agregas preguntas, inclúyelas al final del examen existente
- Si reordenas, devuelve todas en el nuevo orden
- Mantén preguntas no mencionadas exactamente igual
- Usa el contexto documental para hacer preguntas más específicas y relevantes sin referirte a los documentos`;
      }

      // Create context message if we have document or exam context
      const hasContext = documentContext || examContextMessage;

      if (hasContext) {
        const contextMessage = `${documentContext}${examContextMessage}`.trim();

        // Log context being sent
        console.log("📤 Client - Sending context to LLM:", {
          hasDocumentContext: !!documentContext,
          hasExamContext: !!examContextMessage,
          documentContextLength: documentContext?.length || 0,
          examContextLength: examContextMessage?.length || 0,
          totalContextLength: contextMessage.length,
          contextPreview: contextMessage.substring(0, 200) + "...",
        });

        // Add context as a system message
        const updatedMessages = [
          ...currentMessages,
          {
            id: `context-${currentMessages.length}`,
            role: "system" as const,
            content: contextMessage,
            createdAt: new Date(),
          },
        ];

        setMessages(updatedMessages);
        messagesRef.current = updatedMessages;
      } else {
        console.log("ℹ️ Client - No context to send to LLM");
      }

      // Submit with original user input
      originalHandleSubmit(e);
    },
    [
      input,
      generateDocumentContext,
      extractedQuestions,
      originalHandleSubmit,
      setMessages,
    ]
  );

  // Update messages ref when messages change
  useEffect(() => {
    messagesRef.current = messages;
  }, [messages]);

  // Initialize database and load conversations
  useEffect(() => {
    const init = async () => {
      try {
        await initializeExamDatabase();
        const allConversations = await ExamService.getAllExamConversations();
        setConversations(allConversations);

        if (options.initialConversationId) {
          const conversation = await ExamService.getExamConversation(
            options.initialConversationId
          );
          if (conversation) {
            setCurrentConversationId(options.initialConversationId);
            const aiMessages = transformToAIMessages(conversation.messages);
            setMessages(aiMessages);
            setLastSavedMessages(aiMessages);

            // Load topic summaries for this conversation
            if (enableDocumentContext && options.initialConversationId) {
              setTopicSummaries(conversation.topicSummaries || []);
            }

            // Extract questions from existing messages
            const allQuestions: ExamQuestion[] = [];
            for (const msg of conversation.messages) {
              if (msg.role === "assistant") {
                try {
                  const questions = ExamService.parseAIResponse(msg.content);
                  if (questions.length > 0) {
                    // Use the last complete set of questions found
                    const numberedQuestions = questions.map((q, index) => ({
                      ...q,
                      numeroPregunta: index + 1,
                    }));
                    allQuestions.splice(
                      0,
                      allQuestions.length,
                      ...numberedQuestions
                    );
                  }
                } catch {
                  // Ignore parsing errors for old messages
                }
              }
            }
            setExtractedQuestions(allQuestions);
          }
        }
      } catch (error) {
        console.error("Failed to initialize exam chat:", error);
      } finally {
        setIsLoadingConversations(false);
      }
    };

    init();
  }, [options.initialConversationId, setMessages, enableDocumentContext]);

  // Auto-save when messages change (but not during conversation loading)
  useEffect(() => {
    if (
      autoSave &&
      currentConversationId &&
      messages.length > 0 &&
      !isLoadingConversation
    ) {
      // Only schedule auto-save if messages have actually changed
      const currentMessagesJson = JSON.stringify(messages);
      const lastSavedMessagesJson = JSON.stringify(lastSavedMessages);

      if (currentMessagesJson !== lastSavedMessagesJson) {
        scheduleAutoSave();
      }
    }
  }, [
    messages,
    currentConversationId,
    autoSave,
    lastSavedMessages,
    isLoadingConversation,
    scheduleAutoSave,
  ]);

  // Create new exam conversation
  const createNewExamConversation = useCallback(async () => {
    try {
      setIsSaving(true);
      const title =
        extractedQuestions.length > 0
          ? ExamUtils.generateExamTitle(extractedQuestions)
          : "Nueva Conversación de Examen";

      const newId = await ExamService.createExamConversation(title);
      setCurrentConversationId(newId);
      setMessages([
        {
          id: "system-prompt",
          role: "system",
          content: ExamPrompts.getSystemPrompt(),
        },
      ]);
      setExtractedQuestions([]);
      setLastSavedMessages([]);
      await loadAllConversations();
    } catch (error) {
      console.error("Failed to create new exam conversation:", error);
    } finally {
      setIsSaving(false);
    }
  }, [extractedQuestions, setMessages, loadAllConversations]);

  // Load topic summaries for a conversation
  const loadConversationTopicSummaries = useCallback(
    async (conversationId: number) => {
      try {
        console.log(
          "📚 Loading topic summaries for conversation:",
          conversationId
        );
        const summaries = await ExamService.getConversationSummaries(
          conversationId
        );
        setTopicSummaries(summaries);
        console.log(`✅ Loaded ${summaries.length} topic summaries`);
      } catch (error) {
        console.error("❌ Error loading topic summaries:", error);
        setTopicSummaries([]);
      }
    },
    []
  );

  // Add topic summary to current conversation
  const addTopicSummaryToConversation = useCallback(
    async (summary: TopicSummary) => {
      if (!currentConversationIdRef.current) {
        console.warn("No current conversation to add topic summary to");
        return;
      }

      try {
        console.log(
          "📚 Adding topic summary to conversation:",
          summary.fileName
        );
        await ExamService.addTopicSummary(
          currentConversationIdRef.current,
          summary
        );
        setTopicSummaries((prev) => [...prev, summary]);
        console.log("✅ Topic summary added successfully");
      } catch (error) {
        console.error("❌ Error adding topic summary:", error);
        throw error;
      }
    },
    []
  );

  // Remove topic summary from current conversation
  const removeTopicSummaryFromConversation = useCallback(
    async (summaryId: string) => {
      if (!currentConversationIdRef.current) {
        console.warn("No current conversation to remove topic summary from");
        return;
      }

      try {
        console.log("🗑️ Removing topic summary:", summaryId);
        await ExamService.removeTopicSummary(
          currentConversationIdRef.current,
          summaryId
        );
        setTopicSummaries((prev) => prev.filter((s) => s.id !== summaryId));
        console.log("✅ Topic summary removed successfully");
      } catch (error) {
        console.error("❌ Error removing topic summary:", error);
        throw error;
      }
    },
    []
  );

  // Load specific exam conversation
  const loadExamConversation = useCallback(
    async (id: number) => {
      try {
        setIsLoadingConversation(true);
        const conversation = await ExamService.getExamConversation(id);

        if (!conversation) {
          throw new Error("Conversation not found");
        }

        setCurrentConversationId(id);
        const aiMessages = transformToAIMessages(conversation.messages);
        setMessages(aiMessages);
        setLastSavedMessages(aiMessages);

        // Load topic summaries for this conversation
        if (enableDocumentContext) {
          await loadConversationTopicSummaries(id);
        }

        // Extract questions from the loaded conversation
        const allQuestions: ExamQuestion[] = [];
        for (const msg of conversation.messages) {
          if (msg.role === "assistant") {
            try {
              const questions = ExamService.parseAIResponse(msg.content);
              if (questions.length > 0) {
                // Use the last complete set of questions found
                const numberedQuestions = questions.map((q, index) => ({
                  ...q,
                  numeroPregunta: index + 1,
                }));
                allQuestions.splice(
                  0,
                  allQuestions.length,
                  ...numberedQuestions
                );
              }
            } catch {
              // Ignore parsing errors for old messages
            }
          }
        }
        setExtractedQuestions(allQuestions);

        console.log("Exam conversation loaded successfully");
      } catch (error) {
        console.error("Failed to load exam conversation:", error);
        throw error;
      } finally {
        setIsLoadingConversation(false);
      }
    },
    [setMessages, enableDocumentContext, loadConversationTopicSummaries]
  );

  // Delete exam conversation
  const deleteExamConversation = useCallback(
    async (id: number) => {
      try {
        await ExamService.deleteExamConversation(id);

        if (currentConversationId === id) {
          setCurrentConversationId(null);
          setMessages([
            {
              id: "system-prompt",
              role: "system",
              content: ExamPrompts.getSystemPrompt(),
            },
          ]);
          setExtractedQuestions([]);
          setLastSavedMessages([]);
        }

        await loadAllConversations();
      } catch (error) {
        console.error("Failed to delete exam conversation:", error);
      }
    },
    [currentConversationId, setMessages, loadAllConversations]
  );

  // Update conversation title
  const updateConversationTitle = useCallback(
    async (id: number) => {
      try {
        // Get current conversation and update it
        const conversation = await ExamService.getExamConversation(id);
        if (conversation) {
          await ExamService.updateExamConversation(id, conversation.messages);
        }
        await loadAllConversations();
      } catch (error) {
        console.error("Failed to update conversation title:", error);
      }
    },
    [loadAllConversations]
  );

  // Export questions as JSON
  const exportQuestions = useCallback(async (): Promise<string> => {
    const examData = {
      titulo: currentConversationId
        ? conversations.find((c) => c.id === currentConversationId)?.titulo ||
          "Examen Sin Título"
        : "Examen Sin Título",
      totalPreguntas: extractedQuestions.length,
      fechaCreacion: new Date().toISOString(),
      preguntas: extractedQuestions.map((q) => ({
        numero: q.numeroPregunta,
        pregunta: q.pregunta,
        opciones: q.opciones.map((op) => op.texto),
        respuestaCorrecta: q.opciones.findIndex((op) => op.esCorrecta) + 1,
      })),
    };

    return JSON.stringify(examData, null, 2);
  }, [currentConversationId, conversations, extractedQuestions]);

  // Generate exam summary
  const generateExamSummary = useCallback(() => {
    return {
      totalPreguntas: extractedQuestions.length,
      tiposPreguntas: {
        verdaderoFalso: extractedQuestions.filter((q) => q.numeroOpciones === 2)
          .length,
        opcionMultiple: extractedQuestions.filter((q) => q.numeroOpciones > 2)
          .length,
      },
      distribucionOpciones: extractedQuestions.reduce((acc, q) => {
        acc[q.numeroOpciones] = (acc[q.numeroOpciones] || 0) + 1;
        return acc;
      }, {} as Record<number, number>),
    };
  }, [extractedQuestions]);

  // Validate last AI response
  const validateLastResponse = useCallback(() => {
    const lastMessage = messages[messages.length - 1];
    if (!lastMessage || lastMessage.role !== "assistant") {
      return {
        isValid: false,
        error: "No hay respuesta del asistente para validar",
      };
    }

    return ExamUtils.validateAIResponse(lastMessage.content);
  }, [messages]);

  // Cleanup timeout on unmount
  // Cleanup auto-save timeout on unmount
  useEffect(() => {
    return () => {
      if (autoSaveTimeoutRef.current) {
        clearTimeout(autoSaveTimeoutRef.current);
      }
    };
  }, []);

  return {
    // Chat functionality
    messages,
    input,
    handleInputChange,
    handleSubmit,
    isLoading,

    // Exam conversation management
    currentConversationId,
    conversations,
    extractedQuestions,

    // Document context
    topicSummaries,
    hasDocumentContext,
    documentContextSummary,

    // Actions
    createNewExamConversation,
    loadExamConversation,
    saveCurrentConversation,
    deleteExamConversation,
    updateConversationTitle,

    // Document context actions
    loadConversationTopicSummaries,
    addTopicSummaryToConversation,
    removeTopicSummaryFromConversation,

    // Exam specific actions
    exportQuestions,
    generateExamSummary,
    validateLastResponse,

    // Loading states
    isLoadingConversations,
    isSaving,
    isProcessingQuestions,
  };
}

// Utility functions for exam management
class ExamUtils {
  // Generate exam title from content
  static generateExamTitle(
    questions: ExamQuestion[],
    fallback: string = "Nuevo Examen"
  ): string {
    if (!questions || questions.length === 0) {
      return fallback;
    }

    // Try to extract topic from first question
    const firstQuestion = questions[0].pregunta.toLowerCase();

    // Common topics mapping
    const topicMappings = {
      matemática: "Matemáticas",
      historia: "Historia",
      biología: "Biología",
      física: "Física",
      química: "Química",
      geografía: "Geografía",
      literatura: "Literatura",
      inglés: "Inglés",
      programación: "Programación",
      javascript: "JavaScript",
      python: "Python",
    };

    for (const [key, value] of Object.entries(topicMappings)) {
      if (firstQuestion.includes(key)) {
        return `Examen de ${value}`;
      }
    }

    // Fallback to question count
    return `Examen (${questions.length} pregunta${
      questions.length > 1 ? "s" : ""
    })`;
  }

  // Validate JSON response from AI
  static validateAIResponse(response: string): {
    isValid: boolean;
    error?: string;
  } {
    try {
      const jsonMatch = response.match(/\{[\s\S]*\}/);
      if (!jsonMatch) {
        return {
          isValid: false,
          error: "No se encontró JSON válido en la respuesta",
        };
      }

      const parsed = JSON.parse(jsonMatch[0]);

      // Validate structure
      if (parsed.pregunta && parsed.opciones) {
        // Single question format
        return this.validateSingleQuestion(parsed);
      } else {
        // Multiple questions format
        return this.validateMultipleQuestions(parsed);
      }
    } catch (error) {
      return { isValid: false, error: `Error de JSON: ${error}` };
    }
  }

  private static validateSingleQuestion(question: Partial<ExamQuestion>): {
    isValid: boolean;
    error?: string;
  } {
    if (!question.pregunta || typeof question.pregunta !== "string") {
      return {
        isValid: false,
        error: 'Falta el campo "pregunta" o no es un string',
      };
    }

    if (!Array.isArray(question.opciones) || question.opciones.length < 2) {
      return {
        isValid: false,
        error: "Las opciones deben ser un array con al menos 2 elementos",
      };
    }

    const correctCount =
      question.opciones?.filter((op) => op.esCorrecta === true).length || 0;
    if (correctCount !== 1) {
      return {
        isValid: false,
        error: "Debe haber exactamente una opción correcta",
      };
    }

    return { isValid: true };
  }

  private static validateMultipleQuestions(
    questions: Record<string, ExamQuestion>
  ): {
    isValid: boolean;
    error?: string;
  } {
    const questionKeys = Object.keys(questions).filter((key) =>
      key.startsWith("pregunta")
    );

    if (questionKeys.length === 0) {
      return {
        isValid: false,
        error: "No se encontraron preguntas en el formato esperado",
      };
    }

    for (const key of questionKeys) {
      const validation = this.validateSingleQuestion(questions[key]);
      if (!validation.isValid) {
        return {
          isValid: false,
          error: `Error en ${key}: ${validation.error}`,
        };
      }
    }

    return { isValid: true };
  }
}
